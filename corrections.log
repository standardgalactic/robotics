 562, 309, 307, 5928, 300, 636, 294, 39048, 7712, 11, 309, 393, 841, 257, 857, 11, 731, 11, 4545, 4272, 13, 51779], "temperature": 0.0, "avg_logprob": -0.09732504915599981, "compression_ratio": 1.5796610169491525, "no_speech_prob": 6.983322340531339e-13}, {"id": 17, "seek": 5698, "start": 56.98, "end": 60.839999999999996, "text": " Right, like you put a specific voltage into one side and you get a specific current out the other.", "tokens": [50365, 1779, 11, 411, 291, 829, 257, 2685, 8352, 666, 472, 1252, 293, 291, 483, 257, 2685, 2190, 484, 264, 661, 13, 50558], "temperature": 0.0, "avg_logprob": -0.11755906142197646, "compression_ratio": 1.539906103286385, "no_speech_prob": 1.4953952789595326e-12}, {"id": 18, "seek": 5698, "start": 61.22, "end": 61.62, "text": " Exactly.", "tokens": [50577, 7587, 13, 50597], "temperature": 0.0, "avg_logprob": -0.11755906142197646, "compression_ratio": 1.539906103286385, "no_speech_prob": 1.4953952789595326e-12}, {"id": 19, "seek": 5698, "start": 61.779999999999994, "end": 67.58, "text": " The components are treated as nothing more than passive obstacles or, you know, just conduits for that energy.", "tokens": [50605, 440, 6677, 366, 8668, 382, 1825, 544, 813, 14975, 17735, 420, 11, 291, 458, 11, 445, 15504, 1208, 337, 300, 2281, 13, 50895], "temperature": 0.0, "avg_logprob": -0.11755906142197646, "compression_ratio": 1.539906103286385, "no_speech_prob": 1.4953952789595326e-12}, {"id": 20, "seek": 5698, "start": 68.0, "end": 74.88, "text": " But, so I've been completely consumed lately by this stack of material that just shatters that view entirely.", "tokens": [50916, 583, 11, 370, 286, 600, 668, 2584, 21226, 12881, 538, 341, 8630, 295, 2527, 300, 445, 402, 37690, 300, 1910, 7696, 13, 51260], "temperature": 0.0, "avg_logprob": -0.11755906142197646, "compression_ratio": 1.539906103286385, "no_speech_prob": 1.4953952789595326e-12}, {"id": 21, "seek": 7488, "start": 74.88, "end": 83.42, "text": " I mean, what if the circuit board inside the phone you're holding right now or the computer you are listening to this deep dive on isn't a dead grid at all?", "tokens": [50365, 286, 914, 11, 437, 498, 264, 9048, 3150, 1854, 264, 2593, 291, 434, 5061, 558, 586, 420, 264, 3820, 291, 366, 4764, 281, 341, 2452, 9192, 322, 1943, 380, 257, 3116, 10748, 412, 439, 30, 50792], "temperature": 0.0, "avg_logprob": -0.08823509705372345, "compression_ratio": 1.5418502202643172, "no_speech_prob": 1.2202596788926656e-12}, {"id": 22, "seek": 7488, "start": 83.56, "end": 85.32, "text": " Yeah, this new framework is wild.", "tokens": [50799, 865, 11, 341, 777, 8388, 307, 4868, 13, 50887], "temperature": 0.0, "avg_logprob": -0.08823509705372345, "compression_ratio": 1.5418502202643172, "no_speech_prob": 1.2202596788926656e-12}, {"id": 23, "seek": 7488, "start": 85.53999999999999, "end": 95.74, "text": " What if it is actually a living landscape of geometric transformations, thermodynamic battles, and, like, physical histories constantly competing for survival?", "tokens": [50898, 708, 498, 309, 307, 767, 257, 2647, 9661, 295, 33246, 34852, 11, 8810, 34988, 14648, 11, 293, 11, 411, 11, 4001, 30631, 6460, 15439, 337, 12559, 30, 51408], "temperature": 0.0, "avg_logprob": -0.08823509705372345, "compression_ratio": 1.5418502202643172, "no_speech_prob": 1.2202596788926656e-12}, {"id": 24, "seek": 9574, "start": 95.74, "end": 101.1, "text": " Looking at it through that specific framework completely changes how you interact with the physical world.", "tokens": [50365, 11053, 412, 309, 807, 300, 2685, 8388, 2584, 2962, 577, 291, 4648, 365, 264, 4001, 1002, 13, 50633], "temperature": 0.0, "avg_logprob": -0.12174434372873018, "compression_ratio": 1.6142857142857143, "no_speech_prob": 1.5492910773740043e-12}, {"id": 25, "seek": 9574, "start": 101.28, "end": 103.36, "text": " It really shifts the entire paradigm.", "tokens": [50642, 467, 534, 19201, 264, 2302, 24709, 13, 50746], "temperature": 0.0, "avg_logprob": -0.12174434372873018, "compression_ratio": 1.6142857142857143, "no_speech_prob": 1.5492910773740043e-12}, {"id": 26, "seek": 9574, "start": 103.69999999999999, "end": 104.16, "text": " It really does.", "tokens": [50763, 467, 534, 775, 13, 50786], "temperature": 0.0, "avg_logprob": -0.12174434372873018, "compression_ratio": 1.6142857142857143, "no_speech_prob": 1.5492910773740043e-12}, {"id": 27, "seek": 9574, "start": 104.17999999999999, "end": 114.44, "text": " You stop seeing simple electricity flowing through wires and you start seeing this profound philosophy of information and structure and existence really playing out in real time.", "tokens": [50787, 509, 1590, 2577, 2199, 10356, 13974, 807, 15537, 293, 291, 722, 2577, 341, 14382, 10675, 295, 1589, 293, 3877, 293, 9123, 534, 2433, 484, 294, 957, 565, 13, 51300], "temperature": 0.0, "avg_logprob": -0.12174434372873018, "compression_ratio": 1.6142857142857143, "no_speech_prob": 1.5492910773740043e-12}, {"id": 28, "seek": 11444, "start": 114.44, "end": 116.02, "text": " Okay, so let's unpack this.", "tokens": [50365, 1033, 11, 370, 718, 311, 26699, 341, 13, 50444], "temperature": 0.0, "avg_logprob": -0.1442134052241614, "compression_ratio": 1.4916943521594683, "no_speech_prob": 1.7897589877149955e-12}, {"id": 29, "seek": 11444, "start": 116.3, "end": 125.96, "text": " We're diving into a truly radical 2026 theoretical book by an independent researcher named Flixian titled The Continuation Geometry of Circuits.", "tokens": [50458, 492, 434, 20241, 666, 257, 4908, 12001, 945, 10880, 20864, 1446, 538, 364, 6695, 21751, 4926, 3235, 970, 952, 19841, 440, 14674, 16073, 2876, 34730, 295, 28938, 7688, 13, 50941], "temperature": 0.0, "avg_logprob": -0.1442134052241614, "compression_ratio": 1.4916943521594683, "no_speech_prob": 1.7897589877149955e-12}, {"id": 30, "seek": 11444, "start": 126.53999999999999, "end": 128.88, "text": " Let me tell you, I was skeptical at first.", "tokens": [50970, 961, 385, 980, 291, 11, 286, 390, 28601, 412, 700, 13, 51087], "temperature": 0.0, "avg_logprob": -0.1442134052241614, "compression_ratio": 1.4916943521594683, "no_speech_prob": 1.7897589877149955e-12}, {"id": 31, "seek": 11444, "start": 129.06, "end": 130.9, "text": " I think any reasonable person would be, yeah.", "tokens": [51096, 286, 519, 604, 10585, 954, 576, 312, 11, 1338, 13, 51188], "temperature": 0.0, "avg_logprob": -0.1442134052241614, "compression_ratio": 1.4916943521594683, "no_speech_prob": 1.7897589877149955e-12}, {"id": 32, "seek": 11444, "start": 130.94, "end": 131.32, "text": " Yeah, right.", "tokens": [51190, 865, 11, 558, 13, 51209], "temperature": 0.0, "avg_logprob": -0.1442134052241614, "compression_ratio": 1.4916943521594683, "no_speech_prob": 1.7897589877149955e-12}, {"id": 33, "seek": 11444, "start": 132.0, "end": 137.84, "text": " But this book takes everything you think you know about basic electronics and just completely flips the axis.", "tokens": [51243, 583, 341, 1446, 2516, 1203, 291, 519, 291, 458, 466, 3875, 20611, 293, 445, 2584, 40249, 264, 10298, 13, 51535], "temperature": 0.0, "avg_logprob": -0.1442134052241614, "compression_ratio": 1.4916943521594683, "no_speech_prob": 1.7897589877149955e-12}, {"id": 34, "seek": 11444, "start": 138.24, "end": 141.48, "text": " Like, components are no longer just resisting or storing charge.", "tokens": [51555, 1743, 11, 6677, 366, 572, 2854, 445, 43940, 420, 26085, 4602, 13, 51717], "temperature": 0.0, "avg_logprob": -0.1442134052241614, "compression_ratio": 1.4916943521594683, "no_speech_prob": 1.7897589877149955e-12}, {"id": 35, "seek": 14148, "start": 141.48, "end": 143.92, "text": " No, they're acting as these things called amplitwists.", "tokens": [50365, 883, 11, 436, 434, 6577, 382, 613, 721, 1219, 9731, 270, 86, 1751, 13, 50487], "temperature": 0.0, "avg_logprob": -0.16564705994752077, "compression_ratio": 1.5741444866920151, "no_speech_prob": 1.340477642081117e-12}, {"id": 36, "seek": 14148, "start": 144.2, "end": 145.22, "text": " Amplitwists, yes.", "tokens": [50501, 2012, 564, 270, 86, 1751, 11, 2086, 13, 50552], "temperature": 0.0, "avg_logprob": -0.16564705994752077, "compression_ratio": 1.5741444866920151, "no_speech_prob": 1.340477642081117e-12}, {"id": 37, "seek": 14148, "start": 145.6, "end": 151.92, "text": " And they are triggering sphere pop collapses and operating as strict admissibility gates.", "tokens": [50571, 400, 436, 366, 40406, 16687, 1665, 48765, 293, 7447, 382, 10910, 5910, 891, 2841, 19792, 13, 50887], "temperature": 0.0, "avg_logprob": -0.16564705994752077, "compression_ratio": 1.5741444866920151, "no_speech_prob": 1.340477642081117e-12}, {"id": 38, "seek": 14148, "start": 152.38, "end": 157.07999999999998, "text": " But what makes Flixian's book so compelling isn't just the flashy vocabulary.", "tokens": [50910, 583, 437, 1669, 3235, 970, 952, 311, 1446, 370, 20050, 1943, 380, 445, 264, 47873, 19864, 13, 51145], "temperature": 0.0, "avg_logprob": -0.16564705994752077, "compression_ratio": 1.5741444866920151, "no_speech_prob": 1.340477642081117e-12}, {"id": 39, "seek": 14148, "start": 157.48, "end": 160.5, "text": " I mean, the words are cool, but it's the underlying rigor.", "tokens": [51165, 286, 914, 11, 264, 2283, 366, 1627, 11, 457, 309, 311, 264, 14217, 42191, 13, 51316], "temperature": 0.0, "avg_logprob": -0.16564705994752077, "compression_ratio": 1.5741444866920151, "no_speech_prob": 1.340477642081117e-12}, {"id": 40, "seek": 14148, "start": 160.88, "end": 166.04, "text": " Yeah, they don't just throw wild science fiction-sounding geometric terms at the wall to see what sticks.", "tokens": [51335, 865, 11, 436, 500, 380, 445, 3507, 4868, 3497, 13266, 12, 82, 24625, 33246, 2115, 412, 264, 2929, 281, 536, 437, 12518, 13, 51593], "temperature": 0.0, "avg_logprob": -0.16564705994752077, "compression_ratio": 1.5741444866920151, "no_speech_prob": 1.340477642081117e-12}, {"id": 41, "seek": 14148, "start": 166.17999999999998, "end": 166.6, "text": " Exactly.", "tokens": [51600, 7587, 13, 51621], "temperature": 0.0, "avg_logprob": -0.16564705994752077, "compression_ratio": 1.5741444866920151, "no_speech_prob": 1.340477642081117e-12}, {"id": 42, "seek": 16660, "start": 166.6, "end": 172.14, "text": " They actually categorize every single claim in the book into three highly disciplined tiers.", "tokens": [50365, 814, 767, 19250, 1125, 633, 2167, 3932, 294, 264, 1446, 666, 1045, 5405, 40061, 40563, 13, 50642], "temperature": 0.0, "avg_logprob": -0.11522340774536133, "compression_ratio": 1.5912408759124088, "no_speech_prob": 1.4100006969289258e-12}, {"id": 43, "seek": 16660, "start": 172.68, "end": 178.98, "text": " It's a brilliant way to structure a sweeping theory like this without, you know, losing the engineers in the audience.", "tokens": [50669, 467, 311, 257, 10248, 636, 281, 3877, 257, 33285, 5261, 411, 341, 1553, 11, 291, 458, 11, 7027, 264, 11955, 294, 264, 4034, 13, 50984], "temperature": 0.0, "avg_logprob": -0.11522340774536133, "compression_ratio": 1.5912408759124088, "no_speech_prob": 1.4100006969289258e-12}, {"id": 44, "seek": 16660, "start": 179.07999999999998, "end": 182.04, "text": " Okay, let's start there because that structure really helped ground me.", "tokens": [50989, 1033, 11, 718, 311, 722, 456, 570, 300, 3877, 534, 4254, 2727, 385, 13, 51137], "temperature": 0.0, "avg_logprob": -0.11522340774536133, "compression_ratio": 1.5912408759124088, "no_speech_prob": 1.4100006969289258e-12}, {"id": 45, "seek": 16660, "start": 182.46, "end": 183.79999999999998, "text": " Tell me about these three tiers.", "tokens": [51158, 5115, 385, 466, 613, 1045, 40563, 13, 51225], "temperature": 0.0, "avg_logprob": -0.11522340774536133, "compression_ratio": 1.5912408759124088, "no_speech_prob": 1.4100006969289258e-12}, {"id": 46, "seek": 16660, "start": 184.16, "end": 186.79999999999998, "text": " So, tier one is entirely uncontroversial.", "tokens": [51243, 407, 11, 12362, 472, 307, 7696, 36019, 340, 840, 831, 13, 51375], "temperature": 0.0, "avg_logprob": -0.11522340774536133, "compression_ratio": 1.5912408759124088, "no_speech_prob": 1.4100006969289258e-12}, {"id": 47, "seek": 16660, "start": 186.94, "end": 188.44, "text": " It's just standard circuit facts.", "tokens": [51382, 467, 311, 445, 3832, 9048, 9130, 13, 51457], "temperature": 0.0, "avg_logprob": -0.11522340774536133, "compression_ratio": 1.5912408759124088, "no_speech_prob": 1.4100006969289258e-12}, {"id": 48, "seek": 16660, "start": 188.57999999999998, "end": 189.92, "text": " Like stuff you'd find in a textbook.", "tokens": [51464, 1743, 1507, 291, 1116, 915, 294, 257, 25591, 13, 51531], "temperature": 0.0, "avg_logprob": -0.11522340774536133, "compression_ratio": 1.5912408759124088, "no_speech_prob": 1.4100006969289258e-12}, {"id": 49, "seek": 16660, "start": 190.35999999999999, "end": 190.66, "text": " Right.", "tokens": [51553, 1779, 13, 51568], "temperature": 0.0, "avg_logprob": -0.11522340774536133, "compression_ratio": 1.5912408759124088, "no_speech_prob": 1.4100006969289258e-12}, {"id": 50, "seek": 19066, "start": 190.66, "end": 200.56, "text": " These are the undeniable realities of electronics, things no electrical engineer or physicist would ever disagree with, like the fact that a capacitor blocks direct current.", "tokens": [50365, 1981, 366, 264, 674, 268, 9364, 27785, 295, 20611, 11, 721, 572, 12147, 11403, 420, 42466, 576, 1562, 14091, 365, 11, 411, 264, 1186, 300, 257, 29372, 8474, 2047, 2190, 13, 50860], "temperature": 0.0, "avg_logprob": -0.1263624936684795, "compression_ratio": 1.5891472868217054, "no_speech_prob": 1.7963706694032466e-12}, {"id": 51, "seek": 19066, "start": 200.96, "end": 201.72, "text": " Makes sense.", "tokens": [50880, 25245, 2020, 13, 50918], "temperature": 0.0, "avg_logprob": -0.1263624936684795, "compression_ratio": 1.5891472868217054, "no_speech_prob": 1.7963706694032466e-12}, {"id": 52, "seek": 19066, "start": 201.92, "end": 202.72, "text": " So, what's tier two?", "tokens": [50928, 407, 11, 437, 311, 12362, 732, 30, 50968], "temperature": 0.0, "avg_logprob": -0.1263624936684795, "compression_ratio": 1.5891472868217054, "no_speech_prob": 1.7963706694032466e-12}, {"id": 53, "seek": 19066, "start": 203.0, "end": 207.06, "text": " Tier two then takes those accepted facts and proves structural equivalences.", "tokens": [50982, 24224, 732, 550, 2516, 729, 9035, 9130, 293, 25019, 15067, 9052, 2667, 13, 51185], "temperature": 0.0, "avg_logprob": -0.1263624936684795, "compression_ratio": 1.5891472868217054, "no_speech_prob": 1.7963706694032466e-12}, {"id": 54, "seek": 19066, "start": 207.72, "end": 215.48, "text": " The author uses mathematics to demonstrate that two seemingly different phenomena are, at their core, structurally identical.", "tokens": [51218, 440, 3793, 4960, 18666, 281, 11698, 300, 732, 18709, 819, 22004, 366, 11, 412, 641, 4965, 11, 6594, 6512, 14800, 13, 51606], "temperature": 0.0, "avg_logprob": -0.1263624936684795, "compression_ratio": 1.5891472868217054, "no_speech_prob": 1.7963706694032466e-12}, {"id": 55, "seek": 21548, "start": 215.48, "end": 216.04, "text": " Okay.", "tokens": [50365, 1033, 13, 50393], "temperature": 0.0, "avg_logprob": -0.1622700362369932, "compression_ratio": 1.6551724137931034, "no_speech_prob": 1.8899482673306878e-12}, {"id": 56, "seek": 21548, "start": 216.29999999999998, "end": 223.56, "text": " And finally, tier three is where the author takes those equivalences and completely reinterprets them through a geometric lens.", "tokens": [50406, 400, 2721, 11, 12362, 1045, 307, 689, 264, 3793, 2516, 729, 9052, 2667, 293, 2584, 319, 5106, 3712, 1373, 552, 807, 257, 33246, 6765, 13, 50769], "temperature": 0.0, "avg_logprob": -0.1622700362369932, "compression_ratio": 1.6551724137931034, "no_speech_prob": 1.8899482673306878e-12}, {"id": 57, "seek": 21548, "start": 223.88, "end": 225.92, "text": " I remember reading this section on Kirschhoff's laws.", "tokens": [50785, 286, 1604, 3760, 341, 3541, 322, 11305, 6145, 1289, 602, 311, 6064, 13, 50887], "temperature": 0.0, "avg_logprob": -0.1622700362369932, "compression_ratio": 1.6551724137931034, "no_speech_prob": 1.8899482673306878e-12}, {"id": 58, "seek": 21548, "start": 226.04, "end": 226.17999999999998, "text": " Yeah.", "tokens": [50893, 865, 13, 50900], "temperature": 0.0, "avg_logprob": -0.1622700362369932, "compression_ratio": 1.6551724137931034, "no_speech_prob": 1.8899482673306878e-12}, {"id": 59, "seek": 21548, "start": 226.32, "end": 228.39999999999998, "text": " And having this massive aha moment.", "tokens": [50907, 400, 1419, 341, 5994, 47340, 1623, 13, 51011], "temperature": 0.0, "avg_logprob": -0.1622700362369932, "compression_ratio": 1.6551724137931034, "no_speech_prob": 1.8899482673306878e-12}, {"id": 60, "seek": 21548, "start": 228.66, "end": 231.45999999999998, "text": " Because in school, you're taught Kirschhoff's current law, right?", "tokens": [51024, 1436, 294, 1395, 11, 291, 434, 5928, 11305, 6145, 1289, 602, 311, 2190, 2101, 11, 558, 30, 51164], "temperature": 0.0, "avg_logprob": -0.1622700362369932, "compression_ratio": 1.6551724137931034, "no_speech_prob": 1.8899482673306878e-12}, {"id": 61, "seek": 21548, "start": 231.82, "end": 234.85999999999999, "text": " The currents flowing into a node have to equal the currents flowing out.", "tokens": [51182, 440, 30110, 13974, 666, 257, 9984, 362, 281, 2681, 264, 30110, 13974, 484, 13, 51334], "temperature": 0.0, "avg_logprob": -0.1622700362369932, "compression_ratio": 1.6551724137931034, "no_speech_prob": 1.8899482673306878e-12}, {"id": 62, "seek": 21548, "start": 234.89999999999998, "end": 236.35999999999999, "text": " Yeah, the classic node rule.", "tokens": [51336, 865, 11, 264, 7230, 9984, 4978, 13, 51409], "temperature": 0.0, "avg_logprob": -0.1622700362369932, "compression_ratio": 1.6551724137931034, "no_speech_prob": 1.8899482673306878e-12}, {"id": 63, "seek": 21548, "start": 236.6, "end": 237.83999999999997, "text": " It's taught as a bookkeeping rule.", "tokens": [51421, 467, 311, 5928, 382, 257, 1446, 25769, 4978, 13, 51483], "temperature": 0.0, "avg_logprob": -0.1622700362369932, "compression_ratio": 1.6551724137931034, "no_speech_prob": 1.8899482673306878e-12}, {"id": 64, "seek": 23784, "start": 237.84, "end": 252.88, "text": " That shift from rule to conservation principle is huge.", "tokens": [50365, 663, 5513, 490, 4978, 281, 16185, 8665, 307, 2603, 13, 51117], "temperature": 0.0, "avg_logprob": -0.1921903337751116, "compression_ratio": 1.4545454545454546, "no_speech_prob": 1.7554039818956646e-12}, {"id": 65, "seek": 23784, "start": 253.0, "end": 257.12, "text": " I mean, the node in a circuit isn't just passively following a law written in a textbook.", "tokens": [51123, 286, 914, 11, 264, 9984, 294, 257, 9048, 1943, 380, 445, 1320, 3413, 3480, 257, 2101, 3720, 294, 257, 25591, 13, 51329], "temperature": 0.0, "avg_logprob": -0.1921903337751116, "compression_ratio": 1.4545454545454546, "no_speech_prob": 1.7554039818956646e-12}, {"id": 66, "seek": 23784, "start": 257.36, "end": 258.12, "text": " No, it's active.", "tokens": [51341, 883, 11, 309, 311, 4967, 13, 51379], "temperature": 0.0, "avg_logprob": -0.1921903337751116, "compression_ratio": 1.4545454545454546, "no_speech_prob": 1.7554039818956646e-12}, {"id": 67, "seek": 23784, "start": 258.48, "end": 258.68, "text": " Right.", "tokens": [51397, 1779, 13, 51407], "temperature": 0.0, "avg_logprob": -0.1921903337751116, "compression_ratio": 1.4545454545454546, "no_speech_prob": 1.7554039818956646e-12}, {"id": 68, "seek": 23784, "start": 258.68, "end": 263.82, "text": " It is a physical coordinate that is actively enforcing the conservation of charge in the steady state.", "tokens": [51407, 467, 307, 257, 4001, 15670, 300, 307, 13022, 25495, 2175, 264, 16185, 295, 4602, 294, 264, 13211, 1785, 13, 51664], "temperature": 0.0, "avg_logprob": -0.1921903337751116, "compression_ratio": 1.4545454545454546, "no_speech_prob": 1.7554039818956646e-12}, {"id": 69, "seek": 26382, "start": 263.82, "end": 270.14, "text": " The universe simply will not allow charge to accumulate infinitely at a point with zero volume.", "tokens": [50365, 440, 6445, 2935, 486, 406, 2089, 4602, 281, 33384, 36227, 412, 257, 935, 365, 4018, 5523, 13, 50681], "temperature": 0.0, "avg_logprob": -0.1456916864635875, "compression_ratio": 1.6360153256704981, "no_speech_prob": 1.5674036504473299e-12}, {"id": 70, "seek": 26382, "start": 270.74, "end": 274.64, "text": " So the geometry of the node forces the current to perfectly balance.", "tokens": [50711, 407, 264, 18426, 295, 264, 9984, 5874, 264, 2190, 281, 6239, 4772, 13, 50906], "temperature": 0.0, "avg_logprob": -0.1456916864635875, "compression_ratio": 1.6360153256704981, "no_speech_prob": 1.5674036504473299e-12}, {"id": 71, "seek": 26382, "start": 274.78, "end": 275.18, "text": " Exactly.", "tokens": [50913, 7587, 13, 50933], "temperature": 0.0, "avg_logprob": -0.1456916864635875, "compression_ratio": 1.6360153256704981, "no_speech_prob": 1.5674036504473299e-12}, {"id": 72, "seek": 26382, "start": 275.4, "end": 282.7, "text": " Well, if we're going to commit to viewing circuits geometrically and really buy into this landscape metaphor the book is building,", "tokens": [50944, 1042, 11, 498, 321, 434, 516, 281, 5599, 281, 17480, 26354, 12956, 81, 984, 293, 534, 2256, 666, 341, 9661, 19157, 264, 1446, 307, 2390, 11, 51309], "temperature": 0.0, "avg_logprob": -0.1456916864635875, "compression_ratio": 1.6360153256704981, "no_speech_prob": 1.5674036504473299e-12}, {"id": 73, "seek": 26382, "start": 282.96, "end": 285.76, "text": " we have to understand the foundational shape of that geometry.", "tokens": [51322, 321, 362, 281, 1223, 264, 32195, 3909, 295, 300, 18426, 13, 51462], "temperature": 0.0, "avg_logprob": -0.1456916864635875, "compression_ratio": 1.6360153256704981, "no_speech_prob": 1.5674036504473299e-12}, {"id": 74, "seek": 26382, "start": 285.96, "end": 287.88, "text": " Which brings us to the amplet whist.", "tokens": [51472, 3013, 5607, 505, 281, 264, 669, 14657, 315, 468, 13, 51568], "temperature": 0.0, "avg_logprob": -0.1456916864635875, "compression_ratio": 1.6360153256704981, "no_speech_prob": 1.5674036504473299e-12}, {"id": 75, "seek": 26382, "start": 288.03999999999996, "end": 289.53999999999996, "text": " Yes, the amplet whist.", "tokens": [51576, 1079, 11, 264, 669, 14657, 315, 468, 13, 51651], "temperature": 0.0, "avg_logprob": -0.1456916864635875, "compression_ratio": 1.6360153256704981, "no_speech_prob": 1.5674036504473299e-12}, {"id": 76, "seek": 28954, "start": 289.54, "end": 294.74, "text": " So to understand the amplet whist, we have to look at how we normally treat alternating current.", "tokens": [50365, 407, 281, 1223, 264, 669, 14657, 315, 468, 11, 321, 362, 281, 574, 412, 577, 321, 5646, 2387, 40062, 2190, 13, 50625], "temperature": 0.0, "avg_logprob": -0.14228122490496675, "compression_ratio": 1.6631944444444444, "no_speech_prob": 1.4215754224819466e-12}, {"id": 77, "seek": 28954, "start": 295.46000000000004, "end": 301.88, "text": " In standard circuit theory, when you have a sinusoidal wave-like, a wave constantly oscillating up and down,", "tokens": [50661, 682, 3832, 9048, 5261, 11, 562, 291, 362, 257, 41503, 17079, 304, 5772, 12, 4092, 11, 257, 5772, 6460, 18225, 990, 493, 293, 760, 11, 50982], "temperature": 0.0, "avg_logprob": -0.14228122490496675, "compression_ratio": 1.6631944444444444, "no_speech_prob": 1.4215754224819466e-12}, {"id": 78, "seek": 28954, "start": 302.6, "end": 307.58000000000004, "text": " we measure a component's resistance to that wave using a concept called impedance.", "tokens": [51018, 321, 3481, 257, 6542, 311, 7335, 281, 300, 5772, 1228, 257, 3410, 1219, 36264, 13, 51267], "temperature": 0.0, "avg_logprob": -0.14228122490496675, "compression_ratio": 1.6631944444444444, "no_speech_prob": 1.4215754224819466e-12}, {"id": 79, "seek": 28954, "start": 308.08000000000004, "end": 308.28000000000003, "text": " Right.", "tokens": [51292, 1779, 13, 51302], "temperature": 0.0, "avg_logprob": -0.14228122490496675, "compression_ratio": 1.6631944444444444, "no_speech_prob": 1.4215754224819466e-12}, {"id": 80, "seek": 28954, "start": 308.34000000000003, "end": 311.32000000000005, "text": " And we represent impedance mathematically as a complex number.", "tokens": [51305, 400, 321, 2906, 36264, 44003, 382, 257, 3997, 1230, 13, 51454], "temperature": 0.0, "avg_logprob": -0.14228122490496675, "compression_ratio": 1.6631944444444444, "no_speech_prob": 1.4215754224819466e-12}, {"id": 81, "seek": 28954, "start": 311.46000000000004, "end": 311.94, "text": " Precisely.", "tokens": [51461, 48746, 736, 13, 51485], "temperature": 0.0, "avg_logprob": -0.14228122490496675, "compression_ratio": 1.6631944444444444, "no_speech_prob": 1.4215754224819466e-12}, {"id": 82, "seek": 28954, "start": 312.04, "end": 314.36, "text": " A number with a real part and an imaginary part.", "tokens": [51490, 316, 1230, 365, 257, 957, 644, 293, 364, 26164, 644, 13, 51606], "temperature": 0.0, "avg_logprob": -0.14228122490496675, "compression_ratio": 1.6631944444444444, "no_speech_prob": 1.4215754224819466e-12}, {"id": 83, "seek": 28954, "start": 314.86, "end": 316.8, "text": " I always hated imaginary numbers in high school.", "tokens": [51631, 286, 1009, 17398, 26164, 3547, 294, 1090, 1395, 13, 51728], "temperature": 0.0, "avg_logprob": -0.14228122490496675, "compression_ratio": 1.6631944444444444, "no_speech_prob": 1.4215754224819466e-12}, {"id": 84, "seek": 28954, "start": 316.86, "end": 317.36, "text": " Oh, me too.", "tokens": [51731, 876, 11, 385, 886, 13, 51756], "temperature": 0.0, "avg_logprob": -0.14228122490496675, "compression_ratio": 1.6631944444444444, "no_speech_prob": 1.4215754224819466e-12}, {"id": 85, "seek": 31736, "start": 317.36, "end": 324.96000000000004, "text": " But the complex number tells you how a component, like a resistor or a coil of wire, changes the incoming voltage and current.", "tokens": [50365, 583, 264, 3997, 1230, 5112, 291, 577, 257, 6542, 11, 411, 257, 37672, 420, 257, 22225, 295, 6234, 11, 2962, 264, 22341, 8352, 293, 2190, 13, 50745], "temperature": 0.0, "avg_logprob": -0.12807820294354413, "compression_ratio": 1.6195286195286196, "no_speech_prob": 1.4609856293507084e-12}, {"id": 86, "seek": 31736, "start": 325.38, "end": 329.24, "text": " But fliction pulls a concept directly from visual complex analysis,", "tokens": [50766, 583, 932, 4105, 16982, 257, 3410, 3838, 490, 5056, 3997, 5215, 11, 50959], "temperature": 0.0, "avg_logprob": -0.12807820294354413, "compression_ratio": 1.6195286195286196, "no_speech_prob": 1.4609856293507084e-12}, {"id": 87, "seek": 31736, "start": 329.64, "end": 332.76, "text": " specifically referencing the mathematician Tristan Needham's work,", "tokens": [50979, 4682, 40582, 264, 48281, 1765, 7559, 16984, 4822, 311, 589, 11, 51135], "temperature": 0.0, "avg_logprob": -0.12807820294354413, "compression_ratio": 1.6195286195286196, "no_speech_prob": 1.4609856293507084e-12}, {"id": 88, "seek": 31736, "start": 333.12, "end": 339.2, "text": " and asks us to look at what that complex number is actually doing in a physical, geometric sense.", "tokens": [51153, 293, 8962, 505, 281, 574, 412, 437, 300, 3997, 1230, 307, 767, 884, 294, 257, 4001, 11, 33246, 2020, 13, 51457], "temperature": 0.0, "avg_logprob": -0.12807820294354413, "compression_ratio": 1.6195286195286196, "no_speech_prob": 1.4609856293507084e-12}, {"id": 89, "seek": 31736, "start": 339.40000000000003, "end": 341.02000000000004, "text": " Because it isn't just a static value.", "tokens": [51467, 1436, 309, 1943, 380, 445, 257, 13437, 2158, 13, 51548], "temperature": 0.0, "avg_logprob": -0.12807820294354413, "compression_ratio": 1.6195286195286196, "no_speech_prob": 1.4609856293507084e-12}, {"id": 90, "seek": 31736, "start": 341.18, "end": 342.3, "text": " No, it is an operator.", "tokens": [51556, 883, 11, 309, 307, 364, 12973, 13, 51612], "temperature": 0.0, "avg_logprob": -0.12807820294354413, "compression_ratio": 1.6195286195286196, "no_speech_prob": 1.4609856293507084e-12}, {"id": 91, "seek": 31736, "start": 342.62, "end": 345.58000000000004, "text": " It performs two physical actions on the wave simultaneously.", "tokens": [51628, 467, 26213, 732, 4001, 5909, 322, 264, 5772, 16561, 13, 51776], "temperature": 0.0, "avg_logprob": -0.12807820294354413, "compression_ratio": 1.6195286195286196, "no_speech_prob": 1.4609856293507084e-12}, {"id": 92, "seek": 34558, "start": 345.58, "end": 350.68, "text": " First, it scales the amplitude, making the physical wave bigger or smaller.", "tokens": [50365, 2386, 11, 309, 17408, 264, 27433, 11, 1455, 264, 4001, 5772, 3801, 420, 4356, 13, 50620], "temperature": 0.0, "avg_logprob": -0.1496971675327846, "compression_ratio": 1.8688524590163935, "no_speech_prob": 1.3724729902922506e-12}, {"id": 93, "seek": 34558, "start": 350.85999999999996, "end": 351.7, "text": " That's the amply part.", "tokens": [50629, 663, 311, 264, 669, 2724, 644, 13, 50671], "temperature": 0.0, "avg_logprob": -0.1496971675327846, "compression_ratio": 1.8688524590163935, "no_speech_prob": 1.3724729902922506e-12}, {"id": 94, "seek": 34558, "start": 351.84, "end": 352.0, "text": " Yep.", "tokens": [50678, 7010, 13, 50686], "temperature": 0.0, "avg_logprob": -0.1496971675327846, "compression_ratio": 1.8688524590163935, "no_speech_prob": 1.3724729902922506e-12}, {"id": 95, "seek": 34558, "start": 352.14, "end": 357.7, "text": " And second, it twists the phase, rotating the timing of the wave forward or backward in time.", "tokens": [50693, 400, 1150, 11, 309, 35290, 264, 5574, 11, 19627, 264, 10822, 295, 264, 5772, 2128, 420, 23897, 294, 565, 13, 50971], "temperature": 0.0, "avg_logprob": -0.1496971675327846, "compression_ratio": 1.8688524590163935, "no_speech_prob": 1.3724729902922506e-12}, {"id": 96, "seek": 34558, "start": 357.76, "end": 360.0, "text": " So it scales the amplitude and it twists the phase.", "tokens": [50974, 407, 309, 17408, 264, 27433, 293, 309, 35290, 264, 5574, 13, 51086], "temperature": 0.0, "avg_logprob": -0.1496971675327846, "compression_ratio": 1.8688524590163935, "no_speech_prob": 1.3724729902922506e-12}, {"id": 97, "seek": 34558, "start": 360.03999999999996, "end": 361.52, "text": " An amplitude and a twist.", "tokens": [51088, 1107, 27433, 293, 257, 8203, 13, 51162], "temperature": 0.0, "avg_logprob": -0.1496971675327846, "compression_ratio": 1.8688524590163935, "no_speech_prob": 1.3724729902922506e-12}, {"id": 98, "seek": 34558, "start": 361.79999999999995, "end": 362.59999999999997, "text": " An amplit whist.", "tokens": [51176, 1107, 9731, 270, 315, 468, 13, 51216], "temperature": 0.0, "avg_logprob": -0.1496971675327846, "compression_ratio": 1.8688524590163935, "no_speech_prob": 1.3724729902922506e-12}, {"id": 99, "seek": 34558, "start": 362.74, "end": 364.78, "text": " You combine the two and you get the amplit whist.", "tokens": [51223, 509, 10432, 264, 732, 293, 291, 483, 264, 9731, 270, 315, 468, 13, 51325], "temperature": 0.0, "avg_logprob": -0.1496971675327846, "compression_ratio": 1.8688524590163935, "no_speech_prob": 1.3724729902922506e-12}, {"id": 100, "seek": 36478, "start": 364.78, "end": 369.9, "text": " The impedance of a component is no longer just a passive property of the metal.", "tokens": [50365, 440, 36264, 295, 257, 6542, 307, 572, 2854, 445, 257, 14975, 4707, 295, 264, 5760, 13, 50621], "temperature": 0.0, "avg_logprob": -0.14757242202758789, "compression_ratio": 1.0394736842105263, "no_speech_prob": 1.243986142394904e-12}, {"id": 101, "seek": 36990, "start": 369.9, "end": 371.41999999999996, "text": " It's doing something active.", "tokens": [50365, 467, 311, 884, 746, 4967, 13, 50441], "temperature": 0.0, "avg_logprob": -0.0855061658998815, "compression_ratio": 1.6063348416289593, "no_speech_prob": 1.455289014296035e-12}, {"id": 102, "seek": 36990, "start": 371.53999999999996, "end": 379.64, "text": " It is an active geometric operator that reaches out, grabs the incoming wave, stretches it, and twists it before sending it on its way.", "tokens": [50447, 467, 307, 364, 4967, 33246, 12973, 300, 14235, 484, 11, 30028, 264, 22341, 5772, 11, 29058, 309, 11, 293, 35290, 309, 949, 7750, 309, 322, 1080, 636, 13, 50852], "temperature": 0.0, "avg_logprob": -0.0855061658998815, "compression_ratio": 1.6063348416289593, "no_speech_prob": 1.455289014296035e-12}, {"id": 103, "seek": 36990, "start": 379.84, "end": 384.17999999999995, "text": " The book draws a really hard line, though, about how these operators interact with each other.", "tokens": [50862, 440, 1446, 20045, 257, 534, 1152, 1622, 11, 1673, 11, 466, 577, 613, 19077, 4648, 365, 1184, 661, 13, 51079], "temperature": 0.0, "avg_logprob": -0.0855061658998815, "compression_ratio": 1.6063348416289593, "no_speech_prob": 1.455289014296035e-12}, {"id": 104, "seek": 36990, "start": 384.28, "end": 390.28, "text": " It makes this massive, like, uncompromising distinction between adding them and composing them.", "tokens": [51084, 467, 1669, 341, 5994, 11, 411, 11, 8585, 28722, 3436, 16844, 1296, 5127, 552, 293, 715, 6110, 552, 13, 51384], "temperature": 0.0, "avg_logprob": -0.0855061658998815, "compression_ratio": 1.6063348416289593, "no_speech_prob": 1.455289014296035e-12}, {"id": 105, "seek": 39028, "start": 390.28, "end": 396.23999999999995, "text": " What's fascinating here is that standard textbooks usually just teach you two memorized algebraic tricks.", "tokens": [50365, 708, 311, 10343, 510, 307, 300, 3832, 33587, 2673, 445, 2924, 291, 732, 46677, 21989, 299, 11733, 13, 50663], "temperature": 0.0, "avg_logprob": -0.15357721370199454, "compression_ratio": 1.5848214285714286, "no_speech_prob": 1.661733684682476e-12}, {"id": 106, "seek": 39028, "start": 396.34, "end": 397.03999999999996, "text": " Oh, I remember this.", "tokens": [50668, 876, 11, 286, 1604, 341, 13, 50703], "temperature": 0.0, "avg_logprob": -0.15357721370199454, "compression_ratio": 1.5848214285714286, "no_speech_prob": 1.661733684682476e-12}, {"id": 107, "seek": 39028, "start": 397.11999999999995, "end": 397.96, "text": " Series and parallel.", "tokens": [50707, 13934, 293, 8952, 13, 50749], "temperature": 0.0, "avg_logprob": -0.15357721370199454, "compression_ratio": 1.5848214285714286, "no_speech_prob": 1.661733684682476e-12}, {"id": 108, "seek": 39028, "start": 398.11999999999995, "end": 398.35999999999996, "text": " Exactly.", "tokens": [50757, 7587, 13, 50769], "temperature": 0.0, "avg_logprob": -0.15357721370199454, "compression_ratio": 1.5848214285714286, "no_speech_prob": 1.661733684682476e-12}, {"id": 109, "seek": 39028, "start": 398.76, "end": 403.21999999999997, "text": " If you wire components in series, end to end, you add their impedances together.", "tokens": [50789, 759, 291, 6234, 6677, 294, 2638, 11, 917, 281, 917, 11, 291, 909, 641, 22584, 2676, 1214, 13, 51012], "temperature": 0.0, "avg_logprob": -0.15357721370199454, "compression_ratio": 1.5848214285714286, "no_speech_prob": 1.661733684682476e-12}, {"id": 110, "seek": 39028, "start": 403.46, "end": 408.41999999999996, "text": " If you wire them in parallel, side by side, you add their admittances, which is just the inverse of impedance.", "tokens": [51024, 759, 291, 6234, 552, 294, 8952, 11, 1252, 538, 1252, 11, 291, 909, 641, 5910, 593, 2676, 11, 597, 307, 445, 264, 17340, 295, 36264, 13, 51272], "temperature": 0.0, "avg_logprob": -0.15357721370199454, "compression_ratio": 1.5848214285714286, "no_speech_prob": 1.661733684682476e-12}, {"id": 111, "seek": 39028, "start": 408.73999999999995, "end": 408.88, "text": " Right.", "tokens": [51288, 1779, 13, 51295], "temperature": 0.0, "avg_logprob": -0.15357721370199454, "compression_ratio": 1.5848214285714286, "no_speech_prob": 1.661733684682476e-12}, {"id": 112, "seek": 40888, "start": 408.88, "end": 415.3, "text": " Fliction points out that conceptually, both of those physical wirings are just operator addition.", "tokens": [50365, 3235, 4105, 2793, 484, 300, 3410, 671, 11, 1293, 295, 729, 4001, 1987, 1109, 366, 445, 12973, 4500, 13, 50686], "temperature": 0.0, "avg_logprob": -0.15293457394554502, "compression_ratio": 1.6713286713286712, "no_speech_prob": 2.4756466408121236e-12}, {"id": 113, "seek": 40888, "start": 415.7, "end": 416.06, "text": " How so?", "tokens": [50706, 1012, 370, 30, 50724], "temperature": 0.0, "avg_logprob": -0.15293457394554502, "compression_ratio": 1.6713286713286712, "no_speech_prob": 2.4756466408121236e-12}, {"id": 114, "seek": 40888, "start": 416.34, "end": 418.96, "text": " Well, the components are sharing a common environment.", "tokens": [50738, 1042, 11, 264, 6677, 366, 5414, 257, 2689, 2823, 13, 50869], "temperature": 0.0, "avg_logprob": -0.15293457394554502, "compression_ratio": 1.6713286713286712, "no_speech_prob": 2.4756466408121236e-12}, {"id": 115, "seek": 40888, "start": 419.5, "end": 425.92, "text": " Either they're experiencing the exact same current flowing through them, or they're feeling the exact same voltage across them.", "tokens": [50896, 13746, 436, 434, 11139, 264, 1900, 912, 2190, 13974, 807, 552, 11, 420, 436, 434, 2633, 264, 1900, 912, 8352, 2108, 552, 13, 51217], "temperature": 0.0, "avg_logprob": -0.15293457394554502, "compression_ratio": 1.6713286713286712, "no_speech_prob": 2.4756466408121236e-12}, {"id": 116, "seek": 40888, "start": 426.21999999999997, "end": 430.28, "text": " And their individual geometric effects simply sum together in a shared space.", "tokens": [51232, 400, 641, 2609, 33246, 5065, 2935, 2408, 1214, 294, 257, 5507, 1901, 13, 51435], "temperature": 0.0, "avg_logprob": -0.15293457394554502, "compression_ratio": 1.6713286713286712, "no_speech_prob": 2.4756466408121236e-12}, {"id": 117, "seek": 40888, "start": 430.46, "end": 433.21999999999997, "text": " But cascading them is an entirely different beast.", "tokens": [51444, 583, 3058, 66, 8166, 552, 307, 364, 7696, 819, 13464, 13, 51582], "temperature": 0.0, "avg_logprob": -0.15293457394554502, "compression_ratio": 1.6713286713286712, "no_speech_prob": 2.4756466408121236e-12}, {"id": 118, "seek": 40888, "start": 433.36, "end": 436.46, "text": " Cascading is a fundamentally different mathematical reality.", "tokens": [51589, 383, 4806, 8166, 307, 257, 17879, 819, 18894, 4103, 13, 51744], "temperature": 0.0, "avg_logprob": -0.15293457394554502, "compression_ratio": 1.6713286713286712, "no_speech_prob": 2.4756466408121236e-12}, {"id": 119, "seek": 43646, "start": 436.46, "end": 446.09999999999997, "text": " If you cascade two ports so, imagine a chain of amplifiers where the output wire of the first amplifier feeds directly into the input wire of the second amplifier.", "tokens": [50365, 759, 291, 50080, 732, 18160, 370, 11, 3811, 257, 5021, 295, 9731, 23463, 689, 264, 5598, 6234, 295, 264, 700, 27439, 23712, 3838, 666, 264, 4846, 6234, 295, 264, 1150, 27439, 13, 50847], "temperature": 0.0, "avg_logprob": -0.12729160184782695, "compression_ratio": 1.85, "no_speech_prob": 1.6292354835037437e-12}, {"id": 120, "seek": 43646, "start": 446.26, "end": 447.28, "text": " Like daisy-chaining them.", "tokens": [50855, 1743, 1120, 14169, 12, 339, 3686, 552, 13, 50906], "temperature": 0.0, "avg_logprob": -0.12729160184782695, "compression_ratio": 1.85, "no_speech_prob": 1.6292354835037437e-12}, {"id": 121, "seek": 43646, "start": 447.35999999999996, "end": 447.78, "text": " Exactly.", "tokens": [50910, 7587, 13, 50931], "temperature": 0.0, "avg_logprob": -0.12729160184782695, "compression_ratio": 1.85, "no_speech_prob": 1.6292354835037437e-12}, {"id": 122, "seek": 43646, "start": 448.03999999999996, "end": 449.96, "text": " That is no longer operator addition.", "tokens": [50944, 663, 307, 572, 2854, 12973, 4500, 13, 51040], "temperature": 0.0, "avg_logprob": -0.12729160184782695, "compression_ratio": 1.85, "no_speech_prob": 1.6292354835037437e-12}, {"id": 123, "seek": 43646, "start": 450.21999999999997, "end": 451.44, "text": " That is operator composition.", "tokens": [51053, 663, 307, 12973, 12686, 13, 51114], "temperature": 0.0, "avg_logprob": -0.12729160184782695, "compression_ratio": 1.85, "no_speech_prob": 1.6292354835037437e-12}, {"id": 124, "seek": 43646, "start": 451.88, "end": 455.97999999999996, "text": " The output reality of the first operator literally becomes the input reality of the second.", "tokens": [51136, 440, 5598, 4103, 295, 264, 700, 12973, 3736, 3643, 264, 4846, 4103, 295, 264, 1150, 13, 51341], "temperature": 0.0, "avg_logprob": -0.12729160184782695, "compression_ratio": 1.85, "no_speech_prob": 1.6292354835037437e-12}, {"id": 125, "seek": 43646, "start": 456.32, "end": 457.96, "text": " I love how visual this is.", "tokens": [51358, 286, 959, 577, 5056, 341, 307, 13, 51440], "temperature": 0.0, "avg_logprob": -0.12729160184782695, "compression_ratio": 1.85, "no_speech_prob": 1.6292354835037437e-12}, {"id": 126, "seek": 43646, "start": 458.32, "end": 464.62, "text": " When I was reading this section on cascading matched transmission lines, it made me think of the book's concept of an assembly index.", "tokens": [51458, 1133, 286, 390, 3760, 341, 3541, 322, 3058, 66, 8166, 21447, 11574, 3876, 11, 309, 1027, 385, 519, 295, 264, 1446, 311, 3410, 295, 364, 12103, 8186, 13, 51773], "temperature": 0.0, "avg_logprob": -0.12729160184782695, "compression_ratio": 1.85, "no_speech_prob": 1.6292354835037437e-12}, {"id": 127, "seek": 46462, "start": 464.62, "end": 466.62, "text": " Oh, the factory floor analogy.", "tokens": [50365, 876, 11, 264, 9265, 4123, 21663, 13, 50465], "temperature": 0.0, "avg_logprob": -0.1624832614775627, "compression_ratio": 1.77734375, "no_speech_prob": 1.5252706866628052e-12}, {"id": 128, "seek": 46462, "start": 466.74, "end": 467.7, "text": " That's a great one.", "tokens": [50471, 663, 311, 257, 869, 472, 13, 50519], "temperature": 0.0, "avg_logprob": -0.1624832614775627, "compression_ratio": 1.77734375, "no_speech_prob": 1.5252706866628052e-12}, {"id": 129, "seek": 46462, "start": 467.92, "end": 468.12, "text": " Yeah.", "tokens": [50530, 865, 13, 50540], "temperature": 0.0, "avg_logprob": -0.1624832614775627, "compression_ratio": 1.77734375, "no_speech_prob": 1.5252706866628052e-12}, {"id": 130, "seek": 46462, "start": 468.76, "end": 472.16, "text": " Imagine a literal assembly line of workers in a factory.", "tokens": [50572, 11739, 257, 20411, 12103, 1622, 295, 5600, 294, 257, 9265, 13, 50742], "temperature": 0.0, "avg_logprob": -0.1624832614775627, "compression_ratio": 1.77734375, "no_speech_prob": 1.5252706866628052e-12}, {"id": 131, "seek": 46462, "start": 473.18, "end": 479.16, "text": " The first worker takes the physical product coming down the belt, scales it up, and rotates it to the side.", "tokens": [50793, 440, 700, 11346, 2516, 264, 4001, 1674, 1348, 760, 264, 10750, 11, 17408, 309, 493, 11, 293, 42133, 309, 281, 264, 1252, 13, 51092], "temperature": 0.0, "avg_logprob": -0.1624832614775627, "compression_ratio": 1.77734375, "no_speech_prob": 1.5252706866628052e-12}, {"id": 132, "seek": 46462, "start": 479.38, "end": 480.56, "text": " That's a first amplit.", "tokens": [51103, 663, 311, 257, 700, 9731, 270, 13, 51162], "temperature": 0.0, "avg_logprob": -0.1624832614775627, "compression_ratio": 1.77734375, "no_speech_prob": 1.5252706866628052e-12}, {"id": 133, "seek": 46462, "start": 480.76, "end": 480.96, "text": " Right.", "tokens": [51172, 1779, 13, 51182], "temperature": 0.0, "avg_logprob": -0.1624832614775627, "compression_ratio": 1.77734375, "no_speech_prob": 1.5252706866628052e-12}, {"id": 134, "seek": 46462, "start": 481.38, "end": 484.12, "text": " Then they hand it directly to the next worker down the line.", "tokens": [51203, 1396, 436, 1011, 309, 3838, 281, 264, 958, 11346, 760, 264, 1622, 13, 51340], "temperature": 0.0, "avg_logprob": -0.1624832614775627, "compression_ratio": 1.77734375, "no_speech_prob": 1.5252706866628052e-12}, {"id": 135, "seek": 46462, "start": 484.74, "end": 489.56, "text": " That second worker takes it as it currently is, scales it again, and rotates it further.", "tokens": [51371, 663, 1150, 11346, 2516, 309, 382, 309, 4362, 307, 11, 17408, 309, 797, 11, 293, 42133, 309, 3052, 13, 51612], "temperature": 0.0, "avg_logprob": -0.1624832614775627, "compression_ratio": 1.77734375, "no_speech_prob": 1.5252706866628052e-12}, {"id": 136, "seek": 46462, "start": 489.68, "end": 492.58, "text": " So in this scenario, the total amplitude doesn't add.", "tokens": [51618, 407, 294, 341, 9005, 11, 264, 3217, 27433, 1177, 380, 909, 13, 51763], "temperature": 0.0, "avg_logprob": -0.1624832614775627, "compression_ratio": 1.77734375, "no_speech_prob": 1.5252706866628052e-12}, {"id": 137, "seek": 49258, "start": 492.58, "end": 497.34, "text": " It multiplies. But the twist, the physical rotation, adds sequentially.", "tokens": [50365, 467, 12788, 530, 13, 583, 264, 8203, 11, 264, 4001, 12447, 11, 10860, 5123, 3137, 13, 50603], "temperature": 0.0, "avg_logprob": -0.12873969078063965, "compression_ratio": 1.5863309352517985, "no_speech_prob": 1.5071272138275638e-12}, {"id": 138, "seek": 49258, "start": 497.53999999999996, "end": 500.97999999999996, "text": " That factory floor visualization captures the math perfectly.", "tokens": [50613, 663, 9265, 4123, 25801, 27986, 264, 5221, 6239, 13, 50785], "temperature": 0.0, "avg_logprob": -0.12873969078063965, "compression_ratio": 1.5863309352517985, "no_speech_prob": 1.5071272138275638e-12}, {"id": 139, "seek": 49258, "start": 501.53999999999996, "end": 507.8, "text": " Infliction argues that this geometric reality explains why audio and radio engineers do certain bizarre things in practice.", "tokens": [50813, 682, 3423, 4105, 38218, 300, 341, 33246, 4103, 13948, 983, 6278, 293, 6477, 11955, 360, 1629, 18265, 721, 294, 3124, 13, 51126], "temperature": 0.0, "avg_logprob": -0.12873969078063965, "compression_ratio": 1.5863309352517985, "no_speech_prob": 1.5071272138275638e-12}, {"id": 140, "seek": 49258, "start": 508.06, "end": 508.47999999999996, "text": " Like what?", "tokens": [51139, 1743, 437, 30, 51160], "temperature": 0.0, "avg_logprob": -0.12873969078063965, "compression_ratio": 1.5863309352517985, "no_speech_prob": 1.5071272138275638e-12}, {"id": 141, "seek": 49258, "start": 508.9, "end": 515.8, "text": " When engineers are working with a long chain of cascaded amplifiers, they almost never multiply raw power ratios in their heads.", "tokens": [51181, 1133, 11955, 366, 1364, 365, 257, 938, 5021, 295, 3058, 66, 12777, 9731, 23463, 11, 436, 1920, 1128, 12972, 8936, 1347, 32435, 294, 641, 8050, 13, 51526], "temperature": 0.0, "avg_logprob": -0.12873969078063965, "compression_ratio": 1.5863309352517985, "no_speech_prob": 1.5071272138275638e-12}, {"id": 142, "seek": 49258, "start": 515.88, "end": 517.5, "text": " They convert everything to decibels.", "tokens": [51530, 814, 7620, 1203, 281, 46358, 38383, 13, 51611], "temperature": 0.0, "avg_logprob": -0.12873969078063965, "compression_ratio": 1.5863309352517985, "no_speech_prob": 1.5071272138275638e-12}, {"id": 143, "seek": 49258, "start": 517.76, "end": 517.96, "text": " Right.", "tokens": [51624, 1779, 13, 51634], "temperature": 0.0, "avg_logprob": -0.12873969078063965, "compression_ratio": 1.5863309352517985, "no_speech_prob": 1.5071272138275638e-12}, {"id": 144, "seek": 51796, "start": 517.96, "end": 520.8000000000001, "text": " And they add the decibels together, and they add the phase angles.", "tokens": [50365, 400, 436, 909, 264, 46358, 38383, 1214, 11, 293, 436, 909, 264, 5574, 14708, 13, 50507], "temperature": 0.0, "avg_logprob": -0.16495152620168832, "compression_ratio": 1.6796875, "no_speech_prob": 1.4105204634504154e-12}, {"id": 145, "seek": 51796, "start": 521.38, "end": 522.2800000000001, "text": " But why do they do that?", "tokens": [50536, 583, 983, 360, 436, 360, 300, 30, 50581], "temperature": 0.0, "avg_logprob": -0.16495152620168832, "compression_ratio": 1.6796875, "no_speech_prob": 1.4105204634504154e-12}, {"id": 146, "seek": 51796, "start": 522.48, "end": 525.02, "text": " Just because the numbers are smaller and easier to manage.", "tokens": [50591, 1449, 570, 264, 3547, 366, 4356, 293, 3571, 281, 3067, 13, 50718], "temperature": 0.0, "avg_logprob": -0.16495152620168832, "compression_ratio": 1.6796875, "no_speech_prob": 1.4105204634504154e-12}, {"id": 147, "seek": 51796, "start": 525.1800000000001, "end": 527.02, "text": " Like, decibels are just logarithms, right?", "tokens": [50726, 1743, 11, 46358, 38383, 366, 445, 41473, 355, 2592, 11, 558, 30, 50818], "temperature": 0.0, "avg_logprob": -0.16495152620168832, "compression_ratio": 1.6796875, "no_speech_prob": 1.4105204634504154e-12}, {"id": 148, "seek": 51796, "start": 527.2, "end": 528.32, "text": " On the surface, yes.", "tokens": [50827, 1282, 264, 3753, 11, 2086, 13, 50883], "temperature": 0.0, "avg_logprob": -0.16495152620168832, "compression_ratio": 1.6796875, "no_speech_prob": 1.4105204634504154e-12}, {"id": 149, "seek": 51796, "start": 528.88, "end": 532.38, "text": " Logarithms mathematically convert multiplication into addition.", "tokens": [50911, 10824, 289, 355, 2592, 44003, 7620, 27290, 666, 4500, 13, 51086], "temperature": 0.0, "avg_logprob": -0.16495152620168832, "compression_ratio": 1.6796875, "no_speech_prob": 1.4105204634504154e-12}, {"id": 150, "seek": 51796, "start": 533.0400000000001, "end": 541.32, "text": " But structurally, Flitchin points out that these engineers are instinctively applying the mathematical chain rule for composed holomorphic derivatives.", "tokens": [51119, 583, 6594, 6512, 11, 3235, 1549, 259, 2793, 484, 300, 613, 11955, 366, 16556, 3413, 9275, 264, 18894, 5021, 4978, 337, 18204, 4091, 32702, 299, 33733, 13, 51533], "temperature": 0.0, "avg_logprob": -0.16495152620168832, "compression_ratio": 1.6796875, "no_speech_prob": 1.4105204634504154e-12}, {"id": 151, "seek": 54132, "start": 541.32, "end": 551.0400000000001, "text": " Okay, I have to pause you there. Composed holomorphic derivatives. That is exactly the kind of dense phrasing that intimidated me at first.", "tokens": [50365, 1033, 11, 286, 362, 281, 10465, 291, 456, 13, 6620, 1744, 4091, 32702, 299, 33733, 13, 663, 307, 2293, 264, 733, 295, 18011, 7636, 3349, 300, 40234, 385, 412, 700, 13, 50851], "temperature": 0.0, "avg_logprob": -0.12608538568019867, "compression_ratio": 1.3832335329341316, "no_speech_prob": 1.6875387805898034e-12}, {"id": 152, "seek": 54132, "start": 551.1800000000001, "end": 552.12, "text": " It is a mouthful.", "tokens": [50858, 467, 307, 257, 4525, 906, 13, 50905], "temperature": 0.0, "avg_logprob": -0.12608538568019867, "compression_ratio": 1.3832335329341316, "no_speech_prob": 1.6875387805898034e-12}, {"id": 153, "seek": 54132, "start": 552.2800000000001, "end": 554.5600000000001, "text": " What does holomorphic actually mean in this context?", "tokens": [50913, 708, 775, 4091, 32702, 299, 767, 914, 294, 341, 4319, 30, 51027], "temperature": 0.0, "avg_logprob": -0.12608538568019867, "compression_ratio": 1.3832335329341316, "no_speech_prob": 1.6875387805898034e-12}, {"id": 154, "seek": 54132, "start": 554.62, "end": 555.24, "text": " Let's break it down.", "tokens": [51030, 961, 311, 1821, 309, 760, 13, 51061], "temperature": 0.0, "avg_logprob": -0.12608538568019867, "compression_ratio": 1.3832335329341316, "no_speech_prob": 1.6875387805898034e-12}, {"id": 155, "seek": 55524, "start": 555.24, "end": 561.22, "text": " In complex math, a holomorphic function is a mapping that perfectly preserves local angles.", "tokens": [50365, 682, 3997, 5221, 11, 257, 4091, 32702, 299, 2445, 307, 257, 18350, 300, 6239, 1183, 9054, 2654, 14708, 13, 50664], "temperature": 0.0, "avg_logprob": -0.16393144607543944, "compression_ratio": 1.6370967741935485, "no_speech_prob": 1.443743345361237e-12}, {"id": 156, "seek": 55524, "start": 561.46, "end": 562.32, "text": " Preserves angles. Okay.", "tokens": [50676, 2718, 9054, 14708, 13, 1033, 13, 50719], "temperature": 0.0, "avg_logprob": -0.16393144607543944, "compression_ratio": 1.6370967741935485, "no_speech_prob": 1.443743345361237e-12}, {"id": 157, "seek": 55524, "start": 562.36, "end": 562.48, "text": " Yeah.", "tokens": [50721, 865, 13, 50727], "temperature": 0.0, "avg_logprob": -0.16393144607543944, "compression_ratio": 1.6370967741935485, "no_speech_prob": 1.443743345361237e-12}, {"id": 158, "seek": 55524, "start": 562.78, "end": 575.62, "text": " If you draw two lines intersecting at a 90-degree angle, and you push those lines through a holomorphic function, the resulting curves will still intersect at exactly 90 degrees, even if the whole shape has been stretched or rotated.", "tokens": [50742, 759, 291, 2642, 732, 3876, 27815, 278, 412, 257, 4289, 12, 34368, 5802, 11, 293, 291, 2944, 729, 3876, 807, 257, 4091, 32702, 299, 2445, 11, 264, 16505, 19490, 486, 920, 27815, 412, 2293, 4289, 5310, 11, 754, 498, 264, 1379, 3909, 575, 668, 23563, 420, 42146, 13, 51384], "temperature": 0.0, "avg_logprob": -0.16393144607543944, "compression_ratio": 1.6370967741935485, "no_speech_prob": 1.443743345361237e-12}, {"id": 159, "seek": 55524, "start": 575.88, "end": 577.88, "text": " So it doesn't warp the fundamental shape.", "tokens": [51397, 407, 309, 1177, 380, 36030, 264, 8088, 3909, 13, 51497], "temperature": 0.0, "avg_logprob": -0.16393144607543944, "compression_ratio": 1.6370967741935485, "no_speech_prob": 1.443743345361237e-12}, {"id": 160, "seek": 55524, "start": 578.16, "end": 578.6800000000001, "text": " Exactly.", "tokens": [51511, 7587, 13, 51537], "temperature": 0.0, "avg_logprob": -0.16393144607543944, "compression_ratio": 1.6370967741935485, "no_speech_prob": 1.443743345361237e-12}, {"id": 161, "seek": 57868, "start": 578.68, "end": 593.76, "text": " It is a smooth, continuous mapping. The mathematical chain rule tells us that when you compose two of these smooth mappings together, like our factory workers handing the product down the line, the total stretch factor is the multiplication of the individual stretches.", "tokens": [50365, 467, 307, 257, 5508, 11, 10957, 18350, 13, 440, 18894, 5021, 4978, 5112, 505, 300, 562, 291, 35925, 732, 295, 613, 5508, 463, 28968, 1214, 11, 411, 527, 9265, 5600, 34774, 264, 1674, 760, 264, 1622, 11, 264, 3217, 5985, 5952, 307, 264, 27290, 295, 264, 2609, 29058, 13, 51119], "temperature": 0.0, "avg_logprob": -0.05767633738341155, "compression_ratio": 1.7777777777777777, "no_speech_prob": 1.3562719740692342e-12}, {"id": 162, "seek": 57868, "start": 594.04, "end": 597.4399999999999, "text": " And the total rotation is the addition of the individual rotations.", "tokens": [51133, 400, 264, 3217, 12447, 307, 264, 4500, 295, 264, 2609, 44796, 13, 51303], "temperature": 0.0, "avg_logprob": -0.05767633738341155, "compression_ratio": 1.7777777777777777, "no_speech_prob": 1.3562719740692342e-12}, {"id": 163, "seek": 57868, "start": 597.7399999999999, "end": 598.28, "text": " You got it.", "tokens": [51318, 509, 658, 309, 13, 51345], "temperature": 0.0, "avg_logprob": -0.05767633738341155, "compression_ratio": 1.7777777777777777, "no_speech_prob": 1.3562719740692342e-12}, {"id": 164, "seek": 57868, "start": 598.4799999999999, "end": 607.68, "text": " So when an audio engineer is adding decibels and adding degrees of phase shift on a mixing console, they are literally doing complex geometry in their heads without realizing it.", "tokens": [51355, 407, 562, 364, 6278, 11403, 307, 5127, 46358, 38383, 293, 5127, 5310, 295, 5574, 5513, 322, 257, 11983, 11076, 11, 436, 366, 3736, 884, 3997, 18426, 294, 641, 8050, 1553, 16734, 309, 13, 51815], "temperature": 0.0, "avg_logprob": -0.05767633738341155, "compression_ratio": 1.7777777777777777, "no_speech_prob": 1.3562719740692342e-12}, {"id": 165, "seek": 60768, "start": 607.68, "end": 616.76, "text": " They are intuitively navigating the ampletwist geometry. The physical hardware perfectly mirrors the purer mathematics of holomorphic composition.", "tokens": [50365, 814, 366, 46506, 32054, 264, 9731, 302, 86, 468, 18426, 13, 440, 4001, 8837, 6239, 24238, 264, 1864, 260, 18666, 295, 4091, 32702, 299, 12686, 13, 50819], "temperature": 0.0, "avg_logprob": -0.13541987089984184, "compression_ratio": 1.5876288659793814, "no_speech_prob": 1.9271945150833858e-12}, {"id": 166, "seek": 60768, "start": 617.16, "end": 619.3599999999999, "text": " Now, I have to play the skeptic for a moment here.", "tokens": [50839, 823, 11, 286, 362, 281, 862, 264, 19128, 299, 337, 257, 1623, 510, 13, 50949], "temperature": 0.0, "avg_logprob": -0.13541987089984184, "compression_ratio": 1.5876288659793814, "no_speech_prob": 1.9271945150833858e-12}, {"id": 167, "seek": 60768, "start": 619.4399999999999, "end": 619.9599999999999, "text": " Go for it.", "tokens": [50953, 1037, 337, 309, 13, 50979], "temperature": 0.0, "avg_logprob": -0.13541987089984184, "compression_ratio": 1.5876288659793814, "no_speech_prob": 1.9271945150833858e-12}, {"id": 168, "seek": 60768, "start": 620.0, "end": 625.88, "text": " Because as I was reading all of this about ampletwists and holomorphic derivatives, a warning light started flashing in my head.", "tokens": [50981, 1436, 382, 286, 390, 3760, 439, 295, 341, 466, 9731, 302, 86, 1751, 293, 4091, 32702, 299, 33733, 11, 257, 9164, 1442, 1409, 31049, 294, 452, 1378, 13, 51275], "temperature": 0.0, "avg_logprob": -0.13541987089984184, "compression_ratio": 1.5876288659793814, "no_speech_prob": 1.9271945150833858e-12}, {"id": 169, "seek": 60768, "start": 625.88, "end": 631.52, "text": " I found myself thinking, isn't this just a pretentious way of saying complex multiplication?", "tokens": [51275, 286, 1352, 2059, 1953, 11, 1943, 380, 341, 445, 257, 1162, 317, 851, 636, 295, 1566, 3997, 27290, 30, 51557], "temperature": 0.0, "avg_logprob": -0.13541987089984184, "compression_ratio": 1.5876288659793814, "no_speech_prob": 1.9271945150833858e-12}, {"id": 170, "seek": 60768, "start": 631.9799999999999, "end": 634.4, "text": " Ah, the idle renaming critique.", "tokens": [51580, 2438, 11, 264, 30650, 8124, 5184, 25673, 13, 51701], "temperature": 0.0, "avg_logprob": -0.13541987089984184, "compression_ratio": 1.5876288659793814, "no_speech_prob": 1.9271945150833858e-12}, {"id": 171, "seek": 63440, "start": 634.4, "end": 644.4399999999999, "text": " Yeah. Are we just taking a simple algebraic concept, slapping a cool science fiction word like ampletwist on it, and pretending we discovered a new law of physics?", "tokens": [50365, 865, 13, 2014, 321, 445, 1940, 257, 2199, 21989, 299, 3410, 11, 8039, 3759, 257, 1627, 3497, 13266, 1349, 411, 9731, 302, 86, 468, 322, 309, 11, 293, 22106, 321, 6941, 257, 777, 2101, 295, 10649, 30, 50867], "temperature": 0.0, "avg_logprob": -0.08230576404305391, "compression_ratio": 1.5252100840336134, "no_speech_prob": 2.7077034191191895e-12}, {"id": 172, "seek": 63440, "start": 644.8, "end": 648.76, "text": " It is the absolute most important question a reader can ask of this theory.", "tokens": [50885, 467, 307, 264, 8236, 881, 1021, 1168, 257, 15149, 393, 1029, 295, 341, 5261, 13, 51083], "temperature": 0.0, "avg_logprob": -0.08230576404305391, "compression_ratio": 1.5252100840336134, "no_speech_prob": 2.7077034191191895e-12}, {"id": 173, "seek": 63440, "start": 649.02, "end": 656.28, "text": " Well, the author actually brings this exact critique up directly in the text. They call it failure mode one, idle renaming.", "tokens": [51096, 1042, 11, 264, 3793, 767, 5607, 341, 1900, 25673, 493, 3838, 294, 264, 2487, 13, 814, 818, 309, 7763, 4391, 472, 11, 30650, 8124, 5184, 13, 51459], "temperature": 0.0, "avg_logprob": -0.08230576404305391, "compression_ratio": 1.5252100840336134, "no_speech_prob": 2.7077034191191895e-12}, {"id": 174, "seek": 65628, "start": 656.28, "end": 665.0, "text": " An affliction where merely playing a game of vocabulary, taking established math, and putting a new coat of paint on it, this book would be conceptually useless.", "tokens": [50365, 1107, 2096, 75, 4105, 689, 17003, 2433, 257, 1216, 295, 19864, 11, 1940, 7545, 5221, 11, 293, 3372, 257, 777, 10690, 295, 4225, 322, 309, 11, 341, 1446, 576, 312, 3410, 671, 14115, 13, 50801], "temperature": 0.0, "avg_logprob": -0.13781334224500155, "compression_ratio": 1.4691943127962086, "no_speech_prob": 1.5191875535336408e-12}, {"id": 175, "seek": 65628, "start": 665.6, "end": 669.68, "text": " But they vigorously defend against the charge of idle renaming.", "tokens": [50831, 583, 436, 42396, 5098, 8602, 1970, 264, 4602, 295, 30650, 8124, 5184, 13, 51035], "temperature": 0.0, "avg_logprob": -0.13781334224500155, "compression_ratio": 1.4691943127962086, "no_speech_prob": 1.5191875535336408e-12}, {"id": 176, "seek": 65628, "start": 670.1, "end": 674.28, "text": " So how do they justify it? What is the structural value of calling it an ampletwist?", "tokens": [51056, 407, 577, 360, 436, 20833, 309, 30, 708, 307, 264, 15067, 2158, 295, 5141, 309, 364, 9731, 302, 86, 468, 30, 51265], "temperature": 0.0, "avg_logprob": -0.13781334224500155, "compression_ratio": 1.4691943127962086, "no_speech_prob": 1.5191875535336408e-12}, {"id": 177, "seek": 67428, "start": 674.28, "end": 690.6, "text": " The value lies in how the vocabulary forces your brain to categorize the physical world. By demanding that you view the component as an active geometric operator rather than a passive number, you are forced to separate operator addition from operator composition.", "tokens": [50365, 440, 2158, 9134, 294, 577, 264, 19864, 5874, 428, 3567, 281, 19250, 1125, 264, 4001, 1002, 13, 3146, 19960, 300, 291, 1910, 264, 6542, 382, 364, 4967, 33246, 12973, 2831, 813, 257, 14975, 1230, 11, 291, 366, 7579, 281, 4994, 12973, 4500, 490, 12973, 12686, 13, 51181], "temperature": 0.0, "avg_logprob": -0.09946039975699732, "compression_ratio": 1.5425531914893618, "no_speech_prob": 1.9204000369088536e-12}, {"id": 178, "seek": 67428, "start": 690.86, "end": 692.02, "text": " Which people mix up a lot.", "tokens": [51194, 3013, 561, 2890, 493, 257, 688, 13, 51252], "temperature": 0.0, "avg_logprob": -0.09946039975699732, "compression_ratio": 1.5425531914893618, "no_speech_prob": 1.9204000369088536e-12}, {"id": 179, "seek": 69202, "start": 692.02, "end": 696.6999999999999, "text": " Constantly. Students and even seasoned engineers constantly muddle these concepts.", "tokens": [50365, 8574, 3627, 13, 17244, 293, 754, 30111, 11955, 6460, 8933, 2285, 613, 10392, 13, 50599], "temperature": 0.0, "avg_logprob": -0.0725061406894606, "compression_ratio": 1.657243816254417, "no_speech_prob": 1.8756279081960647e-12}, {"id": 180, "seek": 69202, "start": 697.34, "end": 705.98, "text": " They try to apply cascading math to parallel circuits, or vice versa, and get confused when the physical circuit behaves wildly differently than their equations predicted.", "tokens": [50631, 814, 853, 281, 3079, 3058, 66, 8166, 5221, 281, 8952, 26354, 11, 420, 11964, 25650, 11, 293, 483, 9019, 562, 264, 4001, 9048, 36896, 34731, 7614, 813, 641, 11787, 19147, 13, 51063], "temperature": 0.0, "avg_logprob": -0.0725061406894606, "compression_ratio": 1.657243816254417, "no_speech_prob": 1.8756279081960647e-12}, {"id": 181, "seek": 69202, "start": 706.18, "end": 706.46, "text": " Oh, wow.", "tokens": [51073, 876, 11, 6076, 13, 51087], "temperature": 0.0, "avg_logprob": -0.0725061406894606, "compression_ratio": 1.657243816254417, "no_speech_prob": 1.8756279081960647e-12}, {"id": 182, "seek": 69202, "start": 706.62, "end": 720.24, "text": " By framing it geometrically, you instantly see why the mathematical chain rule perfectly describes a cascade of amplifiers, but completely, utterly fails if you just wire those same amplifiers in parallel.", "tokens": [51095, 3146, 28971, 309, 12956, 81, 984, 11, 291, 13518, 536, 983, 264, 18894, 5021, 4978, 6239, 15626, 257, 50080, 295, 9731, 23463, 11, 457, 2584, 11, 30251, 18199, 498, 291, 445, 6234, 729, 912, 9731, 23463, 294, 8952, 13, 51776], "temperature": 0.0, "avg_logprob": -0.0725061406894606, "compression_ratio": 1.657243816254417, "no_speech_prob": 1.8756279081960647e-12}, {"id": 183, "seek": 72024, "start": 720.24, "end": 723.96, "text": " Because the physical topology of the circuit dictates the geometry of the math.", "tokens": [50365, 1436, 264, 4001, 1192, 1793, 295, 264, 9048, 12569, 1024, 264, 18426, 295, 264, 5221, 13, 50551], "temperature": 0.0, "avg_logprob": -0.13363618235434255, "compression_ratio": 1.6498422712933754, "no_speech_prob": 2.092735056427597e-12}, {"id": 184, "seek": 72024, "start": 724.08, "end": 730.24, "text": " Exactly. It provides you with an entirely new mental toolbox to categorize the physical world.", "tokens": [50557, 7587, 13, 467, 6417, 291, 365, 364, 7696, 777, 4973, 44593, 281, 19250, 1125, 264, 4001, 1002, 13, 50865], "temperature": 0.0, "avg_logprob": -0.13363618235434255, "compression_ratio": 1.6498422712933754, "no_speech_prob": 2.092735056427597e-12}, {"id": 185, "seek": 72024, "start": 730.48, "end": 736.48, "text": " And that new toolbox gives us a breathtakingly elegant way to understand phenomena like resonance.", "tokens": [50877, 400, 300, 777, 44593, 2709, 505, 257, 48393, 356, 21117, 636, 281, 1223, 22004, 411, 30944, 13, 51177], "temperature": 0.0, "avg_logprob": -0.13363618235434255, "compression_ratio": 1.6498422712933754, "no_speech_prob": 2.092735056427597e-12}, {"id": 186, "seek": 72024, "start": 736.7, "end": 738.36, "text": " Yes. Resonance.", "tokens": [51188, 1079, 13, 5015, 266, 719, 13, 51271], "temperature": 0.0, "avg_logprob": -0.13363618235434255, "compression_ratio": 1.6498422712933754, "no_speech_prob": 2.092735056427597e-12}, {"id": 187, "seek": 72024, "start": 738.38, "end": 741.1800000000001, "text": " This is one of those moments where the book just made something click for me.", "tokens": [51272, 639, 307, 472, 295, 729, 6065, 689, 264, 1446, 445, 1027, 746, 2052, 337, 385, 13, 51412], "temperature": 0.0, "avg_logprob": -0.13363618235434255, "compression_ratio": 1.6498422712933754, "no_speech_prob": 2.092735056427597e-12}, {"id": 188, "seek": 72024, "start": 741.32, "end": 742.26, "text": " It's a great section.", "tokens": [51419, 467, 311, 257, 869, 3541, 13, 51466], "temperature": 0.0, "avg_logprob": -0.13363618235434255, "compression_ratio": 1.6498422712933754, "no_speech_prob": 2.092735056427597e-12}, {"id": 189, "seek": 72024, "start": 742.5, "end": 749.04, "text": " Normally when you study an RLC circuit, which is just a circuit with a resistor and a ductor coil and a capacitor all wired together,", "tokens": [51478, 17424, 562, 291, 2979, 364, 497, 14766, 9048, 11, 597, 307, 445, 257, 9048, 365, 257, 37672, 293, 257, 25954, 284, 22225, 293, 257, 29372, 439, 27415, 1214, 11, 51805], "temperature": 0.0, "avg_logprob": -0.13363618235434255, "compression_ratio": 1.6498422712933754, "no_speech_prob": 2.092735056427597e-12}, {"id": 190, "seek": 74904, "start": 749.04, "end": 758.4, "text": " you are taught that resonance is simply the specific frequency where the inductive reactants and the capacitive reactants perfectly cancel each other out.", "tokens": [50365, 291, 366, 5928, 300, 30944, 307, 2935, 264, 2685, 7893, 689, 264, 31612, 488, 4515, 1719, 293, 264, 4637, 2187, 4515, 1719, 6239, 10373, 1184, 661, 484, 13, 50833], "temperature": 0.0, "avg_logprob": -0.14110273184235564, "compression_ratio": 1.6736401673640167, "no_speech_prob": 1.4954010252310468e-12}, {"id": 191, "seek": 74904, "start": 758.5799999999999, "end": 761.3199999999999, "text": " Right. It's presented as just a neat little algebraic cancellation.", "tokens": [50842, 1779, 13, 467, 311, 8212, 382, 445, 257, 10654, 707, 21989, 299, 45867, 13, 50979], "temperature": 0.0, "avg_logprob": -0.14110273184235564, "compression_ratio": 1.6736401673640167, "no_speech_prob": 1.4954010252310468e-12}, {"id": 192, "seek": 74904, "start": 761.9599999999999, "end": 770.02, "text": " But geometrically, within this framework, fliction defines resonance not as a cancellation, but as an amplit-wist fixed point.", "tokens": [51011, 583, 12956, 81, 984, 11, 1951, 341, 8388, 11, 932, 4105, 23122, 30944, 406, 382, 257, 45867, 11, 457, 382, 364, 9731, 270, 12, 86, 468, 6806, 935, 13, 51414], "temperature": 0.0, "avg_logprob": -0.14110273184235564, "compression_ratio": 1.6736401673640167, "no_speech_prob": 1.4954010252310468e-12}, {"id": 193, "seek": 74904, "start": 770.16, "end": 771.66, "text": " Amplit-wist fixed point.", "tokens": [51421, 2012, 564, 270, 12, 86, 468, 6806, 935, 13, 51496], "temperature": 0.0, "avg_logprob": -0.14110273184235564, "compression_ratio": 1.6736401673640167, "no_speech_prob": 1.4954010252310468e-12}, {"id": 194, "seek": 74904, "start": 771.74, "end": 772.8, "text": " This sounds so permanent.", "tokens": [51500, 639, 3263, 370, 10996, 13, 51553], "temperature": 0.0, "avg_logprob": -0.14110273184235564, "compression_ratio": 1.6736401673640167, "no_speech_prob": 1.4954010252310468e-12}, {"id": 195, "seek": 77280, "start": 772.8, "end": 775.28, "text": " Well, it describes a beautiful physical alignment.", "tokens": [50365, 1042, 11, 309, 15626, 257, 2238, 4001, 18515, 13, 50489], "temperature": 0.0, "avg_logprob": -0.10037863114300896, "compression_ratio": 1.6553191489361703, "no_speech_prob": 1.832194118644992e-12}, {"id": 196, "seek": 77280, "start": 775.8599999999999, "end": 786.0999999999999, "text": " What it means is that as you sweep the frequency of the wave up and down, there is one specific magic frequency where the rotation, the twist, vanishes entirely.", "tokens": [50518, 708, 309, 1355, 307, 300, 382, 291, 22169, 264, 7893, 295, 264, 5772, 493, 293, 760, 11, 456, 307, 472, 2685, 5585, 7893, 689, 264, 12447, 11, 264, 8203, 11, 3161, 16423, 7696, 13, 51030], "temperature": 0.0, "avg_logprob": -0.10037863114300896, "compression_ratio": 1.6553191489361703, "no_speech_prob": 1.832194118644992e-12}, {"id": 197, "seek": 77280, "start": 786.3, "end": 789.54, "text": " The geometric operator completely stops twisting the wave in time.", "tokens": [51040, 440, 33246, 12973, 2584, 10094, 34491, 264, 5772, 294, 565, 13, 51202], "temperature": 0.0, "avg_logprob": -0.10037863114300896, "compression_ratio": 1.6553191489361703, "no_speech_prob": 1.832194118644992e-12}, {"id": 198, "seek": 77280, "start": 789.64, "end": 795.76, "text": " Right. It degenerates from a complex operation of rotating and scaling into a pure, simple scaling operation.", "tokens": [51207, 1779, 13, 467, 40520, 1024, 490, 257, 3997, 6916, 295, 19627, 293, 21589, 666, 257, 6075, 11, 2199, 21589, 6916, 13, 51513], "temperature": 0.0, "avg_logprob": -0.10037863114300896, "compression_ratio": 1.6553191489361703, "no_speech_prob": 1.832194118644992e-12}, {"id": 199, "seek": 79576, "start": 795.76, "end": 801.4, "text": " The voltage wave and the current wave lock into absolute perfect temporal alignment.", "tokens": [50365, 440, 8352, 5772, 293, 264, 2190, 5772, 4017, 666, 8236, 2176, 30881, 18515, 13, 50647], "temperature": 0.0, "avg_logprob": -0.1594224642681819, "compression_ratio": 1.7042801556420233, "no_speech_prob": 1.4325101434925491e-12}, {"id": 200, "seek": 79576, "start": 802.16, "end": 804.16, "text": " Visually, they become perfectly collinear.", "tokens": [50685, 10410, 671, 11, 436, 1813, 6239, 1263, 533, 289, 13, 50785], "temperature": 0.0, "avg_logprob": -0.1594224642681819, "compression_ratio": 1.7042801556420233, "no_speech_prob": 1.4325101434925491e-12}, {"id": 201, "seek": 79576, "start": 804.46, "end": 807.52, "text": " So the component just stops fighting the timing of the wave.", "tokens": [50800, 407, 264, 6542, 445, 10094, 5237, 264, 10822, 295, 264, 5772, 13, 50953], "temperature": 0.0, "avg_logprob": -0.1594224642681819, "compression_ratio": 1.7042801556420233, "no_speech_prob": 1.4325101434925491e-12}, {"id": 202, "seek": 79576, "start": 807.86, "end": 809.86, "text": " It surrenders the phase and just scales the height.", "tokens": [50970, 467, 36862, 433, 264, 5574, 293, 445, 17408, 264, 6681, 13, 51070], "temperature": 0.0, "avg_logprob": -0.1594224642681819, "compression_ratio": 1.7042801556420233, "no_speech_prob": 1.4325101434925491e-12}, {"id": 203, "seek": 79576, "start": 810.06, "end": 821.06, "text": " It actively selects the one single frequency in the entire universe where it can interact purely with the amplitude without imposing any temporal rotation or delay on the signal passing through it.", "tokens": [51080, 467, 13022, 3048, 82, 264, 472, 2167, 7893, 294, 264, 2302, 6445, 689, 309, 393, 4648, 17491, 365, 264, 27433, 1553, 40288, 604, 30881, 12447, 420, 8577, 322, 264, 6358, 8437, 807, 309, 13, 51630], "temperature": 0.0, "avg_logprob": -0.1594224642681819, "compression_ratio": 1.7042801556420233, "no_speech_prob": 1.4325101434925491e-12}, {"id": 204, "seek": 82106, "start": 821.06, "end": 822.18, "text": " So what does this all mean?", "tokens": [50365, 407, 437, 775, 341, 439, 914, 30, 50421], "temperature": 0.0, "avg_logprob": -0.12514409312495478, "compression_ratio": 1.6716981132075472, "no_speech_prob": 2.6663929311027124e-12}, {"id": 205, "seek": 82106, "start": 822.3399999999999, "end": 827.2399999999999, "text": " It means we have this beautiful, pristine, reversible world of amplit-wists.", "tokens": [50429, 467, 1355, 321, 362, 341, 2238, 11, 582, 42745, 11, 44788, 1002, 295, 9731, 270, 12, 86, 1751, 13, 50674], "temperature": 0.0, "avg_logprob": -0.12514409312495478, "compression_ratio": 1.6716981132075472, "no_speech_prob": 2.6663929311027124e-12}, {"id": 206, "seek": 82106, "start": 827.4, "end": 828.9, "text": " Reversible is the key word there.", "tokens": [50682, 1300, 840, 964, 307, 264, 2141, 1349, 456, 13, 50757], "temperature": 0.0, "avg_logprob": -0.12514409312495478, "compression_ratio": 1.6716981132075472, "no_speech_prob": 2.6663929311027124e-12}, {"id": 207, "seek": 82106, "start": 828.9, "end": 842.3199999999999, "text": " If I am standing at the end of that factory assembly line and I have the final output product and I know exactly what operations the workers performed, I can perfectly rewind the mathematics to deduce exactly what the original input looked like.", "tokens": [50757, 759, 286, 669, 4877, 412, 264, 917, 295, 300, 9265, 12103, 1622, 293, 286, 362, 264, 2572, 5598, 1674, 293, 286, 458, 2293, 437, 7705, 264, 5600, 10332, 11, 286, 393, 6239, 41458, 264, 18666, 281, 4172, 4176, 2293, 437, 264, 3380, 4846, 2956, 411, 13, 51428], "temperature": 0.0, "avg_logprob": -0.12514409312495478, "compression_ratio": 1.6716981132075472, "no_speech_prob": 2.6663929311027124e-12}, {"id": 208, "seek": 82106, "start": 842.42, "end": 843.8199999999999, "text": " It is totally invertible.", "tokens": [51433, 467, 307, 3879, 33966, 964, 13, 51503], "temperature": 0.0, "avg_logprob": -0.12514409312495478, "compression_ratio": 1.6716981132075472, "no_speech_prob": 2.6663929311027124e-12}, {"id": 209, "seek": 82106, "start": 843.9799999999999, "end": 844.9599999999999, "text": " You can run the movie backwards.", "tokens": [51511, 509, 393, 1190, 264, 3169, 12204, 13, 51560], "temperature": 0.0, "avg_logprob": -0.12514409312495478, "compression_ratio": 1.6716981132075472, "no_speech_prob": 2.6663929311027124e-12}, {"id": 210, "seek": 84496, "start": 844.96, "end": 850.52, "text": " But the real world of electronics isn't always reversible, is it?", "tokens": [50365, 583, 264, 957, 1002, 295, 20611, 1943, 380, 1009, 44788, 11, 307, 309, 30, 50643], "temperature": 0.0, "avg_logprob": -0.1283102968464727, "compression_ratio": 1.7061611374407584, "no_speech_prob": 1.6619848943258408e-12}, {"id": 211, "seek": 84496, "start": 850.7800000000001, "end": 853.7800000000001, "text": " Sometimes a circuit has to make a permanent, irreversible decision.", "tokens": [50656, 4803, 257, 9048, 575, 281, 652, 257, 10996, 11, 16014, 840, 964, 3537, 13, 50806], "temperature": 0.0, "avg_logprob": -0.1283102968464727, "compression_ratio": 1.7061611374407584, "no_speech_prob": 1.6619848943258408e-12}, {"id": 212, "seek": 84496, "start": 853.96, "end": 863.1800000000001, "text": " And the moment a circuit makes a permanent decision, you fall off the edge of the reversible amplit-wist world and you land right in the brutal territory of the diode.", "tokens": [50815, 400, 264, 1623, 257, 9048, 1669, 257, 10996, 3537, 11, 291, 2100, 766, 264, 4691, 295, 264, 44788, 9731, 270, 12, 86, 468, 1002, 293, 291, 2117, 558, 294, 264, 17878, 11360, 295, 264, 40787, 13, 51276], "temperature": 0.0, "avg_logprob": -0.1283102968464727, "compression_ratio": 1.7061611374407584, "no_speech_prob": 1.6619848943258408e-12}, {"id": 213, "seek": 84496, "start": 863.3000000000001, "end": 863.76, "text": " The diode.", "tokens": [51282, 440, 40787, 13, 51305], "temperature": 0.0, "avg_logprob": -0.1283102968464727, "compression_ratio": 1.7061611374407584, "no_speech_prob": 1.6619848943258408e-12}, {"id": 214, "seek": 84496, "start": 864.14, "end": 866.12, "text": " The famous one-way street of electronics.", "tokens": [51324, 440, 4618, 472, 12, 676, 4838, 295, 20611, 13, 51423], "temperature": 0.0, "avg_logprob": -0.1283102968464727, "compression_ratio": 1.7061611374407584, "no_speech_prob": 1.6619848943258408e-12}, {"id": 215, "seek": 84496, "start": 866.36, "end": 866.62, "text": " Yeah.", "tokens": [51435, 865, 13, 51448], "temperature": 0.0, "avg_logprob": -0.1283102968464727, "compression_ratio": 1.7061611374407584, "no_speech_prob": 1.6619848943258408e-12}, {"id": 216, "seek": 86662, "start": 866.62, "end": 871.62, "text": " So if an amplit-wist is reversible and I can rewind the factory line, what happens when I can't?", "tokens": [50365, 407, 498, 364, 9731, 270, 12, 86, 468, 307, 44788, 293, 286, 393, 41458, 264, 9265, 1622, 11, 437, 2314, 562, 286, 393, 380, 30, 50615], "temperature": 0.0, "avg_logprob": -0.12256240844726562, "compression_ratio": 1.6051502145922747, "no_speech_prob": 1.3617898041856646e-12}, {"id": 217, "seek": 86662, "start": 871.76, "end": 878.82, "text": " If the amplit-wist is all about smooth, holomorphic scaling and gentle rotation, the diode is about sheer destruction.", "tokens": [50622, 759, 264, 9731, 270, 12, 86, 468, 307, 439, 466, 5508, 11, 4091, 32702, 299, 21589, 293, 6424, 12447, 11, 264, 40787, 307, 466, 23061, 13563, 13, 50975], "temperature": 0.0, "avg_logprob": -0.12256240844726562, "compression_ratio": 1.6051502145922747, "no_speech_prob": 1.3617898041856646e-12}, {"id": 218, "seek": 86662, "start": 879.26, "end": 879.78, "text": " Destruction.", "tokens": [50997, 16339, 3826, 13, 51023], "temperature": 0.0, "avg_logprob": -0.12256240844726562, "compression_ratio": 1.6051502145922747, "no_speech_prob": 1.3617898041856646e-12}, {"id": 219, "seek": 86662, "start": 880.26, "end": 889.86, "text": " Fliction introduces the ideal diode not just as a simple one-way valve for electricity, but as a severe geometric event called a pop-refuse pair.", "tokens": [51047, 3235, 4105, 31472, 264, 7157, 40787, 406, 445, 382, 257, 2199, 472, 12, 676, 15294, 337, 10356, 11, 457, 382, 257, 8922, 33246, 2280, 1219, 257, 1665, 12, 33115, 438, 6119, 13, 51527], "temperature": 0.0, "avg_logprob": -0.12256240844726562, "compression_ratio": 1.6051502145922747, "no_speech_prob": 1.3617898041856646e-12}, {"id": 220, "seek": 88986, "start": 889.86, "end": 896.62, "text": " Let's define pop and refuse, because this is where the vocabulary of the book really starts doing some heavy conceptual lifting.", "tokens": [50365, 961, 311, 6964, 1665, 293, 16791, 11, 570, 341, 307, 689, 264, 19864, 295, 264, 1446, 534, 3719, 884, 512, 4676, 24106, 15798, 13, 50703], "temperature": 0.0, "avg_logprob": -0.19576650052457242, "compression_ratio": 1.627177700348432, "no_speech_prob": 1.3302467851208921e-12}, {"id": 221, "seek": 88986, "start": 896.92, "end": 897.12, "text": " Sure.", "tokens": [50718, 4894, 13, 50728], "temperature": 0.0, "avg_logprob": -0.19576650052457242, "compression_ratio": 1.627177700348432, "no_speech_prob": 1.3302467851208921e-12}, {"id": 222, "seek": 88986, "start": 897.52, "end": 900.84, "text": " Imagine you are measuring the voltage pushing across a diode.", "tokens": [50748, 11739, 291, 366, 13389, 264, 8352, 7380, 2108, 257, 40787, 13, 50914], "temperature": 0.0, "avg_logprob": -0.19576650052457242, "compression_ratio": 1.627177700348432, "no_speech_prob": 1.3302467851208921e-12}, {"id": 223, "seek": 88986, "start": 901.42, "end": 908.54, "text": " If the voltage is positive, what engineers call forward bias, the diode opens up and lets the current flow through.", "tokens": [50943, 759, 264, 8352, 307, 3353, 11, 437, 11955, 818, 2128, 12577, 11, 264, 40787, 9870, 493, 293, 6653, 264, 2190, 3095, 807, 13, 51299], "temperature": 0.0, "avg_logprob": -0.19576650052457242, "compression_ratio": 1.627177700348432, "no_speech_prob": 1.3302467851208921e-12}, {"id": 224, "seek": 88986, "start": 908.92, "end": 909.22, "text": " Okay.", "tokens": [51318, 1033, 13, 51333], "temperature": 0.0, "avg_logprob": -0.19576650052457242, "compression_ratio": 1.627177700348432, "no_speech_prob": 1.3302467851208921e-12}, {"id": 225, "seek": 88986, "start": 909.26, "end": 911.7, "text": " In Fliction's terminology, the diode pops.", "tokens": [51335, 682, 3235, 4105, 311, 27575, 11, 264, 40787, 16795, 13, 51457], "temperature": 0.0, "avg_logprob": -0.19576650052457242, "compression_ratio": 1.627177700348432, "no_speech_prob": 1.3302467851208921e-12}, {"id": 226, "seek": 88986, "start": 912.24, "end": 918.62, "text": " It takes an admissible positive input and collapses it into a specific forward-flowing output state.", "tokens": [51484, 467, 2516, 364, 5910, 41073, 3353, 4846, 293, 48765, 309, 666, 257, 2685, 2128, 12, 43955, 5598, 1785, 13, 51803], "temperature": 0.0, "avg_logprob": -0.19576650052457242, "compression_ratio": 1.627177700348432, "no_speech_prob": 1.3302467851208921e-12}, {"id": 227, "seek": 88986, "start": 918.7, "end": 918.88, "text": " Wow.", "tokens": [51807, 3153, 13, 51816], "temperature": 0.0, "avg_logprob": -0.19576650052457242, "compression_ratio": 1.627177700348432, "no_speech_prob": 1.3302467851208921e-12}, {"id": 228, "seek": 91888, "start": 918.88, "end": 919.12, "text": " Got it.", "tokens": [50365, 5803, 309, 13, 50377], "temperature": 0.0, "avg_logprob": -0.15401626455372777, "compression_ratio": 1.7446808510638299, "no_speech_prob": 2.389039920752678e-12}, {"id": 229, "seek": 91888, "start": 919.48, "end": 924.24, "text": " But if the voltage is negative reverse bias, the diode violently blocks the current.", "tokens": [50395, 583, 498, 264, 8352, 307, 3671, 9943, 12577, 11, 264, 40787, 46728, 8474, 264, 2190, 13, 50633], "temperature": 0.0, "avg_logprob": -0.15401626455372777, "compression_ratio": 1.7446808510638299, "no_speech_prob": 2.389039920752678e-12}, {"id": 230, "seek": 91888, "start": 924.66, "end": 925.24, "text": " It refuses.", "tokens": [50654, 467, 33222, 13, 50683], "temperature": 0.0, "avg_logprob": -0.15401626455372777, "compression_ratio": 1.7446808510638299, "no_speech_prob": 2.389039920752678e-12}, {"id": 231, "seek": 91888, "start": 925.7, "end": 928.64, "text": " And refuse isn't just a synonym for turning off, right?", "tokens": [50706, 400, 16791, 1943, 380, 445, 257, 5451, 12732, 337, 6246, 766, 11, 558, 30, 50853], "temperature": 0.0, "avg_logprob": -0.15401626455372777, "compression_ratio": 1.7446808510638299, "no_speech_prob": 2.389039920752678e-12}, {"id": 232, "seek": 91888, "start": 928.64, "end": 932.4, "text": " The book frames it as something mathematically catastrophic for information.", "tokens": [50853, 440, 1446, 12083, 309, 382, 746, 44003, 34915, 337, 1589, 13, 51041], "temperature": 0.0, "avg_logprob": -0.15401626455372777, "compression_ratio": 1.7446808510638299, "no_speech_prob": 2.389039920752678e-12}, {"id": 233, "seek": 91888, "start": 932.58, "end": 934.46, "text": " Because it's a total erasure of reality.", "tokens": [51050, 1436, 309, 311, 257, 3217, 1189, 2508, 295, 4103, 13, 51144], "temperature": 0.0, "avg_logprob": -0.15401626455372777, "compression_ratio": 1.7446808510638299, "no_speech_prob": 2.389039920752678e-12}, {"id": 234, "seek": 91888, "start": 934.72, "end": 937.4, "text": " Think about the mathematical mapping happening when the diode refuses.", "tokens": [51157, 6557, 466, 264, 18894, 18350, 2737, 562, 264, 40787, 33222, 13, 51291], "temperature": 0.0, "avg_logprob": -0.15401626455372777, "compression_ratio": 1.7446808510638299, "no_speech_prob": 2.389039920752678e-12}, {"id": 235, "seek": 91888, "start": 937.88, "end": 945.72, "text": " It is taking an entire infinite range of negative voltages, whether the input is negative 1 volt, negative 10 volts, or negative 10,000 volts.", "tokens": [51315, 467, 307, 1940, 364, 2302, 13785, 3613, 295, 3671, 49614, 11, 1968, 264, 4846, 307, 3671, 502, 5962, 11, 3671, 1266, 22322, 11, 420, 3671, 1266, 11, 1360, 22322, 13, 51707], "temperature": 0.0, "avg_logprob": -0.15401626455372777, "compression_ratio": 1.7446808510638299, "no_speech_prob": 2.389039920752678e-12}, {"id": 236, "seek": 94572, "start": 945.72, "end": 951.96, "text": " And it collapses all of them into a single identical null output state, zero amps.", "tokens": [50365, 400, 309, 48765, 439, 295, 552, 666, 257, 2167, 14800, 18184, 5598, 1785, 11, 4018, 43970, 13, 50677], "temperature": 0.0, "avg_logprob": -0.12578983928846277, "compression_ratio": 1.2619047619047619, "no_speech_prob": 1.7972510415673049e-12}, {"id": 237, "seek": 94572, "start": 952.08, "end": 953.82, "text": " It is exactly like a paper shredder.", "tokens": [50683, 467, 307, 2293, 411, 257, 3035, 21567, 1068, 13, 50770], "temperature": 0.0, "avg_logprob": -0.12578983928846277, "compression_ratio": 1.2619047619047619, "no_speech_prob": 1.7972510415673049e-12}, {"id": 238, "seek": 94572, "start": 953.86, "end": 955.32, "text": " Oh, that's a perfect way to look at it.", "tokens": [50772, 876, 11, 300, 311, 257, 2176, 636, 281, 574, 412, 309, 13, 50845], "temperature": 0.0, "avg_logprob": -0.12578983928846277, "compression_ratio": 1.2619047619047619, "no_speech_prob": 1.7972510415673049e-12}, {"id": 239, "seek": 95532, "start": 955.32, "end": 964.22, "text": " If I walk up to you and hand you a tiny shredded piece of paper, and I tell you, you know, this came out of an AND gate, which is a type of logic gate we'll get into shortly, you can't unshred it.", "tokens": [50365, 759, 286, 1792, 493, 281, 291, 293, 1011, 291, 257, 5870, 39091, 2522, 295, 3035, 11, 293, 286, 980, 291, 11, 291, 458, 11, 341, 1361, 484, 295, 364, 8093, 8539, 11, 597, 307, 257, 2010, 295, 9952, 8539, 321, 603, 483, 666, 13392, 11, 291, 393, 380, 2693, 71, 986, 309, 13, 50810], "temperature": 0.0, "avg_logprob": -0.08415789237389197, "compression_ratio": 1.4161073825503356, "no_speech_prob": 1.633033660554395e-12}, {"id": 240, "seek": 95532, "start": 964.4200000000001, "end": 965.58, "text": " No, you can't.", "tokens": [50820, 883, 11, 291, 393, 380, 13, 50878], "temperature": 0.0, "avg_logprob": -0.08415789237389197, "compression_ratio": 1.4161073825503356, "no_speech_prob": 1.633033660554395e-12}, {"id": 241, "seek": 96558, "start": 965.58, "end": 976.34, "text": " If you see a zero coming out of that shredder, you have absolutely no physical or mathematical way to rewind the clock and know if the original document said negative 1, negative 5, or negative 50.", "tokens": [50365, 759, 291, 536, 257, 4018, 1348, 484, 295, 300, 21567, 1068, 11, 291, 362, 3122, 572, 4001, 420, 18894, 636, 281, 41458, 264, 7830, 293, 458, 498, 264, 3380, 4166, 848, 3671, 502, 11, 3671, 1025, 11, 420, 3671, 2625, 13, 50903], "temperature": 0.0, "avg_logprob": -0.1517399601314379, "compression_ratio": 1.6324786324786325, "no_speech_prob": 1.5073605341350826e-12}, {"id": 242, "seek": 96558, "start": 976.76, "end": 979.88, "text": " The history of that information is just gone.", "tokens": [50924, 440, 2503, 295, 300, 1589, 307, 445, 2780, 13, 51080], "temperature": 0.0, "avg_logprob": -0.1517399601314379, "compression_ratio": 1.6324786324786325, "no_speech_prob": 1.5073605341350826e-12}, {"id": 243, "seek": 96558, "start": 980.24, "end": 985.36, "text": " Flishen formalizes that exact shredder concept in theorem 1 of the book.", "tokens": [51098, 3235, 742, 268, 9860, 5660, 300, 1900, 21567, 1068, 3410, 294, 20904, 502, 295, 264, 1446, 13, 51354], "temperature": 0.0, "avg_logprob": -0.1517399601314379, "compression_ratio": 1.6324786324786325, "no_speech_prob": 1.5073605341350826e-12}, {"id": 244, "seek": 96558, "start": 985.48, "end": 987.58, "text": " It is a rigorous mathematical proof.", "tokens": [51360, 467, 307, 257, 29882, 18894, 8177, 13, 51465], "temperature": 0.0, "avg_logprob": -0.1517399601314379, "compression_ratio": 1.6324786324786325, "no_speech_prob": 1.5073605341350826e-12}, {"id": 245, "seek": 96558, "start": 987.74, "end": 988.82, "text": " What does the theorem state?", "tokens": [51473, 708, 775, 264, 20904, 1785, 30, 51527], "temperature": 0.0, "avg_logprob": -0.1517399601314379, "compression_ratio": 1.6324786324786325, "no_speech_prob": 1.5073605341350826e-12}, {"id": 246, "seek": 98882, "start": 988.82, "end": 991.74, "text": " That no invertible function can ever rectify a signal.", "tokens": [50365, 663, 572, 33966, 964, 2445, 393, 1562, 11048, 2505, 257, 6358, 13, 50511], "temperature": 0.0, "avg_logprob": -0.14396610423031017, "compression_ratio": 1.7406143344709897, "no_speech_prob": 1.3404750399959031e-12}, {"id": 247, "seek": 98882, "start": 992.32, "end": 999.1, "text": " Rectification is the process of turning alternating current into direct current, which is what a diode does in a power supply.", "tokens": [50540, 497, 557, 3774, 307, 264, 1399, 295, 6246, 40062, 2190, 666, 2047, 2190, 11, 597, 307, 437, 257, 40787, 775, 294, 257, 1347, 5847, 13, 50879], "temperature": 0.0, "avg_logprob": -0.14396610423031017, "compression_ratio": 1.7406143344709897, "no_speech_prob": 1.3404750399959031e-12}, {"id": 248, "seek": 98882, "start": 999.4200000000001, "end": 999.5200000000001, "text": " Right.", "tokens": [50895, 1779, 13, 50900], "temperature": 0.0, "avg_logprob": -0.14396610423031017, "compression_ratio": 1.7406143344709897, "no_speech_prob": 1.3404750399959031e-12}, {"id": 249, "seek": 98882, "start": 999.86, "end": 1007.2, "text": " The theorem proves that it is mathematically impossible to rectify a signal while remaining in the smooth, reversible, amplitwist world.", "tokens": [50917, 440, 20904, 25019, 300, 309, 307, 44003, 6243, 281, 11048, 2505, 257, 6358, 1339, 8877, 294, 264, 5508, 11, 44788, 11, 9731, 270, 86, 468, 1002, 13, 51284], "temperature": 0.0, "avg_logprob": -0.14396610423031017, "compression_ratio": 1.7406143344709897, "no_speech_prob": 1.3404750399959031e-12}, {"id": 250, "seek": 98882, "start": 1007.9200000000001, "end": 1009.5, "text": " Irreversibility isn't an accident.", "tokens": [51320, 9151, 265, 840, 2841, 1943, 380, 364, 6398, 13, 51399], "temperature": 0.0, "avg_logprob": -0.14396610423031017, "compression_ratio": 1.7406143344709897, "no_speech_prob": 1.3404750399959031e-12}, {"id": 251, "seek": 98882, "start": 1009.86, "end": 1011.96, "text": " It isn't a side effect of bad manufacturing.", "tokens": [51417, 467, 1943, 380, 257, 1252, 1802, 295, 1578, 11096, 13, 51522], "temperature": 0.0, "avg_logprob": -0.14396610423031017, "compression_ratio": 1.7406143344709897, "no_speech_prob": 1.3404750399959031e-12}, {"id": 252, "seek": 98882, "start": 1012.62, "end": 1017.98, "text": " The destruction of information is the fundamental geometric requirement for the device to even function.", "tokens": [51555, 440, 13563, 295, 1589, 307, 264, 8088, 33246, 11695, 337, 264, 4302, 281, 754, 2445, 13, 51823], "temperature": 0.0, "avg_logprob": -0.14396610423031017, "compression_ratio": 1.7406143344709897, "no_speech_prob": 1.3404750399959031e-12}, {"id": 253, "seek": 101798, "start": 1017.98, "end": 1020.5, "text": " That is such a profound shift in perspective.", "tokens": [50365, 663, 307, 1270, 257, 14382, 5513, 294, 4585, 13, 50491], "temperature": 0.0, "avg_logprob": -0.1014351068541061, "compression_ratio": 1.560483870967742, "no_speech_prob": 1.5858690229075822e-12}, {"id": 254, "seek": 101798, "start": 1020.76, "end": 1028.24, "text": " I mean, I've always thought of a diode as doing something highly active, almost muscular, like it is physically pushing the current to stay in one lane.", "tokens": [50504, 286, 914, 11, 286, 600, 1009, 1194, 295, 257, 40787, 382, 884, 746, 5405, 4967, 11, 1920, 31641, 11, 411, 309, 307, 9762, 7380, 264, 2190, 281, 1754, 294, 472, 12705, 13, 50878], "temperature": 0.0, "avg_logprob": -0.1014351068541061, "compression_ratio": 1.560483870967742, "no_speech_prob": 1.5858690229075822e-12}, {"id": 255, "seek": 101798, "start": 1028.52, "end": 1032.72, "text": " But under this framework, it is actually acting as an information black hole.", "tokens": [50892, 583, 833, 341, 8388, 11, 309, 307, 767, 6577, 382, 364, 1589, 2211, 5458, 13, 51102], "temperature": 0.0, "avg_logprob": -0.1014351068541061, "compression_ratio": 1.560483870967742, "no_speech_prob": 1.5858690229075822e-12}, {"id": 256, "seek": 101798, "start": 1032.94, "end": 1039.1200000000001, "text": " It is doing its job by aggressively destroying the mathematical distinction between all negative numbers.", "tokens": [51113, 467, 307, 884, 1080, 1691, 538, 32024, 19926, 264, 18894, 16844, 1296, 439, 3671, 3547, 13, 51422], "temperature": 0.0, "avg_logprob": -0.1014351068541061, "compression_ratio": 1.560483870967742, "no_speech_prob": 1.5858690229075822e-12}, {"id": 257, "seek": 101798, "start": 1039.26, "end": 1039.5, "text": " Wow.", "tokens": [51429, 3153, 13, 51441], "temperature": 0.0, "avg_logprob": -0.1014351068541061, "compression_ratio": 1.560483870967742, "no_speech_prob": 1.5858690229075822e-12}, {"id": 258, "seek": 103950, "start": 1039.5, "end": 1049.46, "text": " And if we connect this to the bigger picture, this irreversible collapse, this intentional destruction of mathematical distinctions, is the absolute foundation of all digital logic.", "tokens": [50365, 400, 498, 321, 1745, 341, 281, 264, 3801, 3036, 11, 341, 16014, 840, 964, 15584, 11, 341, 21935, 13563, 295, 18894, 1483, 49798, 11, 307, 264, 8236, 7030, 295, 439, 4562, 9952, 13, 50863], "temperature": 0.0, "avg_logprob": -0.11726590303274301, "compression_ratio": 1.6901960784313725, "no_speech_prob": 1.5796990451844017e-12}, {"id": 259, "seek": 103950, "start": 1049.6, "end": 1050.34, "text": " Like in computers.", "tokens": [50870, 1743, 294, 10807, 13, 50907], "temperature": 0.0, "avg_logprob": -0.11726590303274301, "compression_ratio": 1.6901960784313725, "no_speech_prob": 1.5796990451844017e-12}, {"id": 260, "seek": 103950, "start": 1050.6, "end": 1056.02, "text": " Every computer, every smartphone, every server farm on Earth relies on microscopic logic gates.", "tokens": [50920, 2048, 3820, 11, 633, 13307, 11, 633, 7154, 5421, 322, 4755, 30910, 322, 47897, 9952, 19792, 13, 51191], "temperature": 0.0, "avg_logprob": -0.11726590303274301, "compression_ratio": 1.6901960784313725, "no_speech_prob": 1.5796990451844017e-12}, {"id": 261, "seek": 103950, "start": 1056.58, "end": 1059.44, "text": " The AND gate, the ORR gate, the XR gate.", "tokens": [51219, 440, 8093, 8539, 11, 264, 19654, 49, 8539, 11, 264, 1783, 49, 8539, 13, 51362], "temperature": 0.0, "avg_logprob": -0.11726590303274301, "compression_ratio": 1.6901960784313725, "no_speech_prob": 1.5796990451844017e-12}, {"id": 262, "seek": 103950, "start": 1059.98, "end": 1064.98, "text": " Fiction points out that every standard two-input logic gate is a non-invertible POP operator.", "tokens": [51389, 479, 4105, 2793, 484, 300, 633, 3832, 732, 12, 259, 2582, 9952, 8539, 307, 257, 2107, 12, 259, 3281, 964, 430, 12059, 12973, 13, 51639], "temperature": 0.0, "avg_logprob": -0.11726590303274301, "compression_ratio": 1.6901960784313725, "no_speech_prob": 1.5796990451844017e-12}, {"id": 263, "seek": 106498, "start": 1064.98, "end": 1069.02, "text": " That makes perfect sense, because you have two input wires and only one output wire.", "tokens": [50365, 663, 1669, 2176, 2020, 11, 570, 291, 362, 732, 4846, 15537, 293, 787, 472, 5598, 6234, 13, 50567], "temperature": 0.0, "avg_logprob": -0.12438117133246528, "compression_ratio": 1.6371308016877637, "no_speech_prob": 1.6232377855057711e-12}, {"id": 264, "seek": 106498, "start": 1069.6, "end": 1075.92, "text": " You are taking a complex, two-dimensional space of possibilities and violently collapsing it into a one-dimensional point.", "tokens": [50596, 509, 366, 1940, 257, 3997, 11, 732, 12, 18759, 1901, 295, 12178, 293, 46728, 45339, 309, 666, 257, 472, 12, 18759, 935, 13, 50912], "temperature": 0.0, "avg_logprob": -0.12438117133246528, "compression_ratio": 1.6371308016877637, "no_speech_prob": 1.6232377855057711e-12}, {"id": 265, "seek": 106498, "start": 1076.18, "end": 1077.76, "text": " Take the AND gate as an example.", "tokens": [50925, 3664, 264, 8093, 8539, 382, 364, 1365, 13, 51004], "temperature": 0.0, "avg_logprob": -0.12438117133246528, "compression_ratio": 1.6371308016877637, "no_speech_prob": 1.6232377855057711e-12}, {"id": 266, "seek": 106498, "start": 1077.94, "end": 1080.76, "text": " It outputs a 1 only if both input wires are a 1.", "tokens": [51013, 467, 23930, 257, 502, 787, 498, 1293, 4846, 15537, 366, 257, 502, 13, 51154], "temperature": 0.0, "avg_logprob": -0.12438117133246528, "compression_ratio": 1.6371308016877637, "no_speech_prob": 1.6232377855057711e-12}, {"id": 267, "seek": 106498, "start": 1080.9, "end": 1083.88, "text": " If the output of an AND gate is a 0, what were the inputs?", "tokens": [51161, 759, 264, 5598, 295, 364, 8093, 8539, 307, 257, 1958, 11, 437, 645, 264, 15743, 30, 51310], "temperature": 0.0, "avg_logprob": -0.12438117133246528, "compression_ratio": 1.6371308016877637, "no_speech_prob": 1.6232377855057711e-12}, {"id": 268, "seek": 106498, "start": 1084.0, "end": 1086.08, "text": " It could have been 0, 0, 0, 1, or 1, 0.", "tokens": [51316, 467, 727, 362, 668, 1958, 11, 1958, 11, 1958, 11, 502, 11, 420, 502, 11, 1958, 13, 51420], "temperature": 0.0, "avg_logprob": -0.12438117133246528, "compression_ratio": 1.6371308016877637, "no_speech_prob": 1.6232377855057711e-12}, {"id": 269, "seek": 108608, "start": 1086.08, "end": 1092.0, "text": " Exactly. Three completely different realities all result in the exact same 0 output.", "tokens": [50365, 7587, 13, 6244, 2584, 819, 27785, 439, 1874, 294, 264, 1900, 912, 1958, 5598, 13, 50661], "temperature": 0.0, "avg_logprob": -0.13370884789360893, "compression_ratio": 1.5914396887159532, "no_speech_prob": 2.624828522937439e-12}, {"id": 270, "seek": 108608, "start": 1092.4399999999998, "end": 1094.02, "text": " You cannot rewind that equation.", "tokens": [50683, 509, 2644, 41458, 300, 5367, 13, 50762], "temperature": 0.0, "avg_logprob": -0.13370884789360893, "compression_ratio": 1.5914396887159532, "no_speech_prob": 2.624828522937439e-12}, {"id": 271, "seek": 108608, "start": 1094.3, "end": 1098.3799999999999, "text": " The moment the gate makes a decision, you have shredded the history of the inputs.", "tokens": [50776, 440, 1623, 264, 8539, 1669, 257, 3537, 11, 291, 362, 39091, 264, 2503, 295, 264, 15743, 13, 50980], "temperature": 0.0, "avg_logprob": -0.13370884789360893, "compression_ratio": 1.5914396887159532, "no_speech_prob": 2.624828522937439e-12}, {"id": 272, "seek": 108608, "start": 1098.6399999999999, "end": 1100.72, "text": " But the book gets incredibly precise here.", "tokens": [50993, 583, 264, 1446, 2170, 6252, 13600, 510, 13, 51097], "temperature": 0.0, "avg_logprob": -0.13370884789360893, "compression_ratio": 1.5914396887159532, "no_speech_prob": 2.624828522937439e-12}, {"id": 273, "seek": 108608, "start": 1101.0, "end": 1104.9399999999998, "text": " It doesn't just offer a philosophical musing that, like, information is destroyed.", "tokens": [51111, 467, 1177, 380, 445, 2626, 257, 25066, 1038, 278, 300, 11, 411, 11, 1589, 307, 8937, 13, 51308], "temperature": 0.0, "avg_logprob": -0.13370884789360893, "compression_ratio": 1.5914396887159532, "no_speech_prob": 2.624828522937439e-12}, {"id": 274, "seek": 108608, "start": 1105.1799999999998, "end": 1110.26, "text": " It uses information theory to calculate exactly how much destruction is occurring.", "tokens": [51320, 467, 4960, 1589, 5261, 281, 8873, 2293, 577, 709, 13563, 307, 18386, 13, 51574], "temperature": 0.0, "avg_logprob": -0.13370884789360893, "compression_ratio": 1.5914396887159532, "no_speech_prob": 2.624828522937439e-12}, {"id": 275, "seek": 111026, "start": 1110.26, "end": 1121.96, "text": " Yeah. Assuming your input signals are completely random and equally likely, an AND gate destroys roughly 1.189 bits of information on average every single time it operates.", "tokens": [50365, 865, 13, 6281, 24919, 428, 4846, 12354, 366, 2584, 4974, 293, 12309, 3700, 11, 364, 8093, 8539, 36714, 9810, 502, 13, 6494, 24, 9239, 295, 1589, 322, 4274, 633, 2167, 565, 309, 22577, 13, 50950], "temperature": 0.0, "avg_logprob": -0.08194676065832619, "compression_ratio": 1.5566037735849056, "no_speech_prob": 1.996585622526803e-12}, {"id": 276, "seek": 111026, "start": 1122.06, "end": 1124.78, "text": " Wait, I'm stuck on something here. 1.189 bits.", "tokens": [50955, 3802, 11, 286, 478, 5541, 322, 746, 510, 13, 502, 13, 6494, 24, 9239, 13, 51091], "temperature": 0.0, "avg_logprob": -0.08194676065832619, "compression_ratio": 1.5566037735849056, "no_speech_prob": 1.996585622526803e-12}, {"id": 277, "seek": 111026, "start": 1125.0, "end": 1125.24, "text": " Yeah.", "tokens": [51102, 865, 13, 51114], "temperature": 0.0, "avg_logprob": -0.08194676065832619, "compression_ratio": 1.5566037735849056, "no_speech_prob": 1.996585622526803e-12}, {"id": 278, "seek": 111026, "start": 1125.44, "end": 1130.72, "text": " How does a physical circuit destroy a fraction of a bit? How does the author arrive at that highly specific number?", "tokens": [51124, 1012, 775, 257, 4001, 9048, 5293, 257, 14135, 295, 257, 857, 30, 1012, 775, 264, 3793, 8881, 412, 300, 5405, 2685, 1230, 30, 51388], "temperature": 0.0, "avg_logprob": -0.08194676065832619, "compression_ratio": 1.5566037735849056, "no_speech_prob": 1.996585622526803e-12}, {"id": 279, "seek": 111026, "start": 1131.0, "end": 1135.86, "text": " It comes down to a concept called conditional entropy, derived from Claude Shannon's information theory.", "tokens": [51402, 467, 1487, 760, 281, 257, 3410, 1219, 27708, 30867, 11, 18949, 490, 12947, 2303, 28974, 311, 1589, 5261, 13, 51645], "temperature": 0.0, "avg_logprob": -0.08194676065832619, "compression_ratio": 1.5566037735849056, "no_speech_prob": 1.996585622526803e-12}, {"id": 280, "seek": 111026, "start": 1135.98, "end": 1136.76, "text": " Let's walk through the math.", "tokens": [51651, 961, 311, 1792, 807, 264, 5221, 13, 51690], "temperature": 0.0, "avg_logprob": -0.08194676065832619, "compression_ratio": 1.5566037735849056, "no_speech_prob": 1.996585622526803e-12}, {"id": 281, "seek": 111026, "start": 1136.84, "end": 1137.54, "text": " Okay, lay it on me.", "tokens": [51694, 1033, 11, 2360, 309, 322, 385, 13, 51729], "temperature": 0.0, "avg_logprob": -0.08194676065832619, "compression_ratio": 1.5566037735849056, "no_speech_prob": 1.996585622526803e-12}, {"id": 282, "seek": 113754, "start": 1137.54, "end": 1144.74, "text": " There are four possible, equally likely input states for two wires, 0, 0, 0, 0, 1, 10, and 11.", "tokens": [50365, 821, 366, 1451, 1944, 11, 12309, 3700, 4846, 4368, 337, 732, 15537, 11, 1958, 11, 1958, 11, 1958, 11, 1958, 11, 502, 11, 1266, 11, 293, 2975, 13, 50725], "temperature": 0.0, "avg_logprob": -0.11414711134774344, "compression_ratio": 1.6643598615916955, "no_speech_prob": 1.3671207178475586e-12}, {"id": 283, "seek": 113754, "start": 1145.24, "end": 1149.86, "text": " As we established, for an A&D gate, three of those four states result in a 0 output.", "tokens": [50750, 1018, 321, 7545, 11, 337, 364, 316, 5, 35, 8539, 11, 1045, 295, 729, 1451, 4368, 1874, 294, 257, 1958, 5598, 13, 50981], "temperature": 0.0, "avg_logprob": -0.11414711134774344, "compression_ratio": 1.6643598615916955, "no_speech_prob": 1.3671207178475586e-12}, {"id": 284, "seek": 113754, "start": 1150.3, "end": 1153.24, "text": " Only one single state. The 11th state results in a 1.", "tokens": [51003, 5686, 472, 2167, 1785, 13, 440, 2975, 392, 1785, 3542, 294, 257, 502, 13, 51150], "temperature": 0.0, "avg_logprob": -0.11414711134774344, "compression_ratio": 1.6643598615916955, "no_speech_prob": 1.3671207178475586e-12}, {"id": 285, "seek": 113754, "start": 1153.32, "end": 1154.3799999999999, "text": " Okay, I'm with you so far.", "tokens": [51154, 1033, 11, 286, 478, 365, 291, 370, 1400, 13, 51207], "temperature": 0.0, "avg_logprob": -0.11414711134774344, "compression_ratio": 1.6643598615916955, "no_speech_prob": 1.3671207178475586e-12}, {"id": 286, "seek": 113754, "start": 1154.3799999999999, "end": 1160.76, "text": " If you look at the output wire and see a 1, you know with absolute 100% certainty that the inputs were 11.", "tokens": [51207, 759, 291, 574, 412, 264, 5598, 6234, 293, 536, 257, 502, 11, 291, 458, 365, 8236, 2319, 4, 27022, 300, 264, 15743, 645, 2975, 13, 51526], "temperature": 0.0, "avg_logprob": -0.11414711134774344, "compression_ratio": 1.6643598615916955, "no_speech_prob": 1.3671207178475586e-12}, {"id": 287, "seek": 113754, "start": 1161.22, "end": 1164.78, "text": " There is no uncertainty. Zero bits of information were lost.", "tokens": [51549, 821, 307, 572, 15697, 13, 17182, 9239, 295, 1589, 645, 2731, 13, 51727], "temperature": 0.0, "avg_logprob": -0.11414711134774344, "compression_ratio": 1.6643598615916955, "no_speech_prob": 1.3671207178475586e-12}, {"id": 288, "seek": 113754, "start": 1164.8799999999999, "end": 1167.36, "text": " Because it's a 1-to-1 mapping in that specific case.", "tokens": [51732, 1436, 309, 311, 257, 502, 12, 1353, 12, 16, 18350, 294, 300, 2685, 1389, 13, 51856], "temperature": 0.0, "avg_logprob": -0.11414711134774344, "compression_ratio": 1.6643598615916955, "no_speech_prob": 1.3671207178475586e-12}, {"id": 289, "seek": 116754, "start": 1167.54, "end": 1172.54, "text": " Right. But, if you look at the output wire and see a 0, you are suddenly faced with uncertainty.", "tokens": [50365, 1779, 13, 583, 11, 498, 291, 574, 412, 264, 5598, 6234, 293, 536, 257, 1958, 11, 291, 366, 5800, 11446, 365, 15697, 13, 50615], "temperature": 0.0, "avg_logprob": -0.14630248125861672, "compression_ratio": 1.5196078431372548, "no_speech_prob": 1.2015988247807141e-12}, {"id": 290, "seek": 116754, "start": 1173.02, "end": 1175.96, "text": " The input was either 0, 0, 0, 1, or 10.", "tokens": [50639, 440, 4846, 390, 2139, 1958, 11, 1958, 11, 1958, 11, 502, 11, 420, 1266, 13, 50786], "temperature": 0.0, "avg_logprob": -0.14630248125861672, "compression_ratio": 1.5196078431372548, "no_speech_prob": 1.2015988247807141e-12}, {"id": 291, "seek": 116754, "start": 1176.28, "end": 1179.24, "text": " You have three equally likely possibilities.", "tokens": [50802, 509, 362, 1045, 12309, 3700, 12178, 13, 50950], "temperature": 0.0, "avg_logprob": -0.14630248125861672, "compression_ratio": 1.5196078431372548, "no_speech_prob": 1.2015988247807141e-12}, {"id": 292, "seek": 116754, "start": 1179.36, "end": 1179.56, "text": " Okay.", "tokens": [50956, 1033, 13, 50966], "temperature": 0.0, "avg_logprob": -0.14630248125861672, "compression_ratio": 1.5196078431372548, "no_speech_prob": 1.2015988247807141e-12}, {"id": 293, "seek": 116754, "start": 1179.8799999999999, "end": 1187.58, "text": " To calculate the entropy, or the missing information, of three equally likely choices, you take the base 2 logarithm of 3.", "tokens": [50982, 1407, 8873, 264, 30867, 11, 420, 264, 5361, 1589, 11, 295, 1045, 12309, 3700, 7994, 11, 291, 747, 264, 3096, 568, 41473, 32674, 295, 805, 13, 51367], "temperature": 0.0, "avg_logprob": -0.14630248125861672, "compression_ratio": 1.5196078431372548, "no_speech_prob": 1.2015988247807141e-12}, {"id": 294, "seek": 118758, "start": 1187.58, "end": 1190.56, "text": " And the base 2 logarithm of 3 is about 1.585.", "tokens": [50365, 400, 264, 3096, 568, 41473, 32674, 295, 805, 307, 466, 502, 13, 20, 19287, 13, 50514], "temperature": 0.0, "avg_logprob": -0.12585426129792865, "compression_ratio": 1.5473684210526315, "no_speech_prob": 1.7214410235819044e-12}, {"id": 295, "seek": 118758, "start": 1190.96, "end": 1197.86, "text": " Exactly. So, 25% of the time, you lose zero bits. And 75% of the time, you lose 1.585 bits.", "tokens": [50534, 7587, 13, 407, 11, 3552, 4, 295, 264, 565, 11, 291, 3624, 4018, 9239, 13, 400, 9562, 4, 295, 264, 565, 11, 291, 3624, 502, 13, 20, 19287, 9239, 13, 50879], "temperature": 0.0, "avg_logprob": -0.12585426129792865, "compression_ratio": 1.5473684210526315, "no_speech_prob": 1.7214410235819044e-12}, {"id": 296, "seek": 118758, "start": 1197.96, "end": 1198.4199999999998, "text": " Oh, I see.", "tokens": [50884, 876, 11, 286, 536, 13, 50907], "temperature": 0.0, "avg_logprob": -0.12585426129792865, "compression_ratio": 1.5473684210526315, "no_speech_prob": 1.7214410235819044e-12}, {"id": 297, "seek": 118758, "start": 1198.48, "end": 1209.3, "text": " If you average that out over time, the gate is bleeding away exactly 1.18875 bits of information, roughly 1.189 bits every single time it cycles.", "tokens": [50910, 759, 291, 4274, 300, 484, 670, 565, 11, 264, 8539, 307, 19312, 1314, 2293, 502, 13, 6494, 23, 11901, 9239, 295, 1589, 11, 9810, 502, 13, 6494, 24, 9239, 633, 2167, 565, 309, 17796, 13, 51451], "temperature": 0.0, "avg_logprob": -0.12585426129792865, "compression_ratio": 1.5473684210526315, "no_speech_prob": 1.7214410235819044e-12}, {"id": 298, "seek": 120930, "start": 1209.3, "end": 1214.22, "text": " That is deeply unsettling to think about. My computer is just bleeding out millions of bits of reality every second.", "tokens": [50365, 663, 307, 8760, 43964, 1688, 281, 519, 466, 13, 1222, 3820, 307, 445, 19312, 484, 6803, 295, 9239, 295, 4103, 633, 1150, 13, 50611], "temperature": 0.0, "avg_logprob": -0.08838703693487705, "compression_ratio": 1.5435897435897437, "no_speech_prob": 1.5428669626615932e-12}, {"id": 299, "seek": 120930, "start": 1214.28, "end": 1214.96, "text": " It really is.", "tokens": [50614, 467, 534, 307, 13, 50648], "temperature": 0.0, "avg_logprob": -0.08838703693487705, "compression_ratio": 1.5435897435897437, "no_speech_prob": 1.5428669626615932e-12}, {"id": 300, "seek": 120930, "start": 1215.04, "end": 1217.82, "text": " But the XOR gate, the exclusive OR gate, behaves differently, right?", "tokens": [50652, 583, 264, 1783, 2483, 8539, 11, 264, 13005, 19654, 8539, 11, 36896, 7614, 11, 558, 30, 50791], "temperature": 0.0, "avg_logprob": -0.08838703693487705, "compression_ratio": 1.5435897435897437, "no_speech_prob": 1.5428669626615932e-12}, {"id": 301, "seek": 120930, "start": 1218.12, "end": 1223.58, "text": " Very differently. The XOR gate outputs a 1 if the inputs are different, and a 0 if they are the same.", "tokens": [50806, 4372, 7614, 13, 440, 1783, 2483, 8539, 23930, 257, 502, 498, 264, 15743, 366, 819, 11, 293, 257, 1958, 498, 436, 366, 264, 912, 13, 51079], "temperature": 0.0, "avg_logprob": -0.08838703693487705, "compression_ratio": 1.5435897435897437, "no_speech_prob": 1.5428669626615932e-12}, {"id": 302, "seek": 122358, "start": 1223.58, "end": 1230.84, "text": " So, two input states, 0, 0, and 11, give a 0 output, and two input states, ERA 1, and 10, give a 1 output.", "tokens": [50365, 407, 11, 732, 4846, 4368, 11, 1958, 11, 1958, 11, 293, 2975, 11, 976, 257, 1958, 5598, 11, 293, 732, 4846, 4368, 11, 462, 3750, 502, 11, 293, 1266, 11, 976, 257, 502, 5598, 13, 50728], "temperature": 0.0, "avg_logprob": -0.08687786793145608, "compression_ratio": 1.713740458015267, "no_speech_prob": 1.7688975284535502e-12}, {"id": 303, "seek": 122358, "start": 1230.98, "end": 1233.34, "text": " The distribution is perfectly balanced.", "tokens": [50735, 440, 7316, 307, 6239, 13902, 13, 50853], "temperature": 0.0, "avg_logprob": -0.08687786793145608, "compression_ratio": 1.713740458015267, "no_speech_prob": 1.7688975284535502e-12}, {"id": 304, "seek": 122358, "start": 1233.52, "end": 1241.78, "text": " So, no matter what output I see, whether it's a 1 or a 0, I am always looking at a 50-50 coin flip as to which pair of inputs created it.", "tokens": [50862, 407, 11, 572, 1871, 437, 5598, 286, 536, 11, 1968, 309, 311, 257, 502, 420, 257, 1958, 11, 286, 669, 1009, 1237, 412, 257, 2625, 12, 2803, 11464, 7929, 382, 281, 597, 6119, 295, 15743, 2942, 309, 13, 51275], "temperature": 0.0, "avg_logprob": -0.08687786793145608, "compression_ratio": 1.713740458015267, "no_speech_prob": 1.7688975284535502e-12}, {"id": 305, "seek": 122358, "start": 1242.04, "end": 1245.8799999999999, "text": " And the entropy of a perfect 50-50 coin flip is exactly 1 bit.", "tokens": [51288, 400, 264, 30867, 295, 257, 2176, 2625, 12, 2803, 11464, 7929, 307, 2293, 502, 857, 13, 51480], "temperature": 0.0, "avg_logprob": -0.08687786793145608, "compression_ratio": 1.713740458015267, "no_speech_prob": 1.7688975284535502e-12}, {"id": 306, "seek": 122358, "start": 1246.32, "end": 1251.76, "text": " Therefore, regardless of the output, an XOR gate destroys exactly 1 bit of information per operation.", "tokens": [51502, 7504, 11, 10060, 295, 264, 5598, 11, 364, 1783, 2483, 8539, 36714, 2293, 502, 857, 295, 1589, 680, 6916, 13, 51774], "temperature": 0.0, "avg_logprob": -0.08687786793145608, "compression_ratio": 1.713740458015267, "no_speech_prob": 1.7688975284535502e-12}, {"id": 307, "seek": 125176, "start": 1251.76, "end": 1254.0, "text": " So, not all geometric collapses are equal.", "tokens": [50365, 407, 11, 406, 439, 33246, 48765, 366, 2681, 13, 50477], "temperature": 0.0, "avg_logprob": -0.10772741302963375, "compression_ratio": 1.721875, "no_speech_prob": 1.7350992604497906e-12}, {"id": 308, "seek": 125176, "start": 1254.78, "end": 1258.84, "text": " Some logic gates are literally more destructive to the history of the universe than others.", "tokens": [50516, 2188, 9952, 19792, 366, 3736, 544, 26960, 281, 264, 2503, 295, 264, 6445, 813, 2357, 13, 50719], "temperature": 0.0, "avg_logprob": -0.10772741302963375, "compression_ratio": 1.721875, "no_speech_prob": 1.7350992604497906e-12}, {"id": 309, "seek": 125176, "start": 1259.0, "end": 1263.42, "text": " And that destruction is not free. It carries a physical, non-negotiable price tag.", "tokens": [50727, 400, 300, 13563, 307, 406, 1737, 13, 467, 16402, 257, 4001, 11, 2107, 12, 28561, 8206, 712, 3218, 6162, 13, 50948], "temperature": 0.0, "avg_logprob": -0.10772741302963375, "compression_ratio": 1.721875, "no_speech_prob": 1.7350992604497906e-12}, {"id": 310, "seek": 125176, "start": 1263.64, "end": 1266.78, "text": " Which brings us to a concept known as Landauer's Bound.", "tokens": [50959, 3013, 5607, 505, 281, 257, 3410, 2570, 382, 6607, 18120, 311, 363, 554, 13, 51116], "temperature": 0.0, "avg_logprob": -0.10772741302963375, "compression_ratio": 1.721875, "no_speech_prob": 1.7350992604497906e-12}, {"id": 311, "seek": 125176, "start": 1266.98, "end": 1270.28, "text": " Landauer's Bound, the thermodynamic toll bridge of the universe.", "tokens": [51126, 6607, 18120, 311, 363, 554, 11, 264, 8810, 34988, 16629, 7283, 295, 264, 6445, 13, 51291], "temperature": 0.0, "avg_logprob": -0.10772741302963375, "compression_ratio": 1.721875, "no_speech_prob": 1.7350992604497906e-12}, {"id": 312, "seek": 125176, "start": 1270.58, "end": 1276.04, "text": " In 1961, a physicist named Rolf Landauer approved a principle that shook the foundations of computing.", "tokens": [51306, 682, 41720, 11, 257, 42466, 4926, 497, 7491, 6607, 18120, 10826, 257, 8665, 300, 28438, 264, 22467, 295, 15866, 13, 51579], "temperature": 0.0, "avg_logprob": -0.10772741302963375, "compression_ratio": 1.721875, "no_speech_prob": 1.7350992604497906e-12}, {"id": 313, "seek": 125176, "start": 1276.44, "end": 1280.04, "text": " He demonstrated that erasing information is not just a mathematical abstraction.", "tokens": [51599, 634, 18772, 300, 1189, 3349, 1589, 307, 406, 445, 257, 18894, 37765, 13, 51779], "temperature": 0.0, "avg_logprob": -0.10772741302963375, "compression_ratio": 1.721875, "no_speech_prob": 1.7350992604497906e-12}, {"id": 314, "seek": 125176, "start": 1280.04, "end": 1281.64, "text": " It requires physical energy.", "tokens": [51779, 467, 7029, 4001, 2281, 13, 51859], "temperature": 0.0, "avg_logprob": -0.10772741302963375, "compression_ratio": 1.721875, "no_speech_prob": 1.7350992604497906e-12}, {"id": 315, "seek": 128176, "start": 1281.76, "end": 1286.28, "text": " It requires a physical exertion of energy that must be dissipated as heat.", "tokens": [50365, 467, 7029, 257, 4001, 31941, 313, 295, 2281, 300, 1633, 312, 29544, 770, 382, 3738, 13, 50591], "temperature": 0.0, "avg_logprob": -0.15168692754662555, "compression_ratio": 1.5823293172690762, "no_speech_prob": 2.5736739128756625e-12}, {"id": 316, "seek": 128176, "start": 1287.08, "end": 1292.9, "text": " You simply cannot destroy a bit of information without paying a minimum energy cost to the universe.", "tokens": [50631, 509, 2935, 2644, 5293, 257, 857, 295, 1589, 1553, 6229, 257, 7285, 2281, 2063, 281, 264, 6445, 13, 50922], "temperature": 0.0, "avg_logprob": -0.15168692754662555, "compression_ratio": 1.5823293172690762, "no_speech_prob": 2.5736739128756625e-12}, {"id": 317, "seek": 128176, "start": 1293.22, "end": 1293.8, "text": " What's the cost?", "tokens": [50938, 708, 311, 264, 2063, 30, 50967], "temperature": 0.0, "avg_logprob": -0.15168692754662555, "compression_ratio": 1.5823293172690762, "no_speech_prob": 2.5736739128756625e-12}, {"id": 318, "seek": 128176, "start": 1294.26, "end": 1303.02, "text": " Specifically, that cost is the Boltzmann constant, multiplied by the absolute temperature of the circuit, multiplied by the natural logarithm of 2.", "tokens": [50990, 26058, 11, 300, 2063, 307, 264, 37884, 89, 14912, 5754, 11, 17207, 538, 264, 8236, 4292, 295, 264, 9048, 11, 17207, 538, 264, 3303, 41473, 32674, 295, 568, 13, 51428], "temperature": 0.0, "avg_logprob": -0.15168692754662555, "compression_ratio": 1.5823293172690762, "no_speech_prob": 2.5736739128756625e-12}, {"id": 319, "seek": 128176, "start": 1303.44, "end": 1306.72, "text": " It is an unavoidable thermodynamic tax on forgetting.", "tokens": [51449, 467, 307, 364, 36541, 17079, 712, 8810, 34988, 3366, 322, 25428, 13, 51613], "temperature": 0.0, "avg_logprob": -0.15168692754662555, "compression_ratio": 1.5823293172690762, "no_speech_prob": 2.5736739128756625e-12}, {"id": 320, "seek": 130672, "start": 1306.72, "end": 1310.96, "text": " Here's where it gets really interesting, though, regarding the author's methodology.", "tokens": [50365, 1692, 311, 689, 309, 2170, 534, 1880, 11, 1673, 11, 8595, 264, 3793, 311, 24850, 13, 50577], "temperature": 0.0, "avg_logprob": -0.14951342205668605, "compression_ratio": 1.5537848605577689, "no_speech_prob": 2.3713600527663914e-12}, {"id": 321, "seek": 130672, "start": 1311.68, "end": 1316.74, "text": " Flixson is incredibly disciplined about where they choose to apply this thermodynamic rule.", "tokens": [50613, 3235, 970, 3015, 307, 6252, 40061, 466, 689, 436, 2826, 281, 3079, 341, 8810, 34988, 4978, 13, 50866], "temperature": 0.0, "avg_logprob": -0.14951342205668605, "compression_ratio": 1.5537848605577689, "no_speech_prob": 2.3713600527663914e-12}, {"id": 322, "seek": 130672, "start": 1316.96, "end": 1317.66, "text": " Very disciplined.", "tokens": [50877, 4372, 40061, 13, 50912], "temperature": 0.0, "avg_logprob": -0.14951342205668605, "compression_ratio": 1.5537848605577689, "no_speech_prob": 2.3713600527663914e-12}, {"id": 323, "seek": 130672, "start": 1318.1000000000001, "end": 1327.28, "text": " You would naturally assume, oh, we just established that the continuous diode destroys information when it refuses, so let's apply Landauer's Bound to the diode to see how much heat it generates.", "tokens": [50934, 509, 576, 8195, 6552, 11, 1954, 11, 321, 445, 7545, 300, 264, 10957, 40787, 36714, 1589, 562, 309, 33222, 11, 370, 718, 311, 3079, 6607, 18120, 311, 363, 554, 281, 264, 40787, 281, 536, 577, 709, 3738, 309, 23815, 13, 51393], "temperature": 0.0, "avg_logprob": -0.14951342205668605, "compression_ratio": 1.5537848605577689, "no_speech_prob": 2.3713600527663914e-12}, {"id": 324, "seek": 132728, "start": 1327.28, "end": 1329.84, "text": " But they absolutely refuse to do it.", "tokens": [50365, 583, 436, 3122, 16791, 281, 360, 309, 13, 50493], "temperature": 0.0, "avg_logprob": -0.16414456997277602, "compression_ratio": 1.6346153846153846, "no_speech_prob": 1.635626096369025e-12}, {"id": 325, "seek": 132728, "start": 1329.84, "end": 1332.94, "text": " It is a phenomenal example of the book's intellectual rigor.", "tokens": [50493, 467, 307, 257, 17778, 1365, 295, 264, 1446, 311, 12576, 42191, 13, 50648], "temperature": 0.0, "avg_logprob": -0.16414456997277602, "compression_ratio": 1.6346153846153846, "no_speech_prob": 1.635626096369025e-12}, {"id": 326, "seek": 132728, "start": 1333.5, "end": 1338.04, "text": " Landauer's Bound specifically applies to discrete clocked logical erasure.", "tokens": [50676, 6607, 18120, 311, 363, 554, 4682, 13165, 281, 27706, 7830, 292, 14978, 1189, 2508, 13, 50903], "temperature": 0.0, "avg_logprob": -0.16414456997277602, "compression_ratio": 1.6346153846153846, "no_speech_prob": 1.635626096369025e-12}, {"id": 327, "seek": 132728, "start": 1338.3, "end": 1338.82, "text": " Clocked erasure.", "tokens": [50916, 46986, 292, 1189, 2508, 13, 50942], "temperature": 0.0, "avg_logprob": -0.16414456997277602, "compression_ratio": 1.6346153846153846, "no_speech_prob": 1.635626096369025e-12}, {"id": 328, "seek": 132728, "start": 1339.08, "end": 1345.44, "text": " A logic gate makes a sudden, discrete decision at a highly specific moment in time driven by a master clock.", "tokens": [50955, 316, 9952, 8539, 1669, 257, 3990, 11, 27706, 3537, 412, 257, 5405, 2685, 1623, 294, 565, 9555, 538, 257, 4505, 7830, 13, 51273], "temperature": 0.0, "avg_logprob": -0.16414456997277602, "compression_ratio": 1.6346153846153846, "no_speech_prob": 1.635626096369025e-12}, {"id": 329, "seek": 132728, "start": 1345.82, "end": 1349.0, "text": " It forces a system from one distinct state into another.", "tokens": [51292, 467, 5874, 257, 1185, 490, 472, 10644, 1785, 666, 1071, 13, 51451], "temperature": 0.0, "avg_logprob": -0.16414456997277602, "compression_ratio": 1.6346153846153846, "no_speech_prob": 1.635626096369025e-12}, {"id": 330, "seek": 132728, "start": 1349.68, "end": 1354.28, "text": " A diode, however, is a continuous, unclocked, analog physical device.", "tokens": [51485, 316, 40787, 11, 4461, 11, 307, 257, 10957, 11, 6219, 4102, 292, 11, 16660, 4001, 4302, 13, 51715], "temperature": 0.0, "avg_logprob": -0.16414456997277602, "compression_ratio": 1.6346153846153846, "no_speech_prob": 1.635626096369025e-12}, {"id": 331, "seek": 135428, "start": 1354.28, "end": 1356.7, "text": " It's just sitting there reacting to the weather of the circuit.", "tokens": [50365, 467, 311, 445, 3798, 456, 25817, 281, 264, 5503, 295, 264, 9048, 13, 50486], "temperature": 0.0, "avg_logprob": -0.1410384178161621, "compression_ratio": 1.5696202531645569, "no_speech_prob": 2.0680397498640257e-12}, {"id": 332, "seek": 135428, "start": 1356.86, "end": 1356.98, "text": " Yes.", "tokens": [50494, 1079, 13, 50500], "temperature": 0.0, "avg_logprob": -0.1410384178161621, "compression_ratio": 1.5696202531645569, "no_speech_prob": 2.0680397498640257e-12}, {"id": 333, "seek": 135428, "start": 1357.66, "end": 1371.28, "text": " And while forward conduction in a diode absolutely produces heat, I mean, it dissipates real power that you can feel with your finger asserting a literal per erasure bit cost for a continuous analog curve is mathematically overreaching.", "tokens": [50534, 400, 1339, 2128, 43842, 294, 257, 40787, 3122, 14725, 3738, 11, 286, 914, 11, 309, 29544, 1024, 957, 1347, 300, 291, 393, 841, 365, 428, 5984, 1256, 27187, 257, 20411, 680, 1189, 2508, 857, 2063, 337, 257, 10957, 16660, 7605, 307, 44003, 670, 265, 2834, 13, 51215], "temperature": 0.0, "avg_logprob": -0.1410384178161621, "compression_ratio": 1.5696202531645569, "no_speech_prob": 2.0680397498640257e-12}, {"id": 334, "seek": 135428, "start": 1372.1399999999999, "end": 1375.48, "text": " Because you can't quantify the discrete bits in a continuous flow.", "tokens": [51258, 1436, 291, 393, 380, 40421, 264, 27706, 9239, 294, 257, 10957, 3095, 13, 51425], "temperature": 0.0, "avg_logprob": -0.1410384178161621, "compression_ratio": 1.5696202531645569, "no_speech_prob": 2.0680397498640257e-12}, {"id": 335, "seek": 137548, "start": 1375.48, "end": 1388.52, "text": " Exactly. Fliction strictly limits the thermodynamic bit erasure cost to the clocked logic gate, cleanly separating the analog diode's messy thermodynamics from the strict informational taxation of Landauer's Bound.", "tokens": [50365, 7587, 13, 3235, 4105, 20792, 10406, 264, 8810, 34988, 857, 1189, 2508, 2063, 281, 264, 7830, 292, 9952, 8539, 11, 2541, 356, 29279, 264, 16660, 40787, 311, 16191, 8810, 35483, 490, 264, 10910, 49391, 47072, 295, 6607, 18120, 311, 363, 554, 13, 51017], "temperature": 0.0, "avg_logprob": -0.07785066763559977, "compression_ratio": 1.6770833333333333, "no_speech_prob": 1.4383298154937996e-12}, {"id": 336, "seek": 137548, "start": 1388.64, "end": 1393.02, "text": " I thought of it like the difference between a bouncer at a nightclub versus a bouncer at a riot.", "tokens": [51023, 286, 1194, 295, 309, 411, 264, 2649, 1296, 257, 272, 14296, 412, 257, 1818, 40607, 5717, 257, 272, 14296, 412, 257, 32211, 13, 51242], "temperature": 0.0, "avg_logprob": -0.07785066763559977, "compression_ratio": 1.6770833333333333, "no_speech_prob": 1.4383298154937996e-12}, {"id": 337, "seek": 137548, "start": 1393.2, "end": 1394.32, "text": " Okay, I like where this is going.", "tokens": [51251, 1033, 11, 286, 411, 689, 341, 307, 516, 13, 51307], "temperature": 0.0, "avg_logprob": -0.07785066763559977, "compression_ratio": 1.6770833333333333, "no_speech_prob": 1.4383298154937996e-12}, {"id": 338, "seek": 137548, "start": 1394.4, "end": 1399.9, "text": " A bouncer at a club is checking IDs one by one, making discrete, countable decisions.", "tokens": [51311, 316, 272, 14296, 412, 257, 6482, 307, 8568, 48212, 472, 538, 472, 11, 1455, 27706, 11, 1207, 712, 5327, 13, 51586], "temperature": 0.0, "avg_logprob": -0.07785066763559977, "compression_ratio": 1.6770833333333333, "no_speech_prob": 1.4383298154937996e-12}, {"id": 339, "seek": 137548, "start": 1400.3, "end": 1402.72, "text": " You can come in, you cannot. That's the logic gate.", "tokens": [51606, 509, 393, 808, 294, 11, 291, 2644, 13, 663, 311, 264, 9952, 8539, 13, 51727], "temperature": 0.0, "avg_logprob": -0.07785066763559977, "compression_ratio": 1.6770833333333333, "no_speech_prob": 1.4383298154937996e-12}, {"id": 340, "seek": 140272, "start": 1402.72, "end": 1405.96, "text": " You can count the bits of information being processed and discarded.", "tokens": [50365, 509, 393, 1207, 264, 9239, 295, 1589, 885, 18846, 293, 45469, 13, 50527], "temperature": 0.0, "avg_logprob": -0.14562320709228516, "compression_ratio": 1.8204081632653062, "no_speech_prob": 1.5610597666956827e-12}, {"id": 341, "seek": 140272, "start": 1406.32, "end": 1415.16, "text": " But if a bouncer is just shoving a massive, continuous crowd of people out the door all at once, you can't really count the bits of information in the shove.", "tokens": [50545, 583, 498, 257, 272, 14296, 307, 445, 2223, 798, 257, 5994, 11, 10957, 6919, 295, 561, 484, 264, 2853, 439, 412, 1564, 11, 291, 393, 380, 534, 1207, 264, 9239, 295, 1589, 294, 264, 35648, 13, 50987], "temperature": 0.0, "avg_logprob": -0.14562320709228516, "compression_ratio": 1.8204081632653062, "no_speech_prob": 1.5610597666956827e-12}, {"id": 342, "seek": 140272, "start": 1415.64, "end": 1417.44, "text": " The crowd is moving continuously.", "tokens": [51011, 440, 6919, 307, 2684, 15684, 13, 51101], "temperature": 0.0, "avg_logprob": -0.14562320709228516, "compression_ratio": 1.8204081632653062, "no_speech_prob": 1.5610597666956827e-12}, {"id": 343, "seek": 140272, "start": 1417.88, "end": 1419.34, "text": " They are both doing physical work.", "tokens": [51123, 814, 366, 1293, 884, 4001, 589, 13, 51196], "temperature": 0.0, "avg_logprob": -0.14562320709228516, "compression_ratio": 1.8204081632653062, "no_speech_prob": 1.5610597666956827e-12}, {"id": 344, "seek": 140272, "start": 1419.42, "end": 1420.14, "text": " They are both sweating.", "tokens": [51200, 814, 366, 1293, 25438, 13, 51236], "temperature": 0.0, "avg_logprob": -0.14562320709228516, "compression_ratio": 1.8204081632653062, "no_speech_prob": 1.5610597666956827e-12}, {"id": 345, "seek": 140272, "start": 1420.54, "end": 1423.26, "text": " But only one is performing discrete informational erasure.", "tokens": [51256, 583, 787, 472, 307, 10205, 27706, 49391, 1189, 2508, 13, 51392], "temperature": 0.0, "avg_logprob": -0.14562320709228516, "compression_ratio": 1.8204081632653062, "no_speech_prob": 1.5610597666956827e-12}, {"id": 346, "seek": 140272, "start": 1423.6200000000001, "end": 1427.64, "text": " That is a brilliant analogy for continuous versus discrete systems.", "tokens": [51410, 663, 307, 257, 10248, 21663, 337, 10957, 5717, 27706, 3652, 13, 51611], "temperature": 0.0, "avg_logprob": -0.14562320709228516, "compression_ratio": 1.8204081632653062, "no_speech_prob": 1.5610597666956827e-12}, {"id": 347, "seek": 142764, "start": 1427.64, "end": 1437.92, "text": " So, if logic gates and diodes are constantly destroying information, if they are relentlessly shredding the past to make decisions about the present, how does a circuit ever remember anything?", "tokens": [50365, 407, 11, 498, 9952, 19792, 293, 1026, 4789, 366, 6460, 19926, 1589, 11, 498, 436, 366, 34045, 12048, 21567, 3584, 264, 1791, 281, 652, 5327, 466, 264, 1974, 11, 577, 775, 257, 9048, 1562, 1604, 1340, 30, 50879], "temperature": 0.0, "avg_logprob": -0.1342706553141276, "compression_ratio": 1.490909090909091, "no_speech_prob": 1.7485603893627188e-12}, {"id": 348, "seek": 142764, "start": 1438.3200000000002, "end": 1440.0800000000002, "text": " That's the million-dollar question.", "tokens": [50899, 663, 311, 264, 2459, 12, 40485, 1168, 13, 50987], "temperature": 0.0, "avg_logprob": -0.1342706553141276, "compression_ratio": 1.490909090909091, "no_speech_prob": 1.7485603893627188e-12}, {"id": 349, "seek": 142764, "start": 1440.2, "end": 1444.76, "text": " Right. How does my phone know what password I typed in five seconds ago? Where does the history go?", "tokens": [50993, 1779, 13, 1012, 775, 452, 2593, 458, 437, 11524, 286, 33941, 294, 1732, 3949, 2057, 30, 2305, 775, 264, 2503, 352, 30, 51221], "temperature": 0.0, "avg_logprob": -0.1342706553141276, "compression_ratio": 1.490909090909091, "no_speech_prob": 1.7485603893627188e-12}, {"id": 350, "seek": 144476, "start": 1444.76, "end": 1450.96, "text": " To understand memory in this framework, the book completely inverts how we are taught about energy storage components.", "tokens": [50365, 1407, 1223, 4675, 294, 341, 8388, 11, 264, 1446, 2584, 28653, 1373, 577, 321, 366, 5928, 466, 2281, 6725, 6677, 13, 50675], "temperature": 0.0, "avg_logprob": -0.13782093205402807, "compression_ratio": 1.6236559139784945, "no_speech_prob": 1.4956349960598692e-12}, {"id": 351, "seek": 144476, "start": 1451.56, "end": 1454.04, "text": " Let's look closely at capacitors and inductors.", "tokens": [50705, 961, 311, 574, 8185, 412, 4637, 9862, 293, 31612, 830, 13, 50829], "temperature": 0.0, "avg_logprob": -0.13782093205402807, "compression_ratio": 1.6236559139784945, "no_speech_prob": 1.4956349960598692e-12}, {"id": 352, "seek": 144476, "start": 1454.32, "end": 1455.26, "text": " Right. The classic duo.", "tokens": [50843, 1779, 13, 440, 7230, 28127, 13, 50890], "temperature": 0.0, "avg_logprob": -0.13782093205402807, "compression_ratio": 1.6236559139784945, "no_speech_prob": 1.4956349960598692e-12}, {"id": 353, "seek": 144476, "start": 1456.04, "end": 1459.7, "text": " In standard physics textbooks, you learn what is called the differential form.", "tokens": [50929, 682, 3832, 10649, 33587, 11, 291, 1466, 437, 307, 1219, 264, 15756, 1254, 13, 51112], "temperature": 0.0, "avg_logprob": -0.13782093205402807, "compression_ratio": 1.6236559139784945, "no_speech_prob": 1.4956349960598692e-12}, {"id": 354, "seek": 144476, "start": 1460.3, "end": 1466.56, "text": " You learn that the current flowing through a capacitor is directly proportional to the instantaneous derivative of the voltage.", "tokens": [51142, 509, 1466, 300, 264, 2190, 13974, 807, 257, 29372, 307, 3838, 24969, 281, 264, 45596, 13760, 295, 264, 8352, 13, 51455], "temperature": 0.0, "avg_logprob": -0.13782093205402807, "compression_ratio": 1.6236559139784945, "no_speech_prob": 1.4956349960598692e-12}, {"id": 355, "seek": 144476, "start": 1467.18, "end": 1470.2, "text": " It is all about capturing the immediate rate of change.", "tokens": [51486, 467, 307, 439, 466, 23384, 264, 11629, 3314, 295, 1319, 13, 51637], "temperature": 0.0, "avg_logprob": -0.13782093205402807, "compression_ratio": 1.6236559139784945, "no_speech_prob": 1.4956349960598692e-12}, {"id": 356, "seek": 147020, "start": 1470.2, "end": 1475.0800000000002, "text": " But fliction insists that viewing it through the derivative is conceptually backwards.", "tokens": [50365, 583, 932, 4105, 50137, 300, 17480, 309, 807, 264, 13760, 307, 3410, 671, 12204, 13, 50609], "temperature": 0.0, "avg_logprob": -0.1982847981982761, "compression_ratio": 1.615, "no_speech_prob": 2.2451517641547403e-12}, {"id": 357, "seek": 147020, "start": 1476.04, "end": 1480.5, "text": " To understand the geometry of circuits, we must look at the integral form.", "tokens": [50657, 1407, 1223, 264, 18426, 295, 26354, 11, 321, 1633, 574, 412, 264, 11573, 1254, 13, 50880], "temperature": 0.0, "avg_logprob": -0.1982847981982761, "compression_ratio": 1.615, "no_speech_prob": 2.2451517641547403e-12}, {"id": 358, "seek": 147020, "start": 1480.6200000000001, "end": 1481.18, "text": " The integral.", "tokens": [50886, 440, 11573, 13, 50914], "temperature": 0.0, "avg_logprob": -0.1982847981982761, "compression_ratio": 1.615, "no_speech_prob": 2.2451517641547403e-12}, {"id": 359, "seek": 147020, "start": 1481.3600000000001, "end": 1485.8600000000001, "text": " The voltage resting on a capacitor isn't just a number that happens to have a derivative.", "tokens": [50923, 440, 8352, 21221, 322, 257, 29372, 1943, 380, 445, 257, 1230, 300, 2314, 281, 362, 257, 13760, 13, 51148], "temperature": 0.0, "avg_logprob": -0.1982847981982761, "compression_ratio": 1.615, "no_speech_prob": 2.2451517641547403e-12}, {"id": 360, "seek": 147020, "start": 1486.4, "end": 1490.18, "text": " The voltage is quite literally the mathematical integral.", "tokens": [51175, 440, 8352, 307, 1596, 3736, 264, 18894, 11573, 13, 51364], "temperature": 0.0, "avg_logprob": -0.1982847981982761, "compression_ratio": 1.615, "no_speech_prob": 2.2451517641547403e-12}, {"id": 361, "seek": 149018, "start": 1490.18, "end": 1497.5800000000002, "text": " The physical, accumulated record of all the current that has ever flowed into that component since the beginning of time.", "tokens": [50365, 440, 4001, 11, 31346, 2136, 295, 439, 264, 2190, 300, 575, 1562, 3095, 292, 666, 300, 6542, 1670, 264, 2863, 295, 565, 13, 50735], "temperature": 0.0, "avg_logprob": -0.14781221662248883, "compression_ratio": 1.6917293233082706, "no_speech_prob": 1.6682360787917405e-12}, {"id": 362, "seek": 149018, "start": 1498.02, "end": 1500.74, "text": " Or at least since the moment you supplied power to the board.", "tokens": [50757, 1610, 412, 1935, 1670, 264, 1623, 291, 27625, 1347, 281, 264, 3150, 13, 50893], "temperature": 0.0, "avg_logprob": -0.14781221662248883, "compression_ratio": 1.6917293233082706, "no_speech_prob": 1.6682360787917405e-12}, {"id": 363, "seek": 149018, "start": 1500.92, "end": 1504.26, "text": " So the component is acting as a physical memory bank for the electrons.", "tokens": [50902, 407, 264, 6542, 307, 6577, 382, 257, 4001, 4675, 3765, 337, 264, 14265, 13, 51069], "temperature": 0.0, "avg_logprob": -0.14781221662248883, "compression_ratio": 1.6917293233082706, "no_speech_prob": 1.6682360787917405e-12}, {"id": 364, "seek": 149018, "start": 1504.6000000000001, "end": 1506.66, "text": " It is hoarding the history of the current.", "tokens": [51086, 467, 307, 45940, 278, 264, 2503, 295, 264, 2190, 13, 51189], "temperature": 0.0, "avg_logprob": -0.14781221662248883, "compression_ratio": 1.6917293233082706, "no_speech_prob": 1.6682360787917405e-12}, {"id": 365, "seek": 149018, "start": 1507.18, "end": 1515.7, "text": " But the book proves, in a section labeled Proposition 9, that this physical memory is both highly specific and deeply fundamentally flawed.", "tokens": [51215, 583, 264, 1446, 25019, 11, 294, 257, 3541, 21335, 21944, 5830, 1722, 11, 300, 341, 4001, 4675, 307, 1293, 5405, 2685, 293, 8760, 17879, 38823, 13, 51641], "temperature": 0.0, "avg_logprob": -0.14781221662248883, "compression_ratio": 1.6917293233082706, "no_speech_prob": 1.6682360787917405e-12}, {"id": 366, "seek": 149018, "start": 1515.8600000000001, "end": 1516.3400000000001, "text": " Flawed how?", "tokens": [51649, 479, 5901, 292, 577, 30, 51673], "temperature": 0.0, "avg_logprob": -0.14781221662248883, "compression_ratio": 1.6917293233082706, "no_speech_prob": 1.6682360787917405e-12}, {"id": 367, "seek": 151634, "start": 1516.34, "end": 1523.08, "text": " Two completely different, wildly varying histories of current can result in the exact same final capacitor voltage.", "tokens": [50365, 4453, 2584, 819, 11, 34731, 22984, 30631, 295, 2190, 393, 1874, 294, 264, 1900, 912, 2572, 29372, 8352, 13, 50702], "temperature": 0.0, "avg_logprob": -0.09453257139738616, "compression_ratio": 1.631578947368421, "no_speech_prob": 1.694508791096061e-12}, {"id": 368, "seek": 151634, "start": 1523.32, "end": 1525.6599999999999, "text": " So a capacitor is exactly like a bank account balance.", "tokens": [50714, 407, 257, 29372, 307, 2293, 411, 257, 3765, 2696, 4772, 13, 50831], "temperature": 0.0, "avg_logprob": -0.09453257139738616, "compression_ratio": 1.631578947368421, "no_speech_prob": 1.694508791096061e-12}, {"id": 369, "seek": 151634, "start": 1525.76, "end": 1525.9599999999998, "text": " Yes.", "tokens": [50836, 1079, 13, 50846], "temperature": 0.0, "avg_logprob": -0.09453257139738616, "compression_ratio": 1.631578947368421, "no_speech_prob": 1.694508791096061e-12}, {"id": 370, "seek": 151634, "start": 1526.1399999999999, "end": 1531.3, "text": " If I log into my banking app right now and it says I have exactly $100, that number is my current state.", "tokens": [50855, 759, 286, 3565, 666, 452, 18261, 724, 558, 586, 293, 309, 1619, 286, 362, 2293, 1848, 6879, 11, 300, 1230, 307, 452, 2190, 1785, 13, 51113], "temperature": 0.0, "avg_logprob": -0.09453257139738616, "compression_ratio": 1.631578947368421, "no_speech_prob": 1.694508791096061e-12}, {"id": 371, "seek": 151634, "start": 1531.58, "end": 1535.72, "text": " It tells me the total amount of purchasing power I possess in this exact millisecond.", "tokens": [51127, 467, 5112, 385, 264, 3217, 2372, 295, 20906, 1347, 286, 17490, 294, 341, 1900, 27940, 18882, 13, 51334], "temperature": 0.0, "avg_logprob": -0.09453257139738616, "compression_ratio": 1.631578947368421, "no_speech_prob": 1.694508791096061e-12}, {"id": 372, "seek": 151634, "start": 1535.8, "end": 1535.9399999999998, "text": " Right.", "tokens": [51338, 1779, 13, 51345], "temperature": 0.0, "avg_logprob": -0.09453257139738616, "compression_ratio": 1.631578947368421, "no_speech_prob": 1.694508791096061e-12}, {"id": 373, "seek": 151634, "start": 1535.9599999999998, "end": 1542.4399999999998, "text": " But that state completely, utterly discards the unique, chaotic history of how I got there.", "tokens": [51346, 583, 300, 1785, 2584, 11, 30251, 2983, 2287, 264, 3845, 11, 27013, 2503, 295, 577, 286, 658, 456, 13, 51670], "temperature": 0.0, "avg_logprob": -0.09453257139738616, "compression_ratio": 1.631578947368421, "no_speech_prob": 1.694508791096061e-12}, {"id": 374, "seek": 154244, "start": 1542.44, "end": 1547.16, "text": " Did you deposit a single $100 bill 10 years ago and never touch it?", "tokens": [50365, 2589, 291, 19107, 257, 2167, 1848, 6879, 2961, 1266, 924, 2057, 293, 1128, 2557, 309, 30, 50601], "temperature": 0.0, "avg_logprob": -0.13183652748495844, "compression_ratio": 1.5924657534246576, "no_speech_prob": 1.5798351125570487e-12}, {"id": 375, "seek": 154244, "start": 1547.3, "end": 1547.74, "text": " Exactly.", "tokens": [50608, 7587, 13, 50630], "temperature": 0.0, "avg_logprob": -0.13183652748495844, "compression_ratio": 1.5924657534246576, "no_speech_prob": 1.5798351125570487e-12}, {"id": 376, "seek": 154244, "start": 1548.28, "end": 1555.22, "text": " Or did I deposit $1,000 yesterday and then spend $900 on a ridiculously expensive, ill-advised dinner last night?", "tokens": [50657, 1610, 630, 286, 19107, 1848, 16, 11, 1360, 5186, 293, 550, 3496, 1848, 23943, 322, 257, 41358, 5124, 11, 3171, 12, 345, 24420, 6148, 1036, 1818, 30, 51004], "temperature": 0.0, "avg_logprob": -0.13183652748495844, "compression_ratio": 1.5924657534246576, "no_speech_prob": 1.5798351125570487e-12}, {"id": 377, "seek": 154244, "start": 1555.64, "end": 1556.3600000000001, "text": " The balance?", "tokens": [51025, 440, 4772, 30, 51061], "temperature": 0.0, "avg_logprob": -0.13183652748495844, "compression_ratio": 1.5924657534246576, "no_speech_prob": 1.5798351125570487e-12}, {"id": 378, "seek": 154244, "start": 1556.76, "end": 1558.72, "text": " The present state doesn't know and it doesn't care.", "tokens": [51081, 440, 1974, 1785, 1177, 380, 458, 293, 309, 1177, 380, 1127, 13, 51179], "temperature": 0.0, "avg_logprob": -0.13183652748495844, "compression_ratio": 1.5924657534246576, "no_speech_prob": 1.5798351125570487e-12}, {"id": 379, "seek": 154244, "start": 1559.14, "end": 1561.46, "text": " The state actively discards the history.", "tokens": [51200, 440, 1785, 13022, 2983, 2287, 264, 2503, 13, 51316], "temperature": 0.0, "avg_logprob": -0.13183652748495844, "compression_ratio": 1.5924657534246576, "no_speech_prob": 1.5798351125570487e-12}, {"id": 380, "seek": 154244, "start": 1561.72, "end": 1567.68, "text": " And this is exactly why control theorists and electrical engineers refer to these values as state variables.", "tokens": [51329, 400, 341, 307, 2293, 983, 1969, 27423, 1751, 293, 12147, 11955, 2864, 281, 613, 4190, 382, 1785, 9102, 13, 51627], "temperature": 0.0, "avg_logprob": -0.13183652748495844, "compression_ratio": 1.5924657534246576, "no_speech_prob": 1.5798351125570487e-12}, {"id": 381, "seek": 154244, "start": 1568.26, "end": 1572.0, "text": " The state is an intentional, lossy compression of the past.", "tokens": [51656, 440, 1785, 307, 364, 21935, 11, 4470, 88, 19355, 295, 264, 1791, 13, 51843], "temperature": 0.0, "avg_logprob": -0.13183652748495844, "compression_ratio": 1.5924657534246576, "no_speech_prob": 1.5798351125570487e-12}, {"id": 382, "seek": 157200, "start": 1572.0, "end": 1572.94, "text": " Aussie compression.", "tokens": [50365, 21286, 414, 19355, 13, 50412], "temperature": 0.0, "avg_logprob": -0.12473153273264567, "compression_ratio": 1.6978417266187051, "no_speech_prob": 1.5134012749593029e-12}, {"id": 383, "seek": 157200, "start": 1573.08, "end": 1573.92, "text": " I love that term.", "tokens": [50419, 286, 959, 300, 1433, 13, 50461], "temperature": 0.0, "avg_logprob": -0.12473153273264567, "compression_ratio": 1.6978417266187051, "no_speech_prob": 1.5134012749593029e-12}, {"id": 384, "seek": 157200, "start": 1574.28, "end": 1586.56, "text": " The physical system compresses its entire complex, meandering history into a single measurable number, the voltage across the plates, and it permanently throws away the specific path it took to arrive at that number.", "tokens": [50479, 440, 4001, 1185, 14778, 279, 1080, 2302, 3997, 11, 385, 474, 1794, 2503, 666, 257, 2167, 43615, 1230, 11, 264, 8352, 2108, 264, 14231, 11, 293, 309, 24042, 19251, 1314, 264, 2685, 3100, 309, 1890, 281, 8881, 412, 300, 1230, 13, 51093], "temperature": 0.0, "avg_logprob": -0.12473153273264567, "compression_ratio": 1.6978417266187051, "no_speech_prob": 1.5134012749593029e-12}, {"id": 385, "seek": 157200, "start": 1586.68, "end": 1587.54, "text": " Because it doesn't need it.", "tokens": [51099, 1436, 309, 1177, 380, 643, 309, 13, 51142], "temperature": 0.0, "avg_logprob": -0.12473153273264567, "compression_ratio": 1.6978417266187051, "no_speech_prob": 1.5134012749593029e-12}, {"id": 386, "seek": 157200, "start": 1587.92, "end": 1588.4, "text": " Exactly.", "tokens": [51161, 7587, 13, 51185], "temperature": 0.0, "avg_logprob": -0.12473153273264567, "compression_ratio": 1.6978417266187051, "no_speech_prob": 1.5134012749593029e-12}, {"id": 387, "seek": 157200, "start": 1588.68, "end": 1593.16, "text": " To calculate what the circuit will do in the next microsecond, it doesn't need the whole story.", "tokens": [51199, 1407, 8873, 437, 264, 9048, 486, 360, 294, 264, 958, 3123, 37841, 18882, 11, 309, 1177, 380, 643, 264, 1379, 1657, 13, 51423], "temperature": 0.0, "avg_logprob": -0.12473153273264567, "compression_ratio": 1.6978417266187051, "no_speech_prob": 1.5134012749593029e-12}, {"id": 388, "seek": 157200, "start": 1593.38, "end": 1595.62, "text": " It only needs that single compressed number.", "tokens": [51434, 467, 787, 2203, 300, 2167, 30353, 1230, 13, 51546], "temperature": 0.0, "avg_logprob": -0.12473153273264567, "compression_ratio": 1.6978417266187051, "no_speech_prob": 1.5134012749593029e-12}, {"id": 389, "seek": 157200, "start": 1595.7, "end": 1597.34, "text": " It is almost liberating in a way.", "tokens": [51550, 467, 307, 1920, 6774, 990, 294, 257, 636, 13, 51632], "temperature": 0.0, "avg_logprob": -0.12473153273264567, "compression_ratio": 1.6978417266187051, "no_speech_prob": 1.5134012749593029e-12}, {"id": 390, "seek": 157200, "start": 1597.38, "end": 1597.56, "text": " Yeah.", "tokens": [51634, 865, 13, 51643], "temperature": 0.0, "avg_logprob": -0.12473153273264567, "compression_ratio": 1.6978417266187051, "no_speech_prob": 1.5134012749593029e-12}, {"id": 391, "seek": 159756, "start": 1597.56, "end": 1601.6399999999999, "text": " The circuit doesn't have to carry the heavy cognitive burden of its entire past.", "tokens": [50365, 440, 9048, 1177, 380, 362, 281, 3985, 264, 4676, 15605, 12578, 295, 1080, 2302, 1791, 13, 50569], "temperature": 0.0, "avg_logprob": -0.14107220261185258, "compression_ratio": 1.5203252032520325, "no_speech_prob": 1.3935754676966394e-12}, {"id": 392, "seek": 159756, "start": 1601.8, "end": 1604.06, "text": " It just carries the tightly compressed summary.", "tokens": [50577, 467, 445, 16402, 264, 21952, 30353, 12691, 13, 50690], "temperature": 0.0, "avg_logprob": -0.14107220261185258, "compression_ratio": 1.5203252032520325, "no_speech_prob": 1.3935754676966394e-12}, {"id": 393, "seek": 159756, "start": 1604.54, "end": 1613.26, "text": " But that lingering dependence on history explains so many physical quirks that engineers usually just treat as frustrating annoyances to be designed around.", "tokens": [50714, 583, 300, 49542, 31704, 322, 2503, 13948, 370, 867, 4001, 35645, 1694, 300, 11955, 2673, 445, 2387, 382, 16522, 8759, 2676, 281, 312, 4761, 926, 13, 51150], "temperature": 0.0, "avg_logprob": -0.14107220261185258, "compression_ratio": 1.5203252032520325, "no_speech_prob": 1.3935754676966394e-12}, {"id": 394, "seek": 159756, "start": 1614.1, "end": 1617.56, "text": " A perfect example is a phenomenon called diode reverse recovery.", "tokens": [51192, 316, 2176, 1365, 307, 257, 14029, 1219, 40787, 9943, 8597, 13, 51365], "temperature": 0.0, "avg_logprob": -0.14107220261185258, "compression_ratio": 1.5203252032520325, "no_speech_prob": 1.3935754676966394e-12}, {"id": 395, "seek": 159756, "start": 1617.76, "end": 1618.48, "text": " Oh, I've heard of this.", "tokens": [51375, 876, 11, 286, 600, 2198, 295, 341, 13, 51411], "temperature": 0.0, "avg_logprob": -0.14107220261185258, "compression_ratio": 1.5203252032520325, "no_speech_prob": 1.3935754676966394e-12}, {"id": 396, "seek": 161848, "start": 1618.48, "end": 1625.9, "text": " When you try to switch a power diode off really, really fast, it doesn't just instantly snap into the refuse state like the map says it should.", "tokens": [50365, 1133, 291, 853, 281, 3679, 257, 1347, 40787, 766, 534, 11, 534, 2370, 11, 309, 1177, 380, 445, 13518, 13650, 666, 264, 16791, 1785, 411, 264, 4471, 1619, 309, 820, 13, 50736], "temperature": 0.0, "avg_logprob": -0.10956123897007533, "compression_ratio": 1.3495934959349594, "no_speech_prob": 1.542873901555497e-12}, {"id": 397, "seek": 161848, "start": 1626.08, "end": 1627.28, "text": " It absolutely doesn't.", "tokens": [50745, 467, 3122, 1177, 380, 13, 50805], "temperature": 0.0, "avg_logprob": -0.10956123897007533, "compression_ratio": 1.3495934959349594, "no_speech_prob": 1.542873901555497e-12}, {"id": 398, "seek": 162728, "start": 1627.28, "end": 1638.66, "text": " If a physical diode has been conducting a heavy forward current, it physically builds up a massive amount of stored minority carrier charge deep inside its silicon junction.", "tokens": [50365, 759, 257, 4001, 40787, 575, 668, 21749, 257, 4676, 2128, 2190, 11, 309, 9762, 15182, 493, 257, 5994, 2372, 295, 12187, 16166, 17574, 4602, 2452, 1854, 1080, 22848, 33718, 13, 50934], "temperature": 0.0, "avg_logprob": -0.09404491123400237, "compression_ratio": 1.6805555555555556, "no_speech_prob": 1.8253178916266544e-12}, {"id": 399, "seek": 162728, "start": 1638.84, "end": 1639.7, "text": " So it gets clogged up.", "tokens": [50943, 407, 309, 2170, 34455, 3004, 493, 13, 50986], "temperature": 0.0, "avg_logprob": -0.09404491123400237, "compression_ratio": 1.6805555555555556, "no_speech_prob": 1.8253178916266544e-12}, {"id": 400, "seek": 162728, "start": 1639.8999999999999, "end": 1640.06, "text": " Yeah.", "tokens": [50996, 865, 13, 51004], "temperature": 0.0, "avg_logprob": -0.09404491123400237, "compression_ratio": 1.6805555555555556, "no_speech_prob": 1.8253178916266544e-12}, {"id": 401, "seek": 162728, "start": 1640.36, "end": 1652.18, "text": " When you suddenly reverse the voltage, trying to slam the door shut, the diode actually conducts current backward for a tiny chaotic fraction of a microsecond while it sweeps all that stored charge out of the junction.", "tokens": [51019, 1133, 291, 5800, 9943, 264, 8352, 11, 1382, 281, 25617, 264, 2853, 5309, 11, 264, 40787, 767, 6018, 82, 2190, 23897, 337, 257, 5870, 27013, 14135, 295, 257, 3123, 37841, 18882, 1339, 309, 2484, 10653, 439, 300, 12187, 4602, 484, 295, 264, 33718, 13, 51610], "temperature": 0.0, "avg_logprob": -0.09404491123400237, "compression_ratio": 1.6805555555555556, "no_speech_prob": 1.8253178916266544e-12}, {"id": 402, "seek": 162728, "start": 1652.36, "end": 1653.32, "text": " Wait, it conducts backward?", "tokens": [51619, 3802, 11, 309, 6018, 82, 23897, 30, 51667], "temperature": 0.0, "avg_logprob": -0.09404491123400237, "compression_ratio": 1.6805555555555556, "no_speech_prob": 1.8253178916266544e-12}, {"id": 403, "seek": 162728, "start": 1653.42, "end": 1654.3799999999999, "text": " I thought it was a one-way street.", "tokens": [51672, 286, 1194, 309, 390, 257, 472, 12, 676, 4838, 13, 51720], "temperature": 0.0, "avg_logprob": -0.09404491123400237, "compression_ratio": 1.6805555555555556, "no_speech_prob": 1.8253178916266544e-12}, {"id": 404, "seek": 165438, "start": 1654.38, "end": 1659.3400000000001, "text": " Usually, yes. But for a brief moment, the diode remembers that it was just conducting.", "tokens": [50365, 11419, 11, 2086, 13, 583, 337, 257, 5353, 1623, 11, 264, 40787, 26228, 300, 309, 390, 445, 21749, 13, 50613], "temperature": 0.0, "avg_logprob": -0.13830827240251067, "compression_ratio": 1.631578947368421, "no_speech_prob": 1.5132513297988481e-12}, {"id": 405, "seek": 165438, "start": 1659.9, "end": 1664.8200000000002, "text": " Its present behavior isn't just a blind reaction to the present voltage pushing against it.", "tokens": [50641, 6953, 1974, 5223, 1943, 380, 445, 257, 6865, 5480, 281, 264, 1974, 8352, 7380, 1970, 309, 13, 50887], "temperature": 0.0, "avg_logprob": -0.13830827240251067, "compression_ratio": 1.631578947368421, "no_speech_prob": 1.5132513297988481e-12}, {"id": 406, "seek": 165438, "start": 1665.1200000000001, "end": 1668.2800000000002, "text": " It is a desperate reaction to its own recent history.", "tokens": [50902, 467, 307, 257, 17601, 5480, 281, 1080, 1065, 5162, 2503, 13, 51060], "temperature": 0.0, "avg_logprob": -0.13830827240251067, "compression_ratio": 1.631578947368421, "no_speech_prob": 1.5132513297988481e-12}, {"id": 407, "seek": 165438, "start": 1668.7, "end": 1674.96, "text": " So the diode is somehow acting as both an irreversible shredder and a lossy historian simultaneously.", "tokens": [51081, 407, 264, 40787, 307, 6063, 6577, 382, 1293, 364, 16014, 840, 964, 21567, 1068, 293, 257, 4470, 88, 25139, 16561, 13, 51394], "temperature": 0.0, "avg_logprob": -0.13830827240251067, "compression_ratio": 1.631578947368421, "no_speech_prob": 1.5132513297988481e-12}, {"id": 408, "seek": 165438, "start": 1675.3600000000001, "end": 1680.22, "text": " And this concept of trapping history scales up perfectly to sequential logic in computers.", "tokens": [51414, 400, 341, 3410, 295, 944, 3759, 2503, 17408, 493, 6239, 281, 42881, 9952, 294, 10807, 13, 51657], "temperature": 0.0, "avg_logprob": -0.13830827240251067, "compression_ratio": 1.631578947368421, "no_speech_prob": 1.5132513297988481e-12}, {"id": 409, "seek": 165438, "start": 1680.8400000000001, "end": 1682.8200000000002, "text": " Things like flip-flops and memory registers.", "tokens": [51688, 9514, 411, 7929, 12, 3423, 3370, 293, 4675, 38351, 13, 51787], "temperature": 0.0, "avg_logprob": -0.13830827240251067, "compression_ratio": 1.631578947368421, "no_speech_prob": 1.5132513297988481e-12}, {"id": 410, "seek": 165438, "start": 1683.2800000000002, "end": 1684.2600000000002, "text": " Okay, how does that work?", "tokens": [51810, 1033, 11, 577, 775, 300, 589, 30, 51859], "temperature": 0.0, "avg_logprob": -0.13830827240251067, "compression_ratio": 1.631578947368421, "no_speech_prob": 1.5132513297988481e-12}, {"id": 411, "seek": 168426, "start": 1684.26, "end": 1688.72, "text": " Well, combinational logic, like the AND gate we talked about earlier, is purely memoryless.", "tokens": [50365, 1042, 11, 38514, 1478, 9952, 11, 411, 264, 8093, 8539, 321, 2825, 466, 3071, 11, 307, 17491, 4675, 1832, 13, 50588], "temperature": 0.0, "avg_logprob": -0.13669627904891968, "compression_ratio": 1.5140562248995983, "no_speech_prob": 2.201725997699744e-12}, {"id": 412, "seek": 168426, "start": 1688.72, "end": 1690.66, "text": " It shreds the past instantly.", "tokens": [50588, 467, 21567, 82, 264, 1791, 13518, 13, 50685], "temperature": 0.0, "avg_logprob": -0.13669627904891968, "compression_ratio": 1.5140562248995983, "no_speech_prob": 2.201725997699744e-12}, {"id": 413, "seek": 168426, "start": 1691.36, "end": 1697.96, "text": " But a flip-flop takes the shredded output of a logic gate and carefully routes it back around to feed into its own input.", "tokens": [50720, 583, 257, 7929, 12, 3423, 404, 2516, 264, 39091, 5598, 295, 257, 9952, 8539, 293, 7500, 18242, 309, 646, 926, 281, 3154, 666, 1080, 1065, 4846, 13, 51050], "temperature": 0.0, "avg_logprob": -0.13669627904891968, "compression_ratio": 1.5140562248995983, "no_speech_prob": 2.201725997699744e-12}, {"id": 414, "seek": 168426, "start": 1698.16, "end": 1698.52, "text": " Oh, wow.", "tokens": [51060, 876, 11, 6076, 13, 51078], "temperature": 0.0, "avg_logprob": -0.13669627904891968, "compression_ratio": 1.5140562248995983, "no_speech_prob": 2.201725997699744e-12}, {"id": 415, "seek": 168426, "start": 1698.66, "end": 1702.34, "text": " Yeah, it physically traps a bit of history inside a continuous geometric loop.", "tokens": [51085, 865, 11, 309, 9762, 24173, 257, 857, 295, 2503, 1854, 257, 10957, 33246, 6367, 13, 51269], "temperature": 0.0, "avg_logprob": -0.13669627904891968, "compression_ratio": 1.5140562248995983, "no_speech_prob": 2.201725997699744e-12}, {"id": 416, "seek": 168426, "start": 1702.46, "end": 1704.66, "text": " Which brings us to a thrilling turning point.", "tokens": [51275, 3013, 5607, 505, 281, 257, 39347, 6246, 935, 13, 51385], "temperature": 0.0, "avg_logprob": -0.13669627904891968, "compression_ratio": 1.5140562248995983, "no_speech_prob": 2.201725997699744e-12}, {"id": 417, "seek": 170466, "start": 1704.66, "end": 1709.48, "text": " We now have components that act as lossy historians, compressing the past.", "tokens": [50365, 492, 586, 362, 6677, 300, 605, 382, 4470, 88, 26442, 11, 14778, 278, 264, 1791, 13, 50606], "temperature": 0.0, "avg_logprob": -0.16732279459635416, "compression_ratio": 1.8457446808510638, "no_speech_prob": 1.5370940197739769e-12}, {"id": 418, "seek": 170466, "start": 1709.98, "end": 1714.16, "text": " We have components that irreversibly destroy information to make decisions.", "tokens": [50631, 492, 362, 6677, 300, 16014, 840, 3545, 5293, 1589, 281, 652, 5327, 13, 50840], "temperature": 0.0, "avg_logprob": -0.16732279459635416, "compression_ratio": 1.8457446808510638, "no_speech_prob": 1.5370940197739769e-12}, {"id": 419, "seek": 170466, "start": 1714.3200000000002, "end": 1714.5400000000002, "text": " Right.", "tokens": [50848, 1779, 13, 50859], "temperature": 0.0, "avg_logprob": -0.16732279459635416, "compression_ratio": 1.8457446808510638, "no_speech_prob": 1.5370940197739769e-12}, {"id": 420, "seek": 170466, "start": 1714.7, "end": 1716.8400000000001, "text": " What happens when we wire them together in a circle?", "tokens": [50867, 708, 2314, 562, 321, 6234, 552, 1214, 294, 257, 6329, 30, 50974], "temperature": 0.0, "avg_logprob": -0.16732279459635416, "compression_ratio": 1.8457446808510638, "no_speech_prob": 1.5370940197739769e-12}, {"id": 421, "seek": 170466, "start": 1717.1200000000001, "end": 1723.94, "text": " What happens when the output of the shredder feeds back into the historian and the output of the historian feeds back into the shredder?", "tokens": [50988, 708, 2314, 562, 264, 5598, 295, 264, 21567, 1068, 23712, 646, 666, 264, 25139, 293, 264, 5598, 295, 264, 25139, 23712, 646, 666, 264, 21567, 1068, 30, 51329], "temperature": 0.0, "avg_logprob": -0.16732279459635416, "compression_ratio": 1.8457446808510638, "no_speech_prob": 1.5370940197739769e-12}, {"id": 422, "seek": 172394, "start": 1723.94, "end": 1727.18, "text": " It seems like you would get a circuit that takes on a life of its own.", "tokens": [50365, 467, 2544, 411, 291, 576, 483, 257, 9048, 300, 2516, 322, 257, 993, 295, 1080, 1065, 13, 50527], "temperature": 0.0, "avg_logprob": -0.1932762690952846, "compression_ratio": 1.0, "no_speech_prob": 2.2531199996012052e-12}, {"id": 423, "seek": 172718, "start": 1727.18, "end": 1729.3, "text": " You get the phenomenon of feedback.", "tokens": [50365, 509, 483, 264, 14029, 295, 5824, 13, 50471], "temperature": 0.0, "avg_logprob": -0.15772651856945408, "compression_ratio": 1.5917159763313609, "no_speech_prob": 1.6674253124071559e-12}, {"id": 424, "seek": 172718, "start": 1730.1000000000001, "end": 1733.92, "text": " Infliction defines a feedback loop in purely geometric terms.", "tokens": [50511, 682, 3423, 4105, 23122, 257, 5824, 6367, 294, 17491, 33246, 2115, 13, 50702], "temperature": 0.0, "avg_logprob": -0.15772651856945408, "compression_ratio": 1.5917159763313609, "no_speech_prob": 1.6674253124071559e-12}, {"id": 425, "seek": 172718, "start": 1734.54, "end": 1740.94, "text": " It is a system that actively defines its own output by demanding that the output satisfy its own defining condition.", "tokens": [50733, 467, 307, 257, 1185, 300, 13022, 23122, 1080, 1065, 5598, 538, 19960, 300, 264, 5598, 19319, 1080, 1065, 17827, 4188, 13, 51053], "temperature": 0.0, "avg_logprob": -0.15772651856945408, "compression_ratio": 1.5917159763313609, "no_speech_prob": 1.6674253124071559e-12}, {"id": 426, "seek": 172718, "start": 1741.0800000000002, "end": 1743.88, "text": " It's a literal fixed point equation made out of metal.", "tokens": [51060, 467, 311, 257, 20411, 6806, 935, 5367, 1027, 484, 295, 5760, 13, 51200], "temperature": 0.0, "avg_logprob": -0.15772651856945408, "compression_ratio": 1.5917159763313609, "no_speech_prob": 1.6674253124071559e-12}, {"id": 427, "seek": 174388, "start": 1743.88, "end": 1745.5400000000002, "text": " That is exactly what it is.", "tokens": [50365, 663, 307, 2293, 437, 309, 307, 13, 50448], "temperature": 0.0, "avg_logprob": -0.09574539058811062, "compression_ratio": 1.62109375, "no_speech_prob": 2.068529809245989e-12}, {"id": 428, "seek": 174388, "start": 1745.88, "end": 1750.0600000000002, "text": " The output isn't just calculated in a straight forward marching line from the input.", "tokens": [50465, 440, 5598, 1943, 380, 445, 15598, 294, 257, 2997, 2128, 30523, 1622, 490, 264, 4846, 13, 50674], "temperature": 0.0, "avg_logprob": -0.09574539058811062, "compression_ratio": 1.62109375, "no_speech_prob": 2.068529809245989e-12}, {"id": 429, "seek": 174388, "start": 1750.5400000000002, "end": 1758.3200000000002, "text": " The output becomes whatever specific physical value balances the complex equation of the signal feeding back into itself.", "tokens": [50698, 440, 5598, 3643, 2035, 2685, 4001, 2158, 33993, 264, 3997, 5367, 295, 264, 6358, 12919, 646, 666, 2564, 13, 51087], "temperature": 0.0, "avg_logprob": -0.09574539058811062, "compression_ratio": 1.62109375, "no_speech_prob": 2.068529809245989e-12}, {"id": 430, "seek": 174388, "start": 1758.42, "end": 1760.5400000000002, "text": " It is mathematical self-reference made physical.", "tokens": [51092, 467, 307, 18894, 2698, 12, 265, 5158, 1027, 4001, 13, 51198], "temperature": 0.0, "avg_logprob": -0.09574539058811062, "compression_ratio": 1.62109375, "no_speech_prob": 2.068529809245989e-12}, {"id": 431, "seek": 174388, "start": 1760.88, "end": 1767.64, "text": " But the real magic, the moment where this all feels like it transcends engineering, is when that feedback loop starts to oscillate.", "tokens": [51215, 583, 264, 957, 5585, 11, 264, 1623, 689, 341, 439, 3417, 411, 309, 43800, 2581, 7043, 11, 307, 562, 300, 5824, 6367, 3719, 281, 18225, 473, 13, 51553], "temperature": 0.0, "avg_logprob": -0.09574539058811062, "compression_ratio": 1.62109375, "no_speech_prob": 2.068529809245989e-12}, {"id": 432, "seek": 176764, "start": 1767.64, "end": 1775.96, "text": " When it stops just quietly sitting there at a balanced equilibrium and spontaneously starts generating a wave, a rhythm, a heartbeat.", "tokens": [50365, 1133, 309, 10094, 445, 19141, 3798, 456, 412, 257, 13902, 15625, 293, 47632, 3719, 17746, 257, 5772, 11, 257, 11801, 11, 257, 34851, 13, 50781], "temperature": 0.0, "avg_logprob": -0.1368624044924366, "compression_ratio": 1.604026845637584, "no_speech_prob": 2.0929232739247405e-12}, {"id": 433, "seek": 176764, "start": 1776.38, "end": 1783.7800000000002, "text": " To explain the birth of that heartbeat, the book reveals a massive historical and mathematical convergence between two wildly different fields.", "tokens": [50802, 1407, 2903, 264, 3965, 295, 300, 34851, 11, 264, 1446, 20893, 257, 5994, 8584, 293, 18894, 32181, 1296, 732, 34731, 819, 7909, 13, 51172], "temperature": 0.0, "avg_logprob": -0.1368624044924366, "compression_ratio": 1.604026845637584, "no_speech_prob": 2.0929232739247405e-12}, {"id": 434, "seek": 176764, "start": 1784.0, "end": 1784.5600000000002, "text": " Through what fields?", "tokens": [51183, 8927, 437, 7909, 30, 51211], "temperature": 0.0, "avg_logprob": -0.1368624044924366, "compression_ratio": 1.604026845637584, "no_speech_prob": 2.0929232739247405e-12}, {"id": 435, "seek": 176764, "start": 1784.96, "end": 1789.0200000000002, "text": " In electrical engineering, there is a fundamental rule called the Barkhausen Criterion.", "tokens": [51231, 682, 12147, 7043, 11, 456, 307, 257, 8088, 4978, 1219, 264, 36275, 23321, 268, 4779, 1681, 313, 13, 51434], "temperature": 0.0, "avg_logprob": -0.1368624044924366, "compression_ratio": 1.604026845637584, "no_speech_prob": 2.0929232739247405e-12}, {"id": 436, "seek": 176764, "start": 1789.42, "end": 1794.38, "text": " It dictates the exact conditions under which an electronic circuit will begin to oscillate.", "tokens": [51454, 467, 12569, 1024, 264, 1900, 4487, 833, 597, 364, 10092, 9048, 486, 1841, 281, 18225, 473, 13, 51702], "temperature": 0.0, "avg_logprob": -0.1368624044924366, "compression_ratio": 1.604026845637584, "no_speech_prob": 2.0929232739247405e-12}, {"id": 437, "seek": 179438, "start": 1794.38, "end": 1801.5200000000002, "text": " Basically, the total gain around the loop has to be exactly one, and the total phase shift has to be exactly zero degrees.", "tokens": [50365, 8537, 11, 264, 3217, 6052, 926, 264, 6367, 575, 281, 312, 2293, 472, 11, 293, 264, 3217, 5574, 5513, 575, 281, 312, 2293, 4018, 5310, 13, 50722], "temperature": 0.0, "avg_logprob": -0.1328194106834522, "compression_ratio": 1.5675675675675675, "no_speech_prob": 1.7970235759515174e-12}, {"id": 438, "seek": 179438, "start": 1801.7, "end": 1811.18, "text": " So the Amplet Whist has to perfectly, flawlessly regenerate its own shape without growing larger, shrinking smaller, or twisting in time.", "tokens": [50731, 407, 264, 2012, 14657, 506, 468, 575, 281, 6239, 11, 13717, 12048, 26358, 473, 1080, 1065, 3909, 1553, 4194, 4833, 11, 41684, 4356, 11, 420, 34491, 294, 565, 13, 51205], "temperature": 0.0, "avg_logprob": -0.1328194106834522, "compression_ratio": 1.5675675675675675, "no_speech_prob": 1.7970235759515174e-12}, {"id": 439, "seek": 179438, "start": 1811.68, "end": 1812.9, "text": " That is the engineering view.", "tokens": [51230, 663, 307, 264, 7043, 1910, 13, 51291], "temperature": 0.0, "avg_logprob": -0.1328194106834522, "compression_ratio": 1.5675675675675675, "no_speech_prob": 1.7970235759515174e-12}, {"id": 440, "seek": 181290, "start": 1812.9, "end": 1827.64, "text": " But in the advanced mathematics of nonlinear dynamics, which biologists and chaoticists use to study organic phenomena like animal gates, predator-prey cycles, or the beating of pacemaker cells in a heart, there is a concept called a Hoff bifurcation.", "tokens": [50365, 583, 294, 264, 7339, 18666, 295, 2107, 28263, 15679, 11, 597, 3228, 12256, 293, 27013, 1751, 764, 281, 2979, 10220, 22004, 411, 5496, 19792, 11, 35377, 12, 3712, 88, 17796, 11, 420, 264, 13497, 295, 15165, 49523, 5438, 294, 257, 1917, 11, 456, 307, 257, 3410, 1219, 257, 29135, 272, 351, 374, 46252, 13, 51102], "temperature": 0.0, "avg_logprob": -0.09579433781085628, "compression_ratio": 1.605263157894737, "no_speech_prob": 1.8906360851889126e-12}, {"id": 441, "seek": 181290, "start": 1827.76, "end": 1829.0, "text": " A Hoff bifurcation.", "tokens": [51108, 316, 29135, 272, 351, 374, 46252, 13, 51170], "temperature": 0.0, "avg_logprob": -0.09579433781085628, "compression_ratio": 1.605263157894737, "no_speech_prob": 1.8906360851889126e-12}, {"id": 442, "seek": 181290, "start": 1829.1000000000001, "end": 1829.42, "text": " Yes.", "tokens": [51175, 1079, 13, 51191], "temperature": 0.0, "avg_logprob": -0.09579433781085628, "compression_ratio": 1.605263157894737, "no_speech_prob": 1.8906360851889126e-12}, {"id": 443, "seek": 181290, "start": 1829.72, "end": 1839.14, "text": " It describes the exact mathematical moment a stable, dead system loses its stability and spontaneously bursts a rhythmic, self-sustaining limit cycle.", "tokens": [51206, 467, 15626, 264, 1900, 18894, 1623, 257, 8351, 11, 3116, 1185, 18293, 1080, 11826, 293, 47632, 41663, 257, 46967, 11, 2698, 12, 82, 381, 3686, 4948, 6586, 13, 51677], "temperature": 0.0, "avg_logprob": -0.09579433781085628, "compression_ratio": 1.605263157894737, "no_speech_prob": 1.8906360851889126e-12}, {"id": 444, "seek": 183914, "start": 1839.14, "end": 1845.1200000000001, "text": " And Flickson points out that these two concepts, discovered by different people in different fields, are describing the exact same thing.", "tokens": [50365, 400, 3235, 618, 3015, 2793, 484, 300, 613, 732, 10392, 11, 6941, 538, 819, 561, 294, 819, 7909, 11, 366, 16141, 264, 1900, 912, 551, 13, 50664], "temperature": 0.0, "avg_logprob": -0.07901780198260051, "compression_ratio": 1.6285714285714286, "no_speech_prob": 2.020622601531241e-12}, {"id": 445, "seek": 183914, "start": 1845.3200000000002, "end": 1848.0, "text": " They are the identical linear algebraic event.", "tokens": [50674, 814, 366, 264, 14800, 8213, 21989, 299, 2280, 13, 50808], "temperature": 0.0, "avg_logprob": -0.07901780198260051, "compression_ratio": 1.6285714285714286, "no_speech_prob": 2.020622601531241e-12}, {"id": 446, "seek": 183914, "start": 1848.42, "end": 1861.1200000000001, "text": " The Barkhausen Criterion governing a radio transmitter and the Hoff bifurcation governing a biological heartbeat are structurally identical descriptions of the transition from a dead equilibrium to a living rhythm.", "tokens": [50829, 440, 36275, 23321, 268, 4779, 1681, 313, 30054, 257, 6477, 40121, 293, 264, 29135, 272, 351, 374, 46252, 30054, 257, 13910, 34851, 366, 6594, 6512, 14800, 24406, 295, 264, 6034, 490, 257, 3116, 15625, 281, 257, 2647, 11801, 13, 51464], "temperature": 0.0, "avg_logprob": -0.07901780198260051, "compression_ratio": 1.6285714285714286, "no_speech_prob": 2.020622601531241e-12}, {"id": 447, "seek": 186112, "start": 1861.12, "end": 1870.8999999999999, "text": " Wait, my engineering textbook from college says that the Barkhausen Criterion gain equals one, phase equals zero, is the sufficient condition for an oscillator to start.", "tokens": [50365, 3802, 11, 452, 7043, 25591, 490, 3859, 1619, 300, 264, 36275, 23321, 268, 4779, 1681, 313, 6052, 6915, 472, 11, 5574, 6915, 4018, 11, 307, 264, 11563, 4188, 337, 364, 43859, 281, 722, 13, 50854], "temperature": 0.0, "avg_logprob": -0.09869520568847656, "compression_ratio": 1.7119205298013245, "no_speech_prob": 1.7414776218305228e-12}, {"id": 448, "seek": 186112, "start": 1871.1599999999999, "end": 1873.7399999999998, "text": " You build a circuit, you match the math, and it oscillates.", "tokens": [50867, 509, 1322, 257, 9048, 11, 291, 2995, 264, 5221, 11, 293, 309, 18225, 1024, 13, 50996], "temperature": 0.0, "avg_logprob": -0.09869520568847656, "compression_ratio": 1.7119205298013245, "no_speech_prob": 1.7414776218305228e-12}, {"id": 449, "seek": 186112, "start": 1873.8799999999999, "end": 1874.1799999999998, "text": " Right.", "tokens": [51003, 1779, 13, 51018], "temperature": 0.0, "avg_logprob": -0.09869520568847656, "compression_ratio": 1.7119205298013245, "no_speech_prob": 1.7414776218305228e-12}, {"id": 450, "seek": 186112, "start": 1874.32, "end": 1876.4399999999998, "text": " But Flitching claims that is a fundamental myth.", "tokens": [51025, 583, 3235, 1549, 278, 9441, 300, 307, 257, 8088, 9474, 13, 51131], "temperature": 0.0, "avg_logprob": -0.09869520568847656, "compression_ratio": 1.7119205298013245, "no_speech_prob": 1.7414776218305228e-12}, {"id": 451, "seek": 186112, "start": 1876.52, "end": 1880.8799999999999, "text": " This is a crucial, deeply physical correction the book makes to standard pedagogy.", "tokens": [51135, 639, 307, 257, 11462, 11, 8760, 4001, 19984, 264, 1446, 1669, 281, 3832, 5670, 559, 7794, 13, 51353], "temperature": 0.0, "avg_logprob": -0.09869520568847656, "compression_ratio": 1.7119205298013245, "no_speech_prob": 1.7414776218305228e-12}, {"id": 452, "seek": 186112, "start": 1881.4399999999998, "end": 1885.56, "text": " The Barkhausen Criterion only describes the steady state marginal condition.", "tokens": [51381, 440, 36275, 23321, 268, 4779, 1681, 313, 787, 15626, 264, 13211, 1785, 16885, 4188, 13, 51587], "temperature": 0.0, "avg_logprob": -0.09869520568847656, "compression_ratio": 1.7119205298013245, "no_speech_prob": 1.7414776218305228e-12}, {"id": 453, "seek": 186112, "start": 1886.02, "end": 1889.02, "text": " It describes the oscillator once it is already perfectly running.", "tokens": [51610, 467, 15626, 264, 43859, 1564, 309, 307, 1217, 6239, 2614, 13, 51760], "temperature": 0.0, "avg_logprob": -0.09869520568847656, "compression_ratio": 1.7119205298013245, "no_speech_prob": 1.7414776218305228e-12}, {"id": 454, "seek": 186112, "start": 1889.2399999999998, "end": 1889.4799999999998, "text": " Okay.", "tokens": [51771, 1033, 13, 51783], "temperature": 0.0, "avg_logprob": -0.09869520568847656, "compression_ratio": 1.7119205298013245, "no_speech_prob": 1.7414776218305228e-12}, {"id": 455, "seek": 188948, "start": 1889.48, "end": 1890.6, "text": " Think about it physically.", "tokens": [50365, 6557, 466, 309, 9762, 13, 50421], "temperature": 0.0, "avg_logprob": -0.1851212413040633, "compression_ratio": 1.6131687242798354, "no_speech_prob": 1.7622726194987948e-12}, {"id": 456, "seek": 188948, "start": 1891.0, "end": 1902.64, "text": " If you build a circuit with a loop gain of exactly 1.000 and it is sitting there perfectly quiet with zero volts, it has absolutely no mathematical or physical reason to start oscillating.", "tokens": [50441, 759, 291, 1322, 257, 9048, 365, 257, 6367, 6052, 295, 2293, 502, 13, 1360, 293, 309, 307, 3798, 456, 6239, 5677, 365, 4018, 22322, 11, 309, 575, 3122, 572, 18894, 420, 4001, 1778, 281, 722, 18225, 990, 13, 51023], "temperature": 0.0, "avg_logprob": -0.1851212413040633, "compression_ratio": 1.6131687242798354, "no_speech_prob": 1.7622726194987948e-12}, {"id": 457, "seek": 188948, "start": 1903.06, "end": 1905.02, "text": " One times zero is still zero.", "tokens": [51044, 1485, 1413, 4018, 307, 920, 4018, 13, 51142], "temperature": 0.0, "avg_logprob": -0.1851212413040633, "compression_ratio": 1.6131687242798354, "no_speech_prob": 1.7622726194987948e-12}, {"id": 458, "seek": 188948, "start": 1905.52, "end": 1907.58, "text": " It is perfectly precariously balanced.", "tokens": [51167, 467, 307, 6239, 4346, 289, 8994, 13902, 13, 51270], "temperature": 0.0, "avg_logprob": -0.1851212413040633, "compression_ratio": 1.6131687242798354, "no_speech_prob": 1.7622726194987948e-12}, {"id": 459, "seek": 188948, "start": 1907.66, "end": 1910.42, "text": " It's like a pencil perfectly balanced on its sharpened tip.", "tokens": [51274, 467, 311, 411, 257, 10985, 6239, 13902, 322, 1080, 31570, 292, 4125, 13, 51412], "temperature": 0.0, "avg_logprob": -0.1851212413040633, "compression_ratio": 1.6131687242798354, "no_speech_prob": 1.7622726194987948e-12}, {"id": 460, "seek": 188948, "start": 1910.7, "end": 1912.26, "text": " It could stay there forever in theory.", "tokens": [51426, 467, 727, 1754, 456, 5680, 294, 5261, 13, 51504], "temperature": 0.0, "avg_logprob": -0.1851212413040633, "compression_ratio": 1.6131687242798354, "no_speech_prob": 1.7622726194987948e-12}, {"id": 461, "seek": 188948, "start": 1912.66, "end": 1913.18, "text": " Exactly.", "tokens": [51524, 7587, 13, 51550], "temperature": 0.0, "avg_logprob": -0.1851212413040633, "compression_ratio": 1.6131687242798354, "no_speech_prob": 1.7622726194987948e-12}, {"id": 462, "seek": 191318, "start": 1913.18, "end": 1917.3600000000001, "text": " To actually start up from nothing, to wake up from the dead silence.", "tokens": [50365, 1407, 767, 722, 493, 490, 1825, 11, 281, 6634, 493, 490, 264, 3116, 12239, 13, 50574], "temperature": 0.0, "avg_logprob": -0.18311436422939958, "compression_ratio": 1.5, "no_speech_prob": 1.7414770797294366e-12}, {"id": 463, "seek": 191318, "start": 1917.8, "end": 1920.9, "text": " The loop initially requires a gain slightly greater than one.", "tokens": [50596, 440, 6367, 9105, 7029, 257, 6052, 4748, 5044, 813, 472, 13, 50751], "temperature": 0.0, "avg_logprob": -0.18311436422939958, "compression_ratio": 1.5, "no_speech_prob": 1.7414770797294366e-12}, {"id": 464, "seek": 191318, "start": 1921.3200000000002, "end": 1924.5600000000002, "text": " It requires what engineers call small signal instability.", "tokens": [50772, 467, 7029, 437, 11955, 818, 1359, 6358, 34379, 13, 50934], "temperature": 0.0, "avg_logprob": -0.18311436422939958, "compression_ratio": 1.5, "no_speech_prob": 1.7414770797294366e-12}, {"id": 465, "seek": 191318, "start": 1924.9, "end": 1927.02, "text": " So it has to be a little bit unstable to get going.", "tokens": [50951, 407, 309, 575, 281, 312, 257, 707, 857, 23742, 281, 483, 516, 13, 51057], "temperature": 0.0, "avg_logprob": -0.18311436422939958, "compression_ratio": 1.5, "no_speech_prob": 1.7414770797294366e-12}, {"id": 466, "seek": 192702, "start": 1927.02, "end": 1932.92, "text": " The microscopic, random thermal noise inherent in the circuit is caught by the loop and amplified.", "tokens": [50365, 440, 47897, 11, 4974, 15070, 5658, 26387, 294, 264, 9048, 307, 5415, 538, 264, 6367, 293, 49237, 13, 50660], "temperature": 0.0, "avg_logprob": -0.15284134025004373, "compression_ratio": 1.5392670157068062, "no_speech_prob": 2.0044196337443143e-12}, {"id": 467, "seek": 192702, "start": 1933.56, "end": 1936.6399999999999, "text": " The wave grows and grows, compounding on itself.", "tokens": [50692, 440, 5772, 13156, 293, 13156, 11, 14154, 278, 322, 2564, 13, 50846], "temperature": 0.0, "avg_logprob": -0.15284134025004373, "compression_ratio": 1.5392670157068062, "no_speech_prob": 2.0044196337443143e-12}, {"id": 468, "seek": 192702, "start": 1937.12, "end": 1938.16, "text": " But here is the problem.", "tokens": [50870, 583, 510, 307, 264, 1154, 13, 50922], "temperature": 0.0, "avg_logprob": -0.15284134025004373, "compression_ratio": 1.5392670157068062, "no_speech_prob": 2.0044196337443143e-12}, {"id": 469, "seek": 192702, "start": 1938.36, "end": 1945.56, "text": " If the gain stays above one forever, the wave would grow exponentially until the transistor exploded or the wires melted.", "tokens": [50932, 759, 264, 6052, 10834, 3673, 472, 5680, 11, 264, 5772, 576, 1852, 37330, 1826, 264, 34750, 27049, 420, 264, 15537, 19057, 13, 51292], "temperature": 0.0, "avg_logprob": -0.15284134025004373, "compression_ratio": 1.5392670157068062, "no_speech_prob": 2.0044196337443143e-12}, {"id": 470, "seek": 194556, "start": 1945.56, "end": 1949.62, "text": " So the circuit needs a way to pull itself back from the brink of destruction.", "tokens": [50365, 407, 264, 9048, 2203, 257, 636, 281, 2235, 2564, 646, 490, 264, 738, 475, 295, 13563, 13, 50568], "temperature": 0.0, "avg_logprob": -0.14721531186785017, "compression_ratio": 1.4948453608247423, "no_speech_prob": 1.7893579413313931e-12}, {"id": 471, "seek": 194556, "start": 1950.1799999999998, "end": 1952.8999999999999, "text": " It requires an amplitude-dependent non-linearity.", "tokens": [50596, 467, 7029, 364, 27433, 12, 36763, 317, 2107, 12, 1889, 17409, 13, 50732], "temperature": 0.0, "avg_logprob": -0.14721531186785017, "compression_ratio": 1.4948453608247423, "no_speech_prob": 1.7893579413313931e-12}, {"id": 472, "seek": 194556, "start": 1953.48, "end": 1960.3999999999999, "text": " As the physical voltage wave gets huge, the transistor or the amplifier literally starts running out of available power from the battery.", "tokens": [50761, 1018, 264, 4001, 8352, 5772, 2170, 2603, 11, 264, 34750, 420, 264, 27439, 3736, 3719, 2614, 484, 295, 2435, 1347, 490, 264, 5809, 13, 51107], "temperature": 0.0, "avg_logprob": -0.14721531186785017, "compression_ratio": 1.4948453608247423, "no_speech_prob": 1.7893579413313931e-12}, {"id": 473, "seek": 194556, "start": 1960.94, "end": 1961.8999999999999, "text": " It runs out of headroom.", "tokens": [51134, 467, 6676, 484, 295, 1378, 2861, 13, 51182], "temperature": 0.0, "avg_logprob": -0.14721531186785017, "compression_ratio": 1.4948453608247423, "no_speech_prob": 1.7893579413313931e-12}, {"id": 474, "seek": 196190, "start": 1961.9, "end": 1963.44, "text": " Right. It hits a physical ceiling.", "tokens": [50365, 1779, 13, 467, 8664, 257, 4001, 13655, 13, 50442], "temperature": 0.0, "avg_logprob": -0.1757380281175886, "compression_ratio": 1.718978102189781, "no_speech_prob": 2.389568577731982e-12}, {"id": 475, "seek": 196190, "start": 1963.8200000000002, "end": 1966.3600000000001, "text": " The physical physics of the silicon compress the signal.", "tokens": [50461, 440, 4001, 10649, 295, 264, 22848, 14778, 264, 6358, 13, 50588], "temperature": 0.0, "avg_logprob": -0.1757380281175886, "compression_ratio": 1.718978102189781, "no_speech_prob": 2.389568577731982e-12}, {"id": 476, "seek": 196190, "start": 1966.6000000000001, "end": 1969.22, "text": " The gain is naturally squished down by reality.", "tokens": [50600, 440, 6052, 307, 8195, 2339, 4729, 760, 538, 4103, 13, 50731], "temperature": 0.0, "avg_logprob": -0.1757380281175886, "compression_ratio": 1.718978102189781, "no_speech_prob": 2.389568577731982e-12}, {"id": 477, "seek": 196190, "start": 1969.66, "end": 1976.9, "text": " And the wave stops growing at the exact, precise amplitude where that compressed, squished gain finally equals exactly one.", "tokens": [50753, 400, 264, 5772, 10094, 4194, 412, 264, 1900, 11, 13600, 27433, 689, 300, 30353, 11, 2339, 4729, 6052, 2721, 6915, 2293, 472, 13, 51115], "temperature": 0.0, "avg_logprob": -0.1757380281175886, "compression_ratio": 1.718978102189781, "no_speech_prob": 2.389568577731982e-12}, {"id": 478, "seek": 196190, "start": 1977.0800000000002, "end": 1981.16, "text": " So the oscillator actively hunts for its own Barkelsen criterion.", "tokens": [51124, 407, 264, 43859, 13022, 7396, 1373, 337, 1080, 1065, 4156, 7124, 6748, 46691, 13, 51328], "temperature": 0.0, "avg_logprob": -0.1757380281175886, "compression_ratio": 1.718978102189781, "no_speech_prob": 2.389568577731982e-12}, {"id": 479, "seek": 196190, "start": 1981.72, "end": 1983.4, "text": " It overshoots into instability.", "tokens": [51356, 467, 15488, 1289, 1971, 666, 34379, 13, 51440], "temperature": 0.0, "avg_logprob": -0.1757380281175886, "compression_ratio": 1.718978102189781, "no_speech_prob": 2.389568577731982e-12}, {"id": 480, "seek": 196190, "start": 1983.98, "end": 1986.66, "text": " The physical limits of the universe squash it back down.", "tokens": [51469, 440, 4001, 10406, 295, 264, 6445, 30725, 309, 646, 760, 13, 51603], "temperature": 0.0, "avg_logprob": -0.1757380281175886, "compression_ratio": 1.718978102189781, "no_speech_prob": 2.389568577731982e-12}, {"id": 481, "seek": 196190, "start": 1986.8200000000002, "end": 1990.0400000000002, "text": " And it settles into the perfect, sustainable rhythm.", "tokens": [51611, 400, 309, 5584, 904, 666, 264, 2176, 11, 11235, 11801, 13, 51772], "temperature": 0.0, "avg_logprob": -0.1757380281175886, "compression_ratio": 1.718978102189781, "no_speech_prob": 2.389568577731982e-12}, {"id": 482, "seek": 199004, "start": 1990.04, "end": 1994.86, "text": " It is actively maintaining its own existence through constant micro-adjustments.", "tokens": [50365, 467, 307, 13022, 14916, 1080, 1065, 9123, 807, 5754, 4532, 12, 345, 3424, 1117, 13, 50606], "temperature": 0.0, "avg_logprob": -0.14065017356528892, "compression_ratio": 1.6812080536912752, "no_speech_prob": 2.399284763920928e-12}, {"id": 483, "seek": 199004, "start": 1995.0, "end": 1997.46, "text": " It is continuous, recursive continuation.", "tokens": [50613, 467, 307, 10957, 11, 20560, 488, 29357, 13, 50736], "temperature": 0.0, "avg_logprob": -0.14065017356528892, "compression_ratio": 1.6812080536912752, "no_speech_prob": 2.399284763920928e-12}, {"id": 484, "seek": 199004, "start": 1998.08, "end": 2000.48, "text": " The geometry is actively fighting to survive.", "tokens": [50767, 440, 18426, 307, 13022, 5237, 281, 7867, 13, 50887], "temperature": 0.0, "avg_logprob": -0.14065017356528892, "compression_ratio": 1.6812080536912752, "no_speech_prob": 2.399284763920928e-12}, {"id": 485, "seek": 199004, "start": 2000.6599999999999, "end": 2006.6, "text": " And it gets even more conceptually fascinating when you take two of these independent oscillators and place them next to each other.", "tokens": [50896, 400, 309, 2170, 754, 544, 3410, 671, 10343, 562, 291, 747, 732, 295, 613, 6695, 18225, 3391, 293, 1081, 552, 958, 281, 1184, 661, 13, 51193], "temperature": 0.0, "avg_logprob": -0.14065017356528892, "compression_ratio": 1.6812080536912752, "no_speech_prob": 2.399284763920928e-12}, {"id": 486, "seek": 199004, "start": 2007.2, "end": 2009.56, "text": " Synchronization. This is where it gets into flocking behavior.", "tokens": [51223, 26155, 14613, 2144, 13, 639, 307, 689, 309, 2170, 666, 2591, 25723, 5223, 13, 51341], "temperature": 0.0, "avg_logprob": -0.14065017356528892, "compression_ratio": 1.6812080536912752, "no_speech_prob": 2.399284763920928e-12}, {"id": 487, "seek": 199004, "start": 2009.82, "end": 2012.08, "text": " Yes. The phenomenon of injection locking.", "tokens": [51354, 1079, 13, 440, 14029, 295, 22873, 23954, 13, 51467], "temperature": 0.0, "avg_logprob": -0.14065017356528892, "compression_ratio": 1.6812080536912752, "no_speech_prob": 2.399284763920928e-12}, {"id": 488, "seek": 199004, "start": 2012.8799999999999, "end": 2018.42, "text": " If you have a free-running electronic oscillator happily beating at its own natural frequency,", "tokens": [51507, 759, 291, 362, 257, 1737, 12, 45482, 10092, 43859, 19909, 13497, 412, 1080, 1065, 3303, 7893, 11, 51784], "temperature": 0.0, "avg_logprob": -0.14065017356528892, "compression_ratio": 1.6812080536912752, "no_speech_prob": 2.399284763920928e-12}, {"id": 489, "seek": 201842, "start": 2018.42, "end": 2024.1200000000001, "text": " and you suddenly inject a strong external signal at a slightly different frequency into its loop,", "tokens": [50365, 293, 291, 5800, 10711, 257, 2068, 8320, 6358, 412, 257, 4748, 819, 7893, 666, 1080, 6367, 11, 50650], "temperature": 0.0, "avg_logprob": -0.1799086087370572, "compression_ratio": 1.553921568627451, "no_speech_prob": 2.108822881943806e-12}, {"id": 490, "seek": 201842, "start": 2024.5600000000002, "end": 2027.54, "text": " the oscillator will actually abandon its own natural rhythm.", "tokens": [50672, 264, 43859, 486, 767, 9072, 1080, 1065, 3303, 11801, 13, 50821], "temperature": 0.0, "avg_logprob": -0.1799086087370572, "compression_ratio": 1.553921568627451, "no_speech_prob": 2.108822881943806e-12}, {"id": 491, "seek": 201842, "start": 2027.66, "end": 2028.02, "text": " Really?", "tokens": [50827, 4083, 30, 50845], "temperature": 0.0, "avg_logprob": -0.1799086087370572, "compression_ratio": 1.553921568627451, "no_speech_prob": 2.108822881943806e-12}, {"id": 492, "seek": 201842, "start": 2028.0800000000002, "end": 2031.98, "text": " It will physically bend its own phase to lock onto the injected signal.", "tokens": [50848, 467, 486, 9762, 11229, 1080, 1065, 5574, 281, 4017, 3911, 264, 36967, 6358, 13, 51043], "temperature": 0.0, "avg_logprob": -0.1799086087370572, "compression_ratio": 1.553921568627451, "no_speech_prob": 2.108822881943806e-12}, {"id": 493, "seek": 201842, "start": 2031.98, "end": 2036.3400000000001, "text": " It's like a drummer playing their own beat, suddenly hearing a loud metronome,", "tokens": [51043, 467, 311, 411, 257, 38535, 2433, 641, 1065, 4224, 11, 5800, 4763, 257, 6588, 1131, 2044, 423, 11, 51261], "temperature": 0.0, "avg_logprob": -0.1799086087370572, "compression_ratio": 1.553921568627451, "no_speech_prob": 2.108822881943806e-12}, {"id": 494, "seek": 203634, "start": 2036.34, "end": 2040.6599999999999, "text": " and unconsciously shifting their hands to match the external beat.", "tokens": [50365, 293, 18900, 356, 17573, 641, 2377, 281, 2995, 264, 8320, 4224, 13, 50581], "temperature": 0.0, "avg_logprob": -0.1877443790435791, "compression_ratio": 1.4583333333333333, "no_speech_prob": 1.87524193222266e-12}, {"id": 495, "seek": 203634, "start": 2040.6599999999999, "end": 2042.32, "text": " That is the perfect analogy.", "tokens": [50581, 663, 307, 264, 2176, 21663, 13, 50664], "temperature": 0.0, "avg_logprob": -0.1877443790435791, "compression_ratio": 1.4583333333333333, "no_speech_prob": 1.87524193222266e-12}, {"id": 496, "seek": 203634, "start": 2042.8, "end": 2045.8999999999999, "text": " And the differential mathematics that govern how a circuit does this", "tokens": [50688, 400, 264, 15756, 18666, 300, 1980, 577, 257, 9048, 775, 341, 50843], "temperature": 0.0, "avg_logprob": -0.1877443790435791, "compression_ratio": 1.4583333333333333, "no_speech_prob": 1.87524193222266e-12}, {"id": 497, "seek": 203634, "start": 2045.8999999999999, "end": 2049.92, "text": " were derived back in 1946 by a researcher named Robert Adler.", "tokens": [50843, 645, 18949, 646, 294, 46062, 538, 257, 21751, 4926, 7977, 1999, 1918, 13, 51044], "temperature": 0.0, "avg_logprob": -0.1877443790435791, "compression_ratio": 1.4583333333333333, "no_speech_prob": 1.87524193222266e-12}, {"id": 498, "seek": 203634, "start": 2050.3199999999997, "end": 2053.6, "text": " It is famously known in engineering as Adler's equation.", "tokens": [51064, 467, 307, 34360, 2570, 294, 7043, 382, 1999, 1918, 311, 5367, 13, 51228], "temperature": 0.0, "avg_logprob": -0.1877443790435791, "compression_ratio": 1.4583333333333333, "no_speech_prob": 1.87524193222266e-12}, {"id": 499, "seek": 203634, "start": 2054.12, "end": 2057.18, "text": " But Flixion pulls off another massive historical convergence here.", "tokens": [51254, 583, 3235, 970, 313, 16982, 766, 1071, 5994, 8584, 32181, 510, 13, 51407], "temperature": 0.0, "avg_logprob": -0.1877443790435791, "compression_ratio": 1.4583333333333333, "no_speech_prob": 1.87524193222266e-12}, {"id": 500, "seek": 205718, "start": 2057.18, "end": 2058.8999999999996, "text": " Yes. A truly stunning one.", "tokens": [50365, 1079, 13, 316, 4908, 18550, 472, 13, 50451], "temperature": 0.0, "avg_logprob": -0.16249163432787822, "compression_ratio": 1.5348837209302326, "no_speech_prob": 1.943045550845124e-12}, {"id": 501, "seek": 205718, "start": 2059.6, "end": 2063.58, "text": " In 1975, nearly 30 years after Adler was studying radio tubes,", "tokens": [50486, 682, 32454, 11, 6217, 2217, 924, 934, 1999, 1918, 390, 7601, 6477, 21458, 11, 50685], "temperature": 0.0, "avg_logprob": -0.16249163432787822, "compression_ratio": 1.5348837209302326, "no_speech_prob": 1.943045550845124e-12}, {"id": 502, "seek": 205718, "start": 2064.12, "end": 2069.04, "text": " a physicist named Yoshiki Kuramoto developed a purely mathematical model", "tokens": [50712, 257, 42466, 4926, 38949, 9850, 16481, 35858, 4743, 257, 17491, 18894, 2316, 50958], "temperature": 0.0, "avg_logprob": -0.16249163432787822, "compression_ratio": 1.5348837209302326, "no_speech_prob": 1.943045550845124e-12}, {"id": 503, "seek": 205718, "start": 2069.04, "end": 2073.4199999999996, "text": " to explain how populations of biological oscillators synchronize.", "tokens": [50958, 281, 2903, 577, 12822, 295, 13910, 18225, 3391, 19331, 1125, 13, 51177], "temperature": 0.0, "avg_logprob": -0.16249163432787822, "compression_ratio": 1.5348837209302326, "no_speech_prob": 1.943045550845124e-12}, {"id": 504, "seek": 205718, "start": 2073.74, "end": 2075.3199999999997, "text": " What kind of biological oscillators?", "tokens": [51193, 708, 733, 295, 13910, 18225, 3391, 30, 51272], "temperature": 0.0, "avg_logprob": -0.16249163432787822, "compression_ratio": 1.5348837209302326, "no_speech_prob": 1.943045550845124e-12}, {"id": 505, "seek": 205718, "start": 2075.3199999999997, "end": 2079.06, "text": " He was trying to figure out how thousands of fireflies in a dark forest", "tokens": [51272, 634, 390, 1382, 281, 2573, 484, 577, 5383, 295, 2610, 24471, 294, 257, 2877, 6719, 51459], "temperature": 0.0, "avg_logprob": -0.16249163432787822, "compression_ratio": 1.5348837209302326, "no_speech_prob": 1.943045550845124e-12}, {"id": 506, "seek": 205718, "start": 2079.06, "end": 2082.44, "text": " managed to suddenly flash in perfect, simultaneous unison,", "tokens": [51459, 6453, 281, 5800, 7319, 294, 2176, 11, 46218, 517, 2770, 11, 51628], "temperature": 0.0, "avg_logprob": -0.16249163432787822, "compression_ratio": 1.5348837209302326, "no_speech_prob": 1.943045550845124e-12}, {"id": 507, "seek": 208244, "start": 2082.44, "end": 2086.32, "text": " or how thousands of distinct pacemaker cells in the human heart", "tokens": [50365, 420, 577, 5383, 295, 10644, 15165, 49523, 5438, 294, 264, 1952, 1917, 50559], "temperature": 0.0, "avg_logprob": -0.13799025648731297, "compression_ratio": 1.7391304347826086, "no_speech_prob": 1.839819963045386e-12}, {"id": 508, "seek": 208244, "start": 2086.32, "end": 2088.1, "text": " aligned to create a single beat.", "tokens": [50559, 17962, 281, 1884, 257, 2167, 4224, 13, 50648], "temperature": 0.0, "avg_logprob": -0.13799025648731297, "compression_ratio": 1.7391304347826086, "no_speech_prob": 1.839819963045386e-12}, {"id": 509, "seek": 208244, "start": 2088.18, "end": 2089.08, "text": " The Kuramoto model.", "tokens": [50652, 440, 16481, 35858, 2316, 13, 50697], "temperature": 0.0, "avg_logprob": -0.13799025648731297, "compression_ratio": 1.7391304347826086, "no_speech_prob": 1.839819963045386e-12}, {"id": 510, "seek": 208244, "start": 2089.14, "end": 2090.16, "text": " The Kuramoto model.", "tokens": [50700, 440, 16481, 35858, 2316, 13, 50751], "temperature": 0.0, "avg_logprob": -0.13799025648731297, "compression_ratio": 1.7391304347826086, "no_speech_prob": 1.839819963045386e-12}, {"id": 511, "seek": 208244, "start": 2090.62, "end": 2092.88, "text": " And Flixion lays the equation side by side", "tokens": [50774, 400, 3235, 970, 313, 32714, 264, 5367, 1252, 538, 1252, 50887], "temperature": 0.0, "avg_logprob": -0.13799025648731297, "compression_ratio": 1.7391304347826086, "no_speech_prob": 1.839819963045386e-12}, {"id": 512, "seek": 208244, "start": 2092.88, "end": 2095.52, "text": " and shows that Adler's equation for a copper radio circuit", "tokens": [50887, 293, 3110, 300, 1999, 1918, 311, 5367, 337, 257, 15007, 6477, 9048, 51019], "temperature": 0.0, "avg_logprob": -0.13799025648731297, "compression_ratio": 1.7391304347826086, "no_speech_prob": 1.839819963045386e-12}, {"id": 513, "seek": 208244, "start": 2095.52, "end": 2097.82, "text": " and the Kuramoto model for biological fireflies", "tokens": [51019, 293, 264, 16481, 35858, 2316, 337, 13910, 2610, 24471, 51134], "temperature": 0.0, "avg_logprob": -0.13799025648731297, "compression_ratio": 1.7391304347826086, "no_speech_prob": 1.839819963045386e-12}, {"id": 514, "seek": 208244, "start": 2097.82, "end": 2101.56, "text": " are, structurally, the exact same differential equation.", "tokens": [51134, 366, 11, 6594, 6512, 11, 264, 1900, 912, 15756, 5367, 13, 51321], "temperature": 0.0, "avg_logprob": -0.13799025648731297, "compression_ratio": 1.7391304347826086, "no_speech_prob": 1.839819963045386e-12}, {"id": 515, "seek": 208244, "start": 2101.62, "end": 2102.56, "text": " That is incredible.", "tokens": [51324, 663, 307, 4651, 13, 51371], "temperature": 0.0, "avg_logprob": -0.13799025648731297, "compression_ratio": 1.7391304347826086, "no_speech_prob": 1.839819963045386e-12}, {"id": 516, "seek": 208244, "start": 2102.86, "end": 2106.06, "text": " Decades apart, studying completely different physical substrates,", "tokens": [51386, 12427, 2977, 4936, 11, 7601, 2584, 819, 4001, 4594, 12507, 11, 51546], "temperature": 0.0, "avg_logprob": -0.13799025648731297, "compression_ratio": 1.7391304347826086, "no_speech_prob": 1.839819963045386e-12}, {"id": 517, "seek": 208244, "start": 2106.64, "end": 2109.56, "text": " one metal, one biological engineers and physicists", "tokens": [51575, 472, 5760, 11, 472, 13910, 11955, 293, 48716, 51721], "temperature": 0.0, "avg_logprob": -0.13799025648731297, "compression_ratio": 1.7391304347826086, "no_speech_prob": 1.839819963045386e-12}, {"id": 518, "seek": 210956, "start": 2109.56, "end": 2113.16, "text": " converged on the identical underlying mathematics of phase coupling.", "tokens": [50365, 9652, 3004, 322, 264, 14800, 14217, 18666, 295, 5574, 37447, 13, 50545], "temperature": 0.0, "avg_logprob": -0.18884333168588033, "compression_ratio": 1.611842105263158, "no_speech_prob": 2.219212877699328e-12}, {"id": 519, "seek": 210956, "start": 2113.82, "end": 2117.04, "text": " It just proves that this geometry of continuation,", "tokens": [50578, 467, 445, 25019, 300, 341, 18426, 295, 29357, 11, 50739], "temperature": 0.0, "avg_logprob": -0.18884333168588033, "compression_ratio": 1.611842105263158, "no_speech_prob": 2.219212877699328e-12}, {"id": 520, "seek": 210956, "start": 2117.58, "end": 2120.9, "text": " of disparate rhythms finding each other and syncing up to survive,", "tokens": [50766, 295, 14548, 473, 44892, 5006, 1184, 661, 293, 5451, 2175, 493, 281, 7867, 11, 50932], "temperature": 0.0, "avg_logprob": -0.18884333168588033, "compression_ratio": 1.611842105263158, "no_speech_prob": 2.219212877699328e-12}, {"id": 521, "seek": 210956, "start": 2121.14, "end": 2123.1, "text": " is a universal property of nature.", "tokens": [50944, 307, 257, 11455, 4707, 295, 3687, 13, 51042], "temperature": 0.0, "avg_logprob": -0.18884333168588033, "compression_ratio": 1.611842105263158, "no_speech_prob": 2.219212877699328e-12}, {"id": 522, "seek": 210956, "start": 2123.58, "end": 2126.08, "text": " It isn't just a quirk of silicon and copper.", "tokens": [51066, 467, 1943, 380, 445, 257, 421, 18610, 295, 22848, 293, 15007, 13, 51191], "temperature": 0.0, "avg_logprob": -0.18884333168588033, "compression_ratio": 1.611842105263158, "no_speech_prob": 2.219212877699328e-12}, {"id": 523, "seek": 210956, "start": 2126.34, "end": 2129.16, "text": " It's a fundamental law of how systems organize.", "tokens": [51204, 467, 311, 257, 8088, 2101, 295, 577, 3652, 13859, 13, 51345], "temperature": 0.0, "avg_logprob": -0.18884333168588033, "compression_ratio": 1.611842105263158, "no_speech_prob": 2.219212877699328e-12}, {"id": 524, "seek": 210956, "start": 2129.46, "end": 2129.82, "text": " Absolutely.", "tokens": [51360, 7021, 13, 51378], "temperature": 0.0, "avg_logprob": -0.18884333168588033, "compression_ratio": 1.611842105263158, "no_speech_prob": 2.219212877699328e-12}, {"id": 525, "seek": 210956, "start": 2130.32, "end": 2133.5, "text": " But human engineers don't just sit back and watch this happen passively.", "tokens": [51403, 583, 1952, 11955, 500, 380, 445, 1394, 646, 293, 1159, 341, 1051, 1320, 3413, 13, 51562], "temperature": 0.0, "avg_logprob": -0.18884333168588033, "compression_ratio": 1.611842105263158, "no_speech_prob": 2.219212877699328e-12}, {"id": 526, "seek": 210956, "start": 2133.88, "end": 2136.1, "text": " We actively weaponize this math,", "tokens": [51581, 492, 13022, 7463, 1125, 341, 5221, 11, 51692], "temperature": 0.0, "avg_logprob": -0.18884333168588033, "compression_ratio": 1.611842105263158, "no_speech_prob": 2.219212877699328e-12}, {"id": 527, "seek": 210956, "start": 2136.1, "end": 2139.14, "text": " which brings us to a device called the phase-locked loop,", "tokens": [51692, 597, 5607, 505, 281, 257, 4302, 1219, 264, 5574, 12, 4102, 292, 6367, 11, 51844], "temperature": 0.0, "avg_logprob": -0.18884333168588033, "compression_ratio": 1.611842105263158, "no_speech_prob": 2.219212877699328e-12}, {"id": 528, "seek": 213914, "start": 2139.14, "end": 2140.24, "text": " or PLL.", "tokens": [50365, 420, 6999, 43, 13, 50420], "temperature": 0.0, "avg_logprob": -0.19606997072696686, "compression_ratio": 1.6862745098039216, "no_speech_prob": 1.789362711820952e-12}, {"id": 529, "seek": 213914, "start": 2140.72, "end": 2142.74, "text": " A phase-locked loop is the ultimate expression", "tokens": [50444, 316, 5574, 12, 4102, 292, 6367, 307, 264, 9705, 6114, 50545], "temperature": 0.0, "avg_logprob": -0.19606997072696686, "compression_ratio": 1.6862745098039216, "no_speech_prob": 1.789362711820952e-12}, {"id": 530, "seek": 213914, "start": 2142.74, "end": 2144.14, "text": " of engineered continuation.", "tokens": [50545, 295, 38648, 29357, 13, 50615], "temperature": 0.0, "avg_logprob": -0.19606997072696686, "compression_ratio": 1.6862745098039216, "no_speech_prob": 1.789362711820952e-12}, {"id": 531, "seek": 213914, "start": 2144.98, "end": 2146.22, "text": " In passive injection locking,", "tokens": [50657, 682, 14975, 22873, 23954, 11, 50719], "temperature": 0.0, "avg_logprob": -0.19606997072696686, "compression_ratio": 1.6862745098039216, "no_speech_prob": 1.789362711820952e-12}, {"id": 532, "seek": 213914, "start": 2146.44, "end": 2148.7999999999997, "text": " an oscillator gets pulled by a strong signal,", "tokens": [50730, 364, 43859, 2170, 7373, 538, 257, 2068, 6358, 11, 50848], "temperature": 0.0, "avg_logprob": -0.19606997072696686, "compression_ratio": 1.6862745098039216, "no_speech_prob": 1.789362711820952e-12}, {"id": 533, "seek": 213914, "start": 2149.12, "end": 2152.02, "text": " much like a physical rubber band connecting two moving objects.", "tokens": [50864, 709, 411, 257, 4001, 11593, 4116, 11015, 732, 2684, 6565, 13, 51009], "temperature": 0.0, "avg_logprob": -0.19606997072696686, "compression_ratio": 1.6862745098039216, "no_speech_prob": 1.789362711820952e-12}, {"id": 534, "seek": 213914, "start": 2152.2799999999997, "end": 2155.5, "text": " But if the external signal drifts too far away in frequency,", "tokens": [51022, 583, 498, 264, 8320, 6358, 1224, 8065, 886, 1400, 1314, 294, 7893, 11, 51183], "temperature": 0.0, "avg_logprob": -0.19606997072696686, "compression_ratio": 1.6862745098039216, "no_speech_prob": 1.789362711820952e-12}, {"id": 535, "seek": 213914, "start": 2155.9, "end": 2158.8399999999997, "text": " the physical rubber band stretches too far and snaps.", "tokens": [51203, 264, 4001, 11593, 4116, 29058, 886, 1400, 293, 19206, 13, 51350], "temperature": 0.0, "avg_logprob": -0.19606997072696686, "compression_ratio": 1.6862745098039216, "no_speech_prob": 1.789362711820952e-12}, {"id": 536, "seek": 213914, "start": 2159.16, "end": 2160.68, "text": " The oscillator breaks the lock", "tokens": [51366, 440, 43859, 9857, 264, 4017, 51442], "temperature": 0.0, "avg_logprob": -0.19606997072696686, "compression_ratio": 1.6862745098039216, "no_speech_prob": 1.789362711820952e-12}, {"id": 537, "seek": 213914, "start": 2160.68, "end": 2163.12, "text": " and falls back into its own chaotic rhythm.", "tokens": [51442, 293, 8804, 646, 666, 1080, 1065, 27013, 11801, 13, 51564], "temperature": 0.0, "avg_logprob": -0.19606997072696686, "compression_ratio": 1.6862745098039216, "no_speech_prob": 1.789362711820952e-12}, {"id": 538, "seek": 213914, "start": 2163.12, "end": 2163.5, "text": " Right.", "tokens": [51564, 1779, 13, 51583], "temperature": 0.0, "avg_logprob": -0.19606997072696686, "compression_ratio": 1.6862745098039216, "no_speech_prob": 1.789362711820952e-12}, {"id": 539, "seek": 213914, "start": 2163.6, "end": 2166.6, "text": " There is a strict physical limit to how far the phase can stretch", "tokens": [51588, 821, 307, 257, 10910, 4001, 4948, 281, 577, 1400, 264, 5574, 393, 5985, 51738], "temperature": 0.0, "avg_logprob": -0.19606997072696686, "compression_ratio": 1.6862745098039216, "no_speech_prob": 1.789362711820952e-12}, {"id": 540, "seek": 213914, "start": 2166.6, "end": 2168.1, "text": " before the geometry collapses.", "tokens": [51738, 949, 264, 18426, 48765, 13, 51813], "temperature": 0.0, "avg_logprob": -0.19606997072696686, "compression_ratio": 1.6862745098039216, "no_speech_prob": 1.789362711820952e-12}, {"id": 541, "seek": 216810, "start": 2168.1, "end": 2172.44, "text": " But a PLL replaces that passive, fragile rubber band", "tokens": [50365, 583, 257, 6999, 43, 46734, 300, 14975, 11, 23847, 11593, 4116, 50582], "temperature": 0.0, "avg_logprob": -0.15115916993882922, "compression_ratio": 1.6808510638297873, "no_speech_prob": 1.6423625697273292e-12}, {"id": 542, "seek": 216810, "start": 2172.44, "end": 2175.36, "text": " with an active, intelligent tracking system.", "tokens": [50582, 365, 364, 4967, 11, 13232, 11603, 1185, 13, 50728], "temperature": 0.0, "avg_logprob": -0.15115916993882922, "compression_ratio": 1.6808510638297873, "no_speech_prob": 1.6423625697273292e-12}, {"id": 543, "seek": 216810, "start": 2175.7, "end": 2179.9, "text": " It uses a component to constantly measure the exact phase error", "tokens": [50745, 467, 4960, 257, 6542, 281, 6460, 3481, 264, 1900, 5574, 6713, 50955], "temperature": 0.0, "avg_logprob": -0.15115916993882922, "compression_ratio": 1.6808510638297873, "no_speech_prob": 1.6423625697273292e-12}, {"id": 544, "seek": 216810, "start": 2179.9, "end": 2183.94, "text": " between its own internal heartbeat and the external reference heartbeat.", "tokens": [50955, 1296, 1080, 1065, 6920, 34851, 293, 264, 8320, 6408, 34851, 13, 51157], "temperature": 0.0, "avg_logprob": -0.15115916993882922, "compression_ratio": 1.6808510638297873, "no_speech_prob": 1.6423625697273292e-12}, {"id": 545, "seek": 216810, "start": 2184.06, "end": 2184.92, "text": " It measures the error.", "tokens": [51163, 467, 8000, 264, 6713, 13, 51206], "temperature": 0.0, "avg_logprob": -0.15115916993882922, "compression_ratio": 1.6808510638297873, "no_speech_prob": 1.6423625697273292e-12}, {"id": 546, "seek": 216810, "start": 2185.02, "end": 2186.54, "text": " It then takes that error voltage,", "tokens": [51211, 467, 550, 2516, 300, 6713, 8352, 11, 51287], "temperature": 0.0, "avg_logprob": -0.15115916993882922, "compression_ratio": 1.6808510638297873, "no_speech_prob": 1.6423625697273292e-12}, {"id": 547, "seek": 216810, "start": 2187.12, "end": 2189.02, "text": " feeds it through a mathematical loop filter,", "tokens": [51316, 23712, 309, 807, 257, 18894, 6367, 6608, 11, 51411], "temperature": 0.0, "avg_logprob": -0.15115916993882922, "compression_ratio": 1.6808510638297873, "no_speech_prob": 1.6423625697273292e-12}, {"id": 548, "seek": 216810, "start": 2189.2599999999998, "end": 2193.2999999999997, "text": " and uses it to actively steer its own internal oscillator.", "tokens": [51423, 293, 4960, 309, 281, 13022, 30814, 1080, 1065, 6920, 43859, 13, 51625], "temperature": 0.0, "avg_logprob": -0.15115916993882922, "compression_ratio": 1.6808510638297873, "no_speech_prob": 1.6423625697273292e-12}, {"id": 549, "seek": 219330, "start": 2193.3, "end": 2197.2200000000003, "text": " And the really clever part the book highlights is the type 2 PLL,", "tokens": [50365, 400, 264, 534, 13494, 644, 264, 1446, 14254, 307, 264, 2010, 568, 6999, 43, 11, 50561], "temperature": 0.0, "avg_logprob": -0.16478788375854492, "compression_ratio": 1.5647058823529412, "no_speech_prob": 2.5437119858390256e-12}, {"id": 550, "seek": 219330, "start": 2197.5800000000004, "end": 2200.46, "text": " which physically adds an integrator to the loop filter.", "tokens": [50579, 597, 9762, 10860, 364, 3572, 1639, 281, 264, 6367, 6608, 13, 50723], "temperature": 0.0, "avg_logprob": -0.16478788375854492, "compression_ratio": 1.5647058823529412, "no_speech_prob": 2.5437119858390256e-12}, {"id": 551, "seek": 219330, "start": 2200.6400000000003, "end": 2202.94, "text": " This is where the concept of histories before states", "tokens": [50732, 639, 307, 689, 264, 3410, 295, 30631, 949, 4368, 50847], "temperature": 0.0, "avg_logprob": -0.16478788375854492, "compression_ratio": 1.5647058823529412, "no_speech_prob": 2.5437119858390256e-12}, {"id": 552, "seek": 219330, "start": 2202.94, "end": 2205.86, "text": " that we discussed earlier comes roaring back with a vengeance.", "tokens": [50847, 300, 321, 7152, 3071, 1487, 36231, 646, 365, 257, 43818, 13, 50993], "temperature": 0.0, "avg_logprob": -0.16478788375854492, "compression_ratio": 1.5647058823529412, "no_speech_prob": 2.5437119858390256e-12}, {"id": 553, "seek": 219330, "start": 2206.54, "end": 2208.46, "text": " An integrator isn't just a math function.", "tokens": [51027, 1107, 3572, 1639, 1943, 380, 445, 257, 5221, 2445, 13, 51123], "temperature": 0.0, "avg_logprob": -0.16478788375854492, "compression_ratio": 1.5647058823529412, "no_speech_prob": 2.5437119858390256e-12}, {"id": 554, "seek": 219330, "start": 2208.82, "end": 2211.1800000000003, "text": " As we established, it is a physical memory bank.", "tokens": [51141, 1018, 321, 7545, 11, 309, 307, 257, 4001, 4675, 3765, 13, 51259], "temperature": 0.0, "avg_logprob": -0.16478788375854492, "compression_ratio": 1.5647058823529412, "no_speech_prob": 2.5437119858390256e-12}, {"id": 555, "seek": 219330, "start": 2211.28, "end": 2211.5, "text": " Right.", "tokens": [51264, 1779, 13, 51275], "temperature": 0.0, "avg_logprob": -0.16478788375854492, "compression_ratio": 1.5647058823529412, "no_speech_prob": 2.5437119858390256e-12}, {"id": 556, "seek": 219330, "start": 2211.7000000000003, "end": 2215.32, "text": " It accumulates the entire history of the phase error over time.", "tokens": [51285, 467, 12989, 26192, 264, 2302, 2503, 295, 264, 5574, 6713, 670, 565, 13, 51466], "temperature": 0.0, "avg_logprob": -0.16478788375854492, "compression_ratio": 1.5647058823529412, "no_speech_prob": 2.5437119858390256e-12}, {"id": 557, "seek": 221532, "start": 2215.32, "end": 2217.6400000000003, "text": " Just like the capacitor acting as a bank account,", "tokens": [50365, 1449, 411, 264, 29372, 6577, 382, 257, 3765, 2696, 11, 50481], "temperature": 0.0, "avg_logprob": -0.16430718558175222, "compression_ratio": 1.546875, "no_speech_prob": 1.6878987357110686e-12}, {"id": 558, "seek": 221532, "start": 2218.06, "end": 2220.86, "text": " storing the history of all previous deposits and withdrawals.", "tokens": [50502, 26085, 264, 2503, 295, 439, 3894, 30958, 293, 14999, 1124, 13, 50642], "temperature": 0.0, "avg_logprob": -0.16430718558175222, "compression_ratio": 1.546875, "no_speech_prob": 1.6878987357110686e-12}, {"id": 559, "seek": 221532, "start": 2220.86, "end": 2221.2200000000003, "text": " Yes.", "tokens": [50642, 1079, 13, 50660], "temperature": 0.0, "avg_logprob": -0.16430718558175222, "compression_ratio": 1.546875, "no_speech_prob": 1.6878987357110686e-12}, {"id": 560, "seek": 221532, "start": 2221.7400000000002, "end": 2225.76, "text": " Because the PLL now has this accumulated history of its own past mistakes,", "tokens": [50686, 1436, 264, 6999, 43, 586, 575, 341, 31346, 2503, 295, 1080, 1065, 1791, 8038, 11, 50887], "temperature": 0.0, "avg_logprob": -0.16430718558175222, "compression_ratio": 1.546875, "no_speech_prob": 1.6878987357110686e-12}, {"id": 561, "seek": 221532, "start": 2225.98, "end": 2230.6800000000003, "text": " it doesn't just react blindly to the immediate instantaneous phase difference.", "tokens": [50898, 309, 1177, 380, 445, 4515, 47744, 281, 264, 11629, 45596, 5574, 2649, 13, 51133], "temperature": 0.0, "avg_logprob": -0.16430718558175222, "compression_ratio": 1.546875, "no_speech_prob": 1.6878987357110686e-12}, {"id": 562, "seek": 221532, "start": 2231.02, "end": 2233.96, "text": " It can permanently adjust its own internal center frequency", "tokens": [51150, 467, 393, 24042, 4369, 1080, 1065, 6920, 3056, 7893, 51297], "temperature": 0.0, "avg_logprob": -0.16430718558175222, "compression_ratio": 1.546875, "no_speech_prob": 1.6878987357110686e-12}, {"id": 563, "seek": 221532, "start": 2233.96, "end": 2236.3, "text": " to continuously match a moving target.", "tokens": [51297, 281, 15684, 2995, 257, 2684, 3779, 13, 51414], "temperature": 0.0, "avg_logprob": -0.16430718558175222, "compression_ratio": 1.546875, "no_speech_prob": 1.6878987357110686e-12}, {"id": 564, "seek": 221532, "start": 2236.5, "end": 2237.84, "text": " So it learns, essentially.", "tokens": [51424, 407, 309, 27152, 11, 4476, 13, 51491], "temperature": 0.0, "avg_logprob": -0.16430718558175222, "compression_ratio": 1.546875, "no_speech_prob": 1.6878987357110686e-12}, {"id": 565, "seek": 223784, "start": 2237.84, "end": 2239.86, "text": " Because it possesses an integrator,", "tokens": [50365, 1436, 309, 17490, 279, 364, 3572, 1639, 11, 50466], "temperature": 0.0, "avg_logprob": -0.16150080829585364, "compression_ratio": 1.5559322033898304, "no_speech_prob": 2.0442614614979426e-12}, {"id": 566, "seek": 223784, "start": 2240.28, "end": 2243.86, "text": " a type 2 PLL can track a constantly drifting frequency offset", "tokens": [50487, 257, 2010, 568, 6999, 43, 393, 2837, 257, 6460, 37973, 7893, 18687, 50666], "temperature": 0.0, "avg_logprob": -0.16150080829585364, "compression_ratio": 1.5559322033898304, "no_speech_prob": 2.0442614614979426e-12}, {"id": 567, "seek": 223784, "start": 2243.86, "end": 2247.1600000000003, "text": " with absolutely zero steady state phase error.", "tokens": [50666, 365, 3122, 4018, 13211, 1785, 5574, 6713, 13, 50831], "temperature": 0.0, "avg_logprob": -0.16150080829585364, "compression_ratio": 1.5559322033898304, "no_speech_prob": 2.0442614614979426e-12}, {"id": 568, "seek": 223784, "start": 2247.58, "end": 2250.32, "text": " It can follow a runaway signal unboundedly,", "tokens": [50852, 467, 393, 1524, 257, 1190, 10318, 6358, 517, 18767, 13516, 11, 50989], "temperature": 0.0, "avg_logprob": -0.16150080829585364, "compression_ratio": 1.5559322033898304, "no_speech_prob": 2.0442614614979426e-12}, {"id": 569, "seek": 223784, "start": 2250.6400000000003, "end": 2253.1800000000003, "text": " limited only by the physical tuning range of its hardware,", "tokens": [51005, 5567, 787, 538, 264, 4001, 15164, 3613, 295, 1080, 8837, 11, 51132], "temperature": 0.0, "avg_logprob": -0.16150080829585364, "compression_ratio": 1.5559322033898304, "no_speech_prob": 2.0442614614979426e-12}, {"id": 570, "seek": 223784, "start": 2253.76, "end": 2256.3, "text": " specifically because it has the required memory", "tokens": [51161, 4682, 570, 309, 575, 264, 4739, 4675, 51288], "temperature": 0.0, "avg_logprob": -0.16150080829585364, "compression_ratio": 1.5559322033898304, "no_speech_prob": 2.0442614614979426e-12}, {"id": 571, "seek": 223784, "start": 2256.3, "end": 2258.4, "text": " to permanently adapt its own geometry.", "tokens": [51288, 281, 24042, 6231, 1080, 1065, 18426, 13, 51393], "temperature": 0.0, "avg_logprob": -0.16150080829585364, "compression_ratio": 1.5559322033898304, "no_speech_prob": 2.0442614614979426e-12}, {"id": 572, "seek": 223784, "start": 2258.82, "end": 2262.76, "text": " So we have these incredible, almost biological structures", "tokens": [51414, 407, 321, 362, 613, 4651, 11, 1920, 13910, 9227, 51611], "temperature": 0.0, "avg_logprob": -0.16150080829585364, "compression_ratio": 1.5559322033898304, "no_speech_prob": 2.0442614614979426e-12}, {"id": 573, "seek": 223784, "start": 2262.76, "end": 2264.48, "text": " living inside our electronics.", "tokens": [51611, 2647, 1854, 527, 20611, 13, 51697], "temperature": 0.0, "avg_logprob": -0.16150080829585364, "compression_ratio": 1.5559322033898304, "no_speech_prob": 2.0442614614979426e-12}, {"id": 574, "seek": 223784, "start": 2265.1000000000004, "end": 2266.94, "text": " Circuits syncing up like fireflies,", "tokens": [51728, 28938, 7688, 5451, 2175, 493, 411, 2610, 24471, 11, 51820], "temperature": 0.0, "avg_logprob": -0.16150080829585364, "compression_ratio": 1.5559322033898304, "no_speech_prob": 2.0442614614979426e-12}, {"id": 575, "seek": 226694, "start": 2266.94, "end": 2268.98, "text": " actively hunting for their own stability,", "tokens": [50365, 13022, 12599, 337, 641, 1065, 11826, 11, 50467], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 576, "seek": 226694, "start": 2269.36, "end": 2270.84, "text": " regenerating their own continuation,", "tokens": [50486, 26358, 990, 641, 1065, 29357, 11, 50560], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 577, "seek": 226694, "start": 2271.26, "end": 2273.52, "text": " using the accumulated history of their past errors.", "tokens": [50581, 1228, 264, 31346, 2503, 295, 641, 1791, 13603, 13, 50694], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 578, "seek": 226694, "start": 2273.62, "end": 2274.92, "text": " It's remarkably elegant.", "tokens": [50699, 467, 311, 37381, 21117, 13, 50764], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 579, "seek": 226694, "start": 2275.02, "end": 2275.9, "text": " It sounds beautiful.", "tokens": [50769, 467, 3263, 2238, 13, 50813], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 580, "seek": 226694, "start": 2276.06, "end": 2277.38, "text": " It sounds geometrically perfect.", "tokens": [50821, 467, 3263, 12956, 81, 984, 2176, 13, 50887], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 581, "seek": 226694, "start": 2277.76, "end": 2279.64, "text": " But they exist in a physical universe", "tokens": [50906, 583, 436, 2514, 294, 257, 4001, 6445, 51000], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 582, "seek": 226694, "start": 2279.64, "end": 2282.5, "text": " that is constantly, relentlessly trying to tear", "tokens": [51000, 300, 307, 6460, 11, 34045, 12048, 1382, 281, 12556, 51143], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 583, "seek": 226694, "start": 2282.5, "end": 2283.84, "text": " that beautiful structure apart.", "tokens": [51143, 300, 2238, 3877, 4936, 13, 51210], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 584, "seek": 226694, "start": 2284.02, "end": 2285.34, "text": " The universe does not like order.", "tokens": [51219, 440, 6445, 775, 406, 411, 1668, 13, 51285], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 585, "seek": 226694, "start": 2285.66, "end": 2288.1, "text": " Every single time you do work in the physical universe,", "tokens": [51301, 2048, 2167, 565, 291, 360, 589, 294, 264, 4001, 6445, 11, 51423], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 586, "seek": 226694, "start": 2288.2200000000003, "end": 2289.04, "text": " you generate entropy.", "tokens": [51429, 291, 8460, 30867, 13, 51470], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 587, "seek": 226694, "start": 2289.34, "end": 2290.94, "text": " You generate thermodynamic heat.", "tokens": [51485, 509, 8460, 8810, 34988, 3738, 13, 51565], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 588, "seek": 226694, "start": 2291.36, "end": 2292.42, "text": " And in electronic circuits,", "tokens": [51586, 400, 294, 10092, 26354, 11, 51639], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 589, "seek": 226694, "start": 2292.42, "end": 2295.2200000000003, "text": " the primary source of that heat is the basic resistor.", "tokens": [51639, 264, 6194, 4009, 295, 300, 3738, 307, 264, 3875, 37672, 13, 51779], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 590, "seek": 226694, "start": 2295.2200000000003, "end": 2295.56, "text": " Right.", "tokens": [51779, 1779, 13, 51796], "temperature": 0.0, "avg_logprob": -0.18649770887635594, "compression_ratio": 1.761755485893417, "no_speech_prob": 2.3257923364994326e-12}, {"id": 591, "seek": 229556, "start": 2295.56, "end": 2297.34, "text": " The current flows through a resistive material,", "tokens": [50365, 440, 2190, 12867, 807, 257, 4597, 488, 2527, 11, 50454], "temperature": 0.0, "avg_logprob": -0.204920116223787, "compression_ratio": 1.5252525252525253, "no_speech_prob": 2.184295496213129e-12}, {"id": 592, "seek": 229556, "start": 2297.58, "end": 2299.0, "text": " friction occurs at the atomic level,", "tokens": [50466, 17710, 11843, 412, 264, 22275, 1496, 11, 50537], "temperature": 0.0, "avg_logprob": -0.204920116223787, "compression_ratio": 1.5252525252525253, "no_speech_prob": 2.184295496213129e-12}, {"id": 593, "seek": 229556, "start": 2299.16, "end": 2300.06, "text": " and it gets hot.", "tokens": [50545, 293, 309, 2170, 2368, 13, 50590], "temperature": 0.0, "avg_logprob": -0.204920116223787, "compression_ratio": 1.5252525252525253, "no_speech_prob": 2.184295496213129e-12}, {"id": 594, "seek": 229556, "start": 2300.4, "end": 2301.58, "text": " That is basic Heisel physics.", "tokens": [50607, 663, 307, 3875, 634, 39711, 10649, 13, 50666], "temperature": 0.0, "avg_logprob": -0.204920116223787, "compression_ratio": 1.5252525252525253, "no_speech_prob": 2.184295496213129e-12}, {"id": 595, "seek": 229556, "start": 2301.82, "end": 2304.66, "text": " But fliction ties this basic heating effect", "tokens": [50678, 583, 932, 4105, 14039, 341, 3875, 15082, 1802, 50820], "temperature": 0.0, "avg_logprob": -0.204920116223787, "compression_ratio": 1.5252525252525253, "no_speech_prob": 2.184295496213129e-12}, {"id": 596, "seek": 229556, "start": 2304.66, "end": 2306.88, "text": " directly to informational noise", "tokens": [50820, 3838, 281, 49391, 5658, 50931], "temperature": 0.0, "avg_logprob": -0.204920116223787, "compression_ratio": 1.5252525252525253, "no_speech_prob": 2.184295496213129e-12}, {"id": 597, "seek": 229556, "start": 2306.88, "end": 2309.98, "text": " using a profound result from statistical mechanics", "tokens": [50931, 1228, 257, 14382, 1874, 490, 22820, 12939, 51086], "temperature": 0.0, "avg_logprob": -0.204920116223787, "compression_ratio": 1.5252525252525253, "no_speech_prob": 2.184295496213129e-12}, {"id": 598, "seek": 229556, "start": 2309.98, "end": 2312.32, "text": " called the fluctuation-dissipation theorem.", "tokens": [51086, 1219, 264, 23448, 16073, 12, 67, 891, 647, 399, 20904, 13, 51203], "temperature": 0.0, "avg_logprob": -0.204920116223787, "compression_ratio": 1.5252525252525253, "no_speech_prob": 2.184295496213129e-12}, {"id": 599, "seek": 231232, "start": 2312.32, "end": 2313.96, "text": " I am stuck on this theorem.", "tokens": [50365, 286, 669, 5541, 322, 341, 20904, 13, 50447], "temperature": 0.0, "avg_logprob": -0.1626896858215332, "compression_ratio": 1.7875457875457876, "no_speech_prob": 2.1507494136346894e-12}, {"id": 600, "seek": 231232, "start": 2314.38, "end": 2315.86, "text": " Fluctuation and dissipation.", "tokens": [50468, 33612, 349, 16073, 293, 29544, 399, 13, 50542], "temperature": 0.0, "avg_logprob": -0.1626896858215332, "compression_ratio": 1.7875457875457876, "no_speech_prob": 2.1507494136346894e-12}, {"id": 601, "seek": 231232, "start": 2316.1600000000003, "end": 2317.96, "text": " What is the physical link here?", "tokens": [50557, 708, 307, 264, 4001, 2113, 510, 30, 50647], "temperature": 0.0, "avg_logprob": -0.1626896858215332, "compression_ratio": 1.7875457875457876, "no_speech_prob": 2.1507494136346894e-12}, {"id": 602, "seek": 231232, "start": 2318.48, "end": 2321.6200000000003, "text": " The theorem states that the exact same physical mechanism", "tokens": [50673, 440, 20904, 4368, 300, 264, 1900, 912, 4001, 7513, 50830], "temperature": 0.0, "avg_logprob": -0.1626896858215332, "compression_ratio": 1.7875457875457876, "no_speech_prob": 2.1507494136346894e-12}, {"id": 603, "seek": 231232, "start": 2321.6200000000003, "end": 2324.88, "text": " that allows a component to dissipate energy into the environment", "tokens": [50830, 300, 4045, 257, 6542, 281, 29544, 473, 2281, 666, 264, 2823, 50993], "temperature": 0.0, "avg_logprob": -0.1626896858215332, "compression_ratio": 1.7875457875457876, "no_speech_prob": 2.1507494136346894e-12}, {"id": 604, "seek": 231232, "start": 2324.88, "end": 2328.1800000000003, "text": " must also cause that component to randomly fluctuate.", "tokens": [50993, 1633, 611, 3082, 300, 6542, 281, 16979, 23448, 10107, 13, 51158], "temperature": 0.0, "avg_logprob": -0.1626896858215332, "compression_ratio": 1.7875457875457876, "no_speech_prob": 2.1507494136346894e-12}, {"id": 605, "seek": 231232, "start": 2328.42, "end": 2329.0, "text": " Wait, really?", "tokens": [51170, 3802, 11, 534, 30, 51199], "temperature": 0.0, "avg_logprob": -0.1626896858215332, "compression_ratio": 1.7875457875457876, "no_speech_prob": 2.1507494136346894e-12}, {"id": 606, "seek": 231232, "start": 2329.34, "end": 2331.5, "text": " You physically cannot have a resistor", "tokens": [51216, 509, 9762, 2644, 362, 257, 37672, 51324], "temperature": 0.0, "avg_logprob": -0.1626896858215332, "compression_ratio": 1.7875457875457876, "no_speech_prob": 2.1507494136346894e-12}, {"id": 607, "seek": 231232, "start": 2331.5, "end": 2333.9, "text": " that turns electrical energy into heat", "tokens": [51324, 300, 4523, 12147, 2281, 666, 3738, 51444], "temperature": 0.0, "avg_logprob": -0.1626896858215332, "compression_ratio": 1.7875457875457876, "no_speech_prob": 2.1507494136346894e-12}, {"id": 608, "seek": 231232, "start": 2333.9, "end": 2335.84, "text": " without that exact same resistor", "tokens": [51444, 1553, 300, 1900, 912, 37672, 51541], "temperature": 0.0, "avg_logprob": -0.1626896858215332, "compression_ratio": 1.7875457875457876, "no_speech_prob": 2.1507494136346894e-12}, {"id": 609, "seek": 231232, "start": 2335.84, "end": 2339.6600000000003, "text": " also generating random chaotic thermal noise in the voltage.", "tokens": [51541, 611, 17746, 4974, 27013, 15070, 5658, 294, 264, 8352, 13, 51732], "temperature": 0.0, "avg_logprob": -0.1626896858215332, "compression_ratio": 1.7875457875457876, "no_speech_prob": 2.1507494136346894e-12}, {"id": 610, "seek": 231232, "start": 2339.8, "end": 2341.2200000000003, "text": " That is Johnson-Nyquist noise, right?", "tokens": [51739, 663, 307, 9779, 12, 45, 88, 358, 468, 5658, 11, 558, 30, 51810], "temperature": 0.0, "avg_logprob": -0.1626896858215332, "compression_ratio": 1.7875457875457876, "no_speech_prob": 2.1507494136346894e-12}, {"id": 611, "seek": 234122, "start": 2341.22, "end": 2344.8999999999996, "text": " Yes. They are two sides of the exact same thermodynamic coin.", "tokens": [50365, 1079, 13, 814, 366, 732, 4881, 295, 264, 1900, 912, 8810, 34988, 11464, 13, 50549], "temperature": 0.0, "avg_logprob": -0.19377174377441406, "compression_ratio": 1.641350210970464, "no_speech_prob": 2.2451567514847337e-12}, {"id": 612, "seek": 234122, "start": 2344.8999999999996, "end": 2348.58, "text": " The entropy production, the heat you feel, and the noise,", "tokens": [50549, 440, 30867, 4265, 11, 264, 3738, 291, 841, 11, 293, 264, 5658, 11, 50733], "temperature": 0.0, "avg_logprob": -0.19377174377441406, "compression_ratio": 1.641350210970464, "no_speech_prob": 2.2451567514847337e-12}, {"id": 613, "seek": 234122, "start": 2348.8799999999997, "end": 2350.72, "text": " the chaotic electrical fluctuation,", "tokens": [50748, 264, 27013, 12147, 23448, 16073, 11, 50840], "temperature": 0.0, "avg_logprob": -0.19377174377441406, "compression_ratio": 1.641350210970464, "no_speech_prob": 2.2451567514847337e-12}, {"id": 614, "seek": 234122, "start": 2350.9199999999996, "end": 2352.98, "text": " are mathematically and physically linked.", "tokens": [50850, 366, 44003, 293, 9762, 9408, 13, 50953], "temperature": 0.0, "avg_logprob": -0.19377174377441406, "compression_ratio": 1.641350210970464, "no_speech_prob": 2.2451567514847337e-12}, {"id": 615, "seek": 234122, "start": 2353.2, "end": 2354.74, "text": " So you can't just build a better resistor.", "tokens": [50964, 407, 291, 393, 380, 445, 1322, 257, 1101, 37672, 13, 51041], "temperature": 0.0, "avg_logprob": -0.19377174377441406, "compression_ratio": 1.641350210970464, "no_speech_prob": 2.2451567514847337e-12}, {"id": 616, "seek": 234122, "start": 2354.8799999999997, "end": 2356.68, "text": " You cannot engineer a magical resistor", "tokens": [51048, 509, 2644, 11403, 257, 12066, 37672, 51138], "temperature": 0.0, "avg_logprob": -0.19377174377441406, "compression_ratio": 1.641350210970464, "no_speech_prob": 2.2451567514847337e-12}, {"id": 617, "seek": 234122, "start": 2356.68, "end": 2358.2999999999997, "text": " that successfully dissipates heat", "tokens": [51138, 300, 10727, 29544, 1024, 3738, 51219], "temperature": 0.0, "avg_logprob": -0.19377174377441406, "compression_ratio": 1.641350210970464, "no_speech_prob": 2.2451567514847337e-12}, {"id": 618, "seek": 234122, "start": 2358.2999999999997, "end": 2360.7799999999997, "text": " but stays perfectly electrically quiet.", "tokens": [51219, 457, 10834, 6239, 7072, 984, 5677, 13, 51343], "temperature": 0.0, "avg_logprob": -0.19377174377441406, "compression_ratio": 1.641350210970464, "no_speech_prob": 2.2451567514847337e-12}, {"id": 619, "seek": 234122, "start": 2361.16, "end": 2362.58, "text": " The laws of the universe forbid it.", "tokens": [51362, 440, 6064, 295, 264, 6445, 34117, 309, 13, 51433], "temperature": 0.0, "avg_logprob": -0.19377174377441406, "compression_ratio": 1.641350210970464, "no_speech_prob": 2.2451567514847337e-12}, {"id": 620, "seek": 236258, "start": 2362.58, "end": 2365.84, "text": " The noise is the unavoidable thermodynamic tax", "tokens": [50365, 440, 5658, 307, 264, 36541, 17079, 712, 8810, 34988, 3366, 50528], "temperature": 0.0, "avg_logprob": -0.16894119777036518, "compression_ratio": 1.5857740585774058, "no_speech_prob": 2.0685508427681354e-12}, {"id": 621, "seek": 236258, "start": 2365.84, "end": 2367.6, "text": " for existing above absolute zero.", "tokens": [50528, 337, 6741, 3673, 8236, 4018, 13, 50616], "temperature": 0.0, "avg_logprob": -0.16894119777036518, "compression_ratio": 1.5857740585774058, "no_speech_prob": 2.0685508427681354e-12}, {"id": 622, "seek": 236258, "start": 2368.2599999999998, "end": 2370.7999999999997, "text": " And that noise is everywhere, in every component.", "tokens": [50649, 400, 300, 5658, 307, 5315, 11, 294, 633, 6542, 13, 50776], "temperature": 0.0, "avg_logprob": -0.16894119777036518, "compression_ratio": 1.5857740585774058, "no_speech_prob": 2.0685508427681354e-12}, {"id": 623, "seek": 236258, "start": 2371.04, "end": 2374.7599999999998, "text": " So how does any signal survive this environment?", "tokens": [50788, 407, 577, 775, 604, 6358, 7867, 341, 2823, 30, 50974], "temperature": 0.0, "avg_logprob": -0.16894119777036518, "compression_ratio": 1.5857740585774058, "no_speech_prob": 2.0685508427681354e-12}, {"id": 624, "seek": 236258, "start": 2375.0, "end": 2376.04, "text": " It's a constant struggle.", "tokens": [50986, 467, 311, 257, 5754, 7799, 13, 51038], "temperature": 0.0, "avg_logprob": -0.16894119777036518, "compression_ratio": 1.5857740585774058, "no_speech_prob": 2.0685508427681354e-12}, {"id": 625, "seek": 236258, "start": 2376.2799999999997, "end": 2379.0, "text": " How does my phone download a perfectly crisp picture", "tokens": [51050, 1012, 775, 452, 2593, 5484, 257, 6239, 22952, 3036, 51186], "temperature": 0.0, "avg_logprob": -0.16894119777036518, "compression_ratio": 1.5857740585774058, "no_speech_prob": 2.0685508427681354e-12}, {"id": 626, "seek": 236258, "start": 2379.0, "end": 2380.72, "text": " from a satellite in space", "tokens": [51186, 490, 257, 16016, 294, 1901, 51272], "temperature": 0.0, "avg_logprob": -0.16894119777036518, "compression_ratio": 1.5857740585774058, "no_speech_prob": 2.0685508427681354e-12}, {"id": 627, "seek": 236258, "start": 2380.72, "end": 2383.24, "text": " if the very components processing the signal", "tokens": [51272, 498, 264, 588, 6677, 9007, 264, 6358, 51398], "temperature": 0.0, "avg_logprob": -0.16894119777036518, "compression_ratio": 1.5857740585774058, "no_speech_prob": 2.0685508427681354e-12}, {"id": 628, "seek": 236258, "start": 2383.24, "end": 2385.98, "text": " are constantly boiling with thermal fluctuations?", "tokens": [51398, 366, 6460, 16208, 365, 15070, 45276, 30, 51535], "temperature": 0.0, "avg_logprob": -0.16894119777036518, "compression_ratio": 1.5857740585774058, "no_speech_prob": 2.0685508427681354e-12}, {"id": 629, "seek": 238598, "start": 2385.98, "end": 2387.9, "text": " It survives through a concept", "tokens": [50365, 467, 46231, 807, 257, 3410, 50461], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 630, "seek": 238598, "start": 2387.9, "end": 2389.94, "text": " Fliction calls admissibility volume,", "tokens": [50461, 3235, 4105, 5498, 5910, 891, 2841, 5523, 11, 50563], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 631, "seek": 238598, "start": 2390.2, "end": 2392.58, "text": " which is how the book radically reinterprets", "tokens": [50576, 597, 307, 577, 264, 1446, 35508, 319, 5106, 3712, 1373, 50695], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 632, "seek": 238598, "start": 2392.58, "end": 2394.14, "text": " the standard engineering metric", "tokens": [50695, 264, 3832, 7043, 20678, 50773], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 633, "seek": 238598, "start": 2394.14, "end": 2396.9, "text": " of signal-to-noise ratio, or SNR.", "tokens": [50773, 295, 6358, 12, 1353, 12, 42641, 8509, 11, 420, 13955, 49, 13, 50911], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 634, "seek": 238598, "start": 2397.08, "end": 2397.56, "text": " SNR.", "tokens": [50920, 13955, 49, 13, 50944], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 635, "seek": 238598, "start": 2397.96, "end": 2399.54, "text": " Anyone who has ever bought a stereo", "tokens": [50964, 14643, 567, 575, 1562, 4243, 257, 29029, 51043], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 636, "seek": 238598, "start": 2399.54, "end": 2401.3, "text": " knows you want a high SNR.", "tokens": [51043, 3255, 291, 528, 257, 1090, 13955, 49, 13, 51131], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 637, "seek": 238598, "start": 2401.66, "end": 2402.76, "text": " You want the music loud", "tokens": [51149, 509, 528, 264, 1318, 6588, 51204], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 638, "seek": 238598, "start": 2402.76, "end": 2404.18, "text": " and the background static quiet.", "tokens": [51204, 293, 264, 3678, 13437, 5677, 13, 51275], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 639, "seek": 238598, "start": 2404.66, "end": 2406.02, "text": " But Fliction asks us to look at", "tokens": [51299, 583, 3235, 4105, 8962, 505, 281, 574, 412, 51367], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 640, "seek": 238598, "start": 2406.02, "end": 2407.72, "text": " what the static is actually doing", "tokens": [51367, 437, 264, 13437, 307, 767, 884, 51452], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 641, "seek": 238598, "start": 2407.72, "end": 2409.36, "text": " to the geometry of the information.", "tokens": [51452, 281, 264, 18426, 295, 264, 1589, 13, 51534], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 642, "seek": 238598, "start": 2409.98, "end": 2413.16, "text": " Noise acts as an active, compressive pressure on reality.", "tokens": [51565, 44821, 10672, 382, 364, 4967, 11, 14778, 488, 3321, 322, 4103, 13, 51724], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 643, "seek": 238598, "start": 2413.52, "end": 2413.86, "text": " How so?", "tokens": [51742, 1012, 370, 30, 51759], "temperature": 0.0, "avg_logprob": -0.1697834239286535, "compression_ratio": 1.5824915824915824, "no_speech_prob": 2.1342023200782156e-12}, {"id": 644, "seek": 241386, "start": 2413.86, "end": 2416.06, "text": " Imagine a digital signal trying to send", "tokens": [50365, 11739, 257, 4562, 6358, 1382, 281, 2845, 50475], "temperature": 0.0, "avg_logprob": -0.11282400841260479, "compression_ratio": 1.7891156462585034, "no_speech_prob": 2.2986116048756555e-12}, {"id": 645, "seek": 241386, "start": 2416.06, "end": 2418.28, "text": " a stream of zeros and ones down a wire.", "tokens": [50475, 257, 4309, 295, 35193, 293, 2306, 760, 257, 6234, 13, 50586], "temperature": 0.0, "avg_logprob": -0.11282400841260479, "compression_ratio": 1.7891156462585034, "no_speech_prob": 2.2986116048756555e-12}, {"id": 646, "seek": 241386, "start": 2418.6600000000003, "end": 2420.84, "text": " Let's say a zero is exactly zero volts", "tokens": [50605, 961, 311, 584, 257, 4018, 307, 2293, 4018, 22322, 50714], "temperature": 0.0, "avg_logprob": -0.11282400841260479, "compression_ratio": 1.7891156462585034, "no_speech_prob": 2.2986116048756555e-12}, {"id": 647, "seek": 241386, "start": 2420.84, "end": 2422.78, "text": " and a one is exactly five volts.", "tokens": [50714, 293, 257, 472, 307, 2293, 1732, 22322, 13, 50811], "temperature": 0.0, "avg_logprob": -0.11282400841260479, "compression_ratio": 1.7891156462585034, "no_speech_prob": 2.2986116048756555e-12}, {"id": 648, "seek": 241386, "start": 2422.94, "end": 2425.1, "text": " In a perfect world, those are very easy to tell apart.", "tokens": [50819, 682, 257, 2176, 1002, 11, 729, 366, 588, 1858, 281, 980, 4936, 13, 50927], "temperature": 0.0, "avg_logprob": -0.11282400841260479, "compression_ratio": 1.7891156462585034, "no_speech_prob": 2.2986116048756555e-12}, {"id": 649, "seek": 241386, "start": 2425.4, "end": 2428.1800000000003, "text": " But add the boiling thermal noise of the universe.", "tokens": [50942, 583, 909, 264, 16208, 15070, 5658, 295, 264, 6445, 13, 51081], "temperature": 0.0, "avg_logprob": -0.11282400841260479, "compression_ratio": 1.7891156462585034, "no_speech_prob": 2.2986116048756555e-12}, {"id": 650, "seek": 241386, "start": 2428.78, "end": 2430.88, "text": " The zero volt signal randomly fluctuates", "tokens": [51111, 440, 4018, 5962, 6358, 16979, 23448, 27710, 51216], "temperature": 0.0, "avg_logprob": -0.11282400841260479, "compression_ratio": 1.7891156462585034, "no_speech_prob": 2.2986116048756555e-12}, {"id": 651, "seek": 241386, "start": 2430.88, "end": 2432.54, "text": " up to one volt, maybe two volts.", "tokens": [51216, 493, 281, 472, 5962, 11, 1310, 732, 22322, 13, 51299], "temperature": 0.0, "avg_logprob": -0.11282400841260479, "compression_ratio": 1.7891156462585034, "no_speech_prob": 2.2986116048756555e-12}, {"id": 652, "seek": 241386, "start": 2432.98, "end": 2435.1, "text": " The five volt signal randomly fluctuates", "tokens": [51321, 440, 1732, 5962, 6358, 16979, 23448, 27710, 51427], "temperature": 0.0, "avg_logprob": -0.11282400841260479, "compression_ratio": 1.7891156462585034, "no_speech_prob": 2.2986116048756555e-12}, {"id": 653, "seek": 241386, "start": 2435.1, "end": 2437.26, "text": " down to four volts, maybe three volts.", "tokens": [51427, 760, 281, 1451, 22322, 11, 1310, 1045, 22322, 13, 51535], "temperature": 0.0, "avg_logprob": -0.11282400841260479, "compression_ratio": 1.7891156462585034, "no_speech_prob": 2.2986116048756555e-12}, {"id": 654, "seek": 241386, "start": 2437.5, "end": 2439.6200000000003, "text": " The physical space between them starts shrinking.", "tokens": [51547, 440, 4001, 1901, 1296, 552, 3719, 41684, 13, 51653], "temperature": 0.0, "avg_logprob": -0.11282400841260479, "compression_ratio": 1.7891156462585034, "no_speech_prob": 2.2986116048756555e-12}, {"id": 655, "seek": 241386, "start": 2439.9, "end": 2441.0, "text": " They're getting squeezed together.", "tokens": [51667, 814, 434, 1242, 39470, 1214, 13, 51722], "temperature": 0.0, "avg_logprob": -0.11282400841260479, "compression_ratio": 1.7891156462585034, "no_speech_prob": 2.2986116048756555e-12}, {"id": 656, "seek": 241386, "start": 2441.2200000000003, "end": 2442.6600000000003, "text": " As the noise floor increases,", "tokens": [51733, 1018, 264, 5658, 4123, 8637, 11, 51805], "temperature": 0.0, "avg_logprob": -0.11282400841260479, "compression_ratio": 1.7891156462585034, "no_speech_prob": 2.2986116048756555e-12}, {"id": 657, "seek": 244266, "start": 2442.66, "end": 2444.2599999999998, "text": " the probability distributions", "tokens": [50365, 264, 8482, 37870, 50445], "temperature": 0.0, "avg_logprob": -0.18671841664357228, "compression_ratio": 1.7307692307692308, "no_speech_prob": 1.7007672397165163e-12}, {"id": 658, "seek": 244266, "start": 2444.2599999999998, "end": 2446.02, "text": " of those two distinct states", "tokens": [50445, 295, 729, 732, 10644, 4368, 50533], "temperature": 0.0, "avg_logprob": -0.18671841664357228, "compression_ratio": 1.7307692307692308, "no_speech_prob": 1.7007672397165163e-12}, {"id": 659, "seek": 244266, "start": 2446.02, "end": 2447.46, "text": " begin to physically overlap.", "tokens": [50533, 1841, 281, 9762, 19959, 13, 50605], "temperature": 0.0, "avg_logprob": -0.18671841664357228, "compression_ratio": 1.7307692307692308, "no_speech_prob": 1.7007672397165163e-12}, {"id": 660, "seek": 244266, "start": 2448.52, "end": 2450.2799999999997, "text": " The noise is literally collapsing", "tokens": [50658, 440, 5658, 307, 3736, 45339, 50746], "temperature": 0.0, "avg_logprob": -0.18671841664357228, "compression_ratio": 1.7307692307692308, "no_speech_prob": 1.7007672397165163e-12}, {"id": 661, "seek": 244266, "start": 2450.2799999999997, "end": 2452.54, "text": " the geometric distinctions between the states.", "tokens": [50746, 264, 33246, 1483, 49798, 1296, 264, 4368, 13, 50859], "temperature": 0.0, "avg_logprob": -0.18671841664357228, "compression_ratio": 1.7307692307692308, "no_speech_prob": 1.7007672397165163e-12}, {"id": 662, "seek": 244266, "start": 2452.74, "end": 2453.12, "text": " Oh, wow.", "tokens": [50869, 876, 11, 6076, 13, 50888], "temperature": 0.0, "avg_logprob": -0.18671841664357228, "compression_ratio": 1.7307692307692308, "no_speech_prob": 1.7007672397165163e-12}, {"id": 663, "seek": 244266, "start": 2453.3199999999997, "end": 2454.7599999999998, "text": " The signal to noise ratio", "tokens": [50898, 440, 6358, 281, 5658, 8509, 50970], "temperature": 0.0, "avg_logprob": -0.18671841664357228, "compression_ratio": 1.7307692307692308, "no_speech_prob": 1.7007672397165163e-12}, {"id": 664, "seek": 244266, "start": 2454.7599999999998, "end": 2456.7999999999997, "text": " isn't just about how loud the signal is.", "tokens": [50970, 1943, 380, 445, 466, 577, 6588, 264, 6358, 307, 13, 51072], "temperature": 0.0, "avg_logprob": -0.18671841664357228, "compression_ratio": 1.7307692307692308, "no_speech_prob": 1.7007672397165163e-12}, {"id": 665, "seek": 244266, "start": 2457.18, "end": 2459.68, "text": " It's a physical measure of distinguishability.", "tokens": [51091, 467, 311, 257, 4001, 3481, 295, 20206, 2310, 13, 51216], "temperature": 0.0, "avg_logprob": -0.18671841664357228, "compression_ratio": 1.7307692307692308, "no_speech_prob": 1.7007672397165163e-12}, {"id": 666, "seek": 244266, "start": 2460.2799999999997, "end": 2462.92, "text": " It defines a mathematical volume of space", "tokens": [51246, 467, 23122, 257, 18894, 5523, 295, 1901, 51378], "temperature": 0.0, "avg_logprob": -0.18671841664357228, "compression_ratio": 1.7307692307692308, "no_speech_prob": 1.7007672397165163e-12}, {"id": 667, "seek": 244266, "start": 2462.92, "end": 2464.8199999999997, "text": " within which states remain distinct", "tokens": [51378, 1951, 597, 4368, 6222, 10644, 51473], "temperature": 0.0, "avg_logprob": -0.18671841664357228, "compression_ratio": 1.7307692307692308, "no_speech_prob": 1.7007672397165163e-12}, {"id": 668, "seek": 244266, "start": 2464.8199999999997, "end": 2466.3599999999997, "text": " and structurally admissible.", "tokens": [51473, 293, 6594, 6512, 5910, 41073, 13, 51550], "temperature": 0.0, "avg_logprob": -0.18671841664357228, "compression_ratio": 1.7307692307692308, "no_speech_prob": 1.7007672397165163e-12}, {"id": 669, "seek": 244266, "start": 2466.58, "end": 2469.24, "text": " And when the noise compresses that volume too much.", "tokens": [51561, 400, 562, 264, 5658, 14778, 279, 300, 5523, 886, 709, 13, 51694], "temperature": 0.0, "avg_logprob": -0.18671841664357228, "compression_ratio": 1.7307692307692308, "no_speech_prob": 1.7007672397165163e-12}, {"id": 670, "seek": 246924, "start": 2469.24, "end": 2471.3599999999997, "text": " The states merge into a gray mush", "tokens": [50365, 440, 4368, 22183, 666, 257, 10855, 11559, 50471], "temperature": 0.0, "avg_logprob": -0.15834083877691701, "compression_ratio": 1.5952380952380953, "no_speech_prob": 1.8143914105525627e-12}, {"id": 671, "seek": 246924, "start": 2471.3599999999997, "end": 2474.24, "text": " and the information is permanently lost to the void.", "tokens": [50471, 293, 264, 1589, 307, 24042, 2731, 281, 264, 22009, 13, 50615], "temperature": 0.0, "avg_logprob": -0.15834083877691701, "compression_ratio": 1.5952380952380953, "no_speech_prob": 1.8143914105525627e-12}, {"id": 672, "seek": 246924, "start": 2474.7, "end": 2476.8799999999997, "text": " But human engineering doesn't just sit back", "tokens": [50638, 583, 1952, 7043, 1177, 380, 445, 1394, 646, 50747], "temperature": 0.0, "avg_logprob": -0.15834083877691701, "compression_ratio": 1.5952380952380953, "no_speech_prob": 1.8143914105525627e-12}, {"id": 673, "seek": 246924, "start": 2476.8799999999997, "end": 2477.9599999999996, "text": " and let the void win.", "tokens": [50747, 293, 718, 264, 22009, 1942, 13, 50801], "temperature": 0.0, "avg_logprob": -0.15834083877691701, "compression_ratio": 1.5952380952380953, "no_speech_prob": 1.8143914105525627e-12}, {"id": 674, "seek": 246924, "start": 2478.3999999999996, "end": 2479.2799999999997, "text": " We fight back.", "tokens": [50823, 492, 2092, 646, 13, 50867], "temperature": 0.0, "avg_logprob": -0.15834083877691701, "compression_ratio": 1.5952380952380953, "no_speech_prob": 1.8143914105525627e-12}, {"id": 675, "seek": 246924, "start": 2479.66, "end": 2481.9799999999996, "text": " We build structures to repair the damage.", "tokens": [50886, 492, 1322, 9227, 281, 10535, 264, 4344, 13, 51002], "temperature": 0.0, "avg_logprob": -0.15834083877691701, "compression_ratio": 1.5952380952380953, "no_speech_prob": 1.8143914105525627e-12}, {"id": 676, "seek": 246924, "start": 2482.2599999999998, "end": 2483.8199999999997, "text": " And this is where the book looks closely", "tokens": [51016, 400, 341, 307, 689, 264, 1446, 1542, 8185, 51094], "temperature": 0.0, "avg_logprob": -0.15834083877691701, "compression_ratio": 1.5952380952380953, "no_speech_prob": 1.8143914105525627e-12}, {"id": 677, "seek": 246924, "start": 2483.8199999999997, "end": 2486.58, "text": " at modern DRAM dynamic random access memory", "tokens": [51094, 412, 4363, 12118, 2865, 8546, 4974, 2105, 4675, 51232], "temperature": 0.0, "avg_logprob": -0.15834083877691701, "compression_ratio": 1.5952380952380953, "no_speech_prob": 1.8143914105525627e-12}, {"id": 678, "seek": 246924, "start": 2486.58, "end": 2489.04, "text": " and the error correcting codes we use to keep it alive.", "tokens": [51232, 293, 264, 6713, 47032, 14211, 321, 764, 281, 1066, 309, 5465, 13, 51355], "temperature": 0.0, "avg_logprob": -0.15834083877691701, "compression_ratio": 1.5952380952380953, "no_speech_prob": 1.8143914105525627e-12}, {"id": 679, "seek": 246924, "start": 2489.58, "end": 2491.5, "text": " D-gram is absolutely fascinating", "tokens": [51382, 413, 12, 1342, 307, 3122, 10343, 51478], "temperature": 0.0, "avg_logprob": -0.15834083877691701, "compression_ratio": 1.5952380952380953, "no_speech_prob": 1.8143914105525627e-12}, {"id": 680, "seek": 246924, "start": 2491.5, "end": 2494.3399999999997, "text": " because it's literally built on the leaky capacitor metaphor", "tokens": [51478, 570, 309, 311, 3736, 3094, 322, 264, 476, 15681, 29372, 19157, 51620], "temperature": 0.0, "avg_logprob": -0.15834083877691701, "compression_ratio": 1.5952380952380953, "no_speech_prob": 1.8143914105525627e-12}, {"id": 681, "seek": 246924, "start": 2494.3399999999997, "end": 2495.3599999999997, "text": " we talked about earlier.", "tokens": [51620, 321, 2825, 466, 3071, 13, 51671], "temperature": 0.0, "avg_logprob": -0.15834083877691701, "compression_ratio": 1.5952380952380953, "no_speech_prob": 1.8143914105525627e-12}, {"id": 682, "seek": 249536, "start": 2495.36, "end": 2497.96, "text": " It stores a single bit of vital data", "tokens": [50365, 467, 9512, 257, 2167, 857, 295, 11707, 1412, 50495], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 683, "seek": 249536, "start": 2497.96, "end": 2499.86, "text": " as a microscopic charge", "tokens": [50495, 382, 257, 47897, 4602, 50590], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 684, "seek": 249536, "start": 2499.86, "end": 2501.56, "text": " on a microscopic capacitor", "tokens": [50590, 322, 257, 47897, 29372, 50675], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 685, "seek": 249536, "start": 2501.56, "end": 2503.38, "text": " deep inside a silicon chip.", "tokens": [50675, 2452, 1854, 257, 22848, 11409, 13, 50766], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 686, "seek": 249536, "start": 2504.1600000000003, "end": 2505.42, "text": " But the capacitor leaks?", "tokens": [50805, 583, 264, 29372, 28885, 30, 50868], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 687, "seek": 249536, "start": 2506.0, "end": 2509.1200000000003, "text": " It is continuously, relentlessly subject", "tokens": [50897, 467, 307, 15684, 11, 34045, 12048, 3983, 51053], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 688, "seek": 249536, "start": 2509.1200000000003, "end": 2510.42, "text": " to thermodynamic decay.", "tokens": [51053, 281, 8810, 34988, 21039, 13, 51118], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 689, "seek": 249536, "start": 2510.94, "end": 2513.32, "text": " The trapped charge slowly bleeds away", "tokens": [51144, 440, 14994, 4602, 5692, 5408, 5147, 1314, 51263], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 690, "seek": 249536, "start": 2513.32, "end": 2514.1, "text": " into the substrate.", "tokens": [51263, 666, 264, 27585, 13, 51302], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 691, "seek": 249536, "start": 2514.36, "end": 2515.82, "text": " So what happens if you just leave it?", "tokens": [51315, 407, 437, 2314, 498, 291, 445, 1856, 309, 30, 51388], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 692, "seek": 249536, "start": 2516.1400000000003, "end": 2517.46, "text": " If the computer does nothing,", "tokens": [51404, 759, 264, 3820, 775, 1825, 11, 51470], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 693, "seek": 249536, "start": 2517.6400000000003, "end": 2519.6800000000003, "text": " the physical voltage representing the one", "tokens": [51479, 264, 4001, 8352, 13460, 264, 472, 51581], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 694, "seek": 249536, "start": 2519.6800000000003, "end": 2521.1600000000003, "text": " will eventually drain away", "tokens": [51581, 486, 4728, 12339, 1314, 51655], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 695, "seek": 249536, "start": 2521.1600000000003, "end": 2522.44, "text": " and merge into the zero,", "tokens": [51655, 293, 22183, 666, 264, 4018, 11, 51719], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 696, "seek": 249536, "start": 2522.94, "end": 2525.3, "text": " becoming an indistinguishable gray area", "tokens": [51744, 5617, 364, 1016, 468, 7050, 742, 712, 10855, 1859, 51862], "temperature": 0.0, "avg_logprob": -0.1750948390022653, "compression_ratio": 1.6548042704626333, "no_speech_prob": 2.167819960000039e-12}, {"id": 697, "seek": 252530, "start": 2525.3, "end": 2526.48, "text": " of lost information.", "tokens": [50365, 295, 2731, 1589, 13, 50424], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 698, "seek": 252530, "start": 2526.48, "end": 2528.3, "text": " So the computer has to constantly,", "tokens": [50424, 407, 264, 3820, 575, 281, 6460, 11, 50515], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 699, "seek": 252530, "start": 2528.6400000000003, "end": 2530.26, "text": " frantically read every single", "tokens": [50532, 431, 49505, 1401, 633, 2167, 50613], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 700, "seek": 252530, "start": 2530.26, "end": 2531.48, "text": " microscopic bit of memory", "tokens": [50613, 47897, 857, 295, 4675, 50674], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 701, "seek": 252530, "start": 2531.48, "end": 2532.48, "text": " on the entire chip", "tokens": [50674, 322, 264, 2302, 11409, 50724], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 702, "seek": 252530, "start": 2532.48, "end": 2534.5600000000004, "text": " and rewrite it back to full strength", "tokens": [50724, 293, 28132, 309, 646, 281, 1577, 3800, 50828], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 703, "seek": 252530, "start": 2534.5600000000004, "end": 2535.42, "text": " before it fades away.", "tokens": [50828, 949, 309, 32679, 1314, 13, 50871], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 704, "seek": 252530, "start": 2535.54, "end": 2535.78, "text": " Yes.", "tokens": [50877, 1079, 13, 50889], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 705, "seek": 252530, "start": 2536.0800000000004, "end": 2538.94, "text": " It is a continuous, hyperactive process", "tokens": [50904, 467, 307, 257, 10957, 11, 9848, 12596, 1399, 51047], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 706, "seek": 252530, "start": 2538.94, "end": 2540.1000000000004, "text": " of recursive continuation", "tokens": [51047, 295, 20560, 488, 29357, 51105], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 707, "seek": 252530, "start": 2540.1000000000004, "end": 2542.1000000000004, "text": " just to hold onto a single memory", "tokens": [51105, 445, 281, 1797, 3911, 257, 2167, 4675, 51205], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 708, "seek": 252530, "start": 2542.1000000000004, "end": 2543.04, "text": " for one more second.", "tokens": [51205, 337, 472, 544, 1150, 13, 51252], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 709, "seek": 252530, "start": 2543.28, "end": 2545.02, "text": " It is the circuit actively fighting", "tokens": [51264, 467, 307, 264, 9048, 13022, 5237, 51351], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 710, "seek": 252530, "start": 2545.02, "end": 2546.94, "text": " a war against entropy in real time,", "tokens": [51351, 257, 1516, 1970, 30867, 294, 957, 565, 11, 51447], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 711, "seek": 252530, "start": 2547.28, "end": 2548.46, "text": " millions of times a second.", "tokens": [51464, 6803, 295, 1413, 257, 1150, 13, 51523], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 712, "seek": 252530, "start": 2549.04, "end": 2550.7400000000002, "text": " But even with that constant refreshing,", "tokens": [51552, 583, 754, 365, 300, 5754, 19772, 11, 51637], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 713, "seek": 252530, "start": 2550.9, "end": 2552.54, "text": " sometimes a physical bit gets flipped anyway.", "tokens": [51645, 2171, 257, 4001, 857, 2170, 26273, 4033, 13, 51727], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 714, "seek": 252530, "start": 2552.9, "end": 2553.54, "text": " Oh, definitely.", "tokens": [51745, 876, 11, 2138, 13, 51777], "temperature": 0.0, "avg_logprob": -0.17947386323119238, "compression_ratio": 1.6731391585760518, "no_speech_prob": 1.4722216501450447e-12}, {"id": 715, "seek": 255354, "start": 2553.54, "end": 2557.22, "text": " A stray cosmic ray from space strikes the silicon", "tokens": [50365, 316, 36219, 27614, 18592, 490, 1901, 16750, 264, 22848, 50549], "temperature": 0.0, "avg_logprob": -0.17967126265816066, "compression_ratio": 1.7372549019607844, "no_speech_prob": 2.7886644816260686e-12}, {"id": 716, "seek": 255354, "start": 2557.22, "end": 2559.38, "text": " or a random thermal spike", "tokens": [50549, 420, 257, 4974, 15070, 21053, 50657], "temperature": 0.0, "avg_logprob": -0.17967126265816066, "compression_ratio": 1.7372549019607844, "no_speech_prob": 2.7886644816260686e-12}, {"id": 717, "seek": 255354, "start": 2559.38, "end": 2560.8, "text": " overcomes the capacitor.", "tokens": [50657, 670, 9055, 264, 29372, 13, 50728], "temperature": 0.0, "avg_logprob": -0.17967126265816066, "compression_ratio": 1.7372549019607844, "no_speech_prob": 2.7886644816260686e-12}, {"id": 718, "seek": 255354, "start": 2561.52, "end": 2562.98, "text": " And that is where Hamming Codes", "tokens": [50764, 400, 300, 307, 689, 8234, 2810, 383, 4789, 50837], "temperature": 0.0, "avg_logprob": -0.17967126265816066, "compression_ratio": 1.7372549019607844, "no_speech_prob": 2.7886644816260686e-12}, {"id": 719, "seek": 255354, "start": 2562.98, "end": 2564.22, "text": " come into the battlefield.", "tokens": [50837, 808, 666, 264, 21818, 13, 50899], "temperature": 0.0, "avg_logprob": -0.17967126265816066, "compression_ratio": 1.7372549019607844, "no_speech_prob": 2.7886644816260686e-12}, {"id": 720, "seek": 255354, "start": 2564.56, "end": 2567.2, "text": " Hamming Codes, the mathematical repair chain.", "tokens": [50916, 8234, 2810, 383, 4789, 11, 264, 18894, 10535, 5021, 13, 51048], "temperature": 0.0, "avg_logprob": -0.17967126265816066, "compression_ratio": 1.7372549019607844, "no_speech_prob": 2.7886644816260686e-12}, {"id": 721, "seek": 255354, "start": 2567.48, "end": 2569.16, "text": " A Hamming Code works by adding", "tokens": [51062, 316, 8234, 2810, 15549, 1985, 538, 5127, 51146], "temperature": 0.0, "avg_logprob": -0.17967126265816066, "compression_ratio": 1.7372549019607844, "no_speech_prob": 2.7886644816260686e-12}, {"id": 722, "seek": 255354, "start": 2569.16, "end": 2570.88, "text": " extra redundant parity bits", "tokens": [51146, 2857, 40997, 44747, 9239, 51232], "temperature": 0.0, "avg_logprob": -0.17967126265816066, "compression_ratio": 1.7372549019607844, "no_speech_prob": 2.7886644816260686e-12}, {"id": 723, "seek": 255354, "start": 2570.88, "end": 2572.7599999999998, "text": " to the raw data before it is stored.", "tokens": [51232, 281, 264, 8936, 1412, 949, 309, 307, 12187, 13, 51326], "temperature": 0.0, "avg_logprob": -0.17967126265816066, "compression_ratio": 1.7372549019607844, "no_speech_prob": 2.7886644816260686e-12}, {"id": 724, "seek": 255354, "start": 2573.2, "end": 2574.5, "text": " It creates a highly structured", "tokens": [51348, 467, 7829, 257, 5405, 18519, 51413], "temperature": 0.0, "avg_logprob": -0.17967126265816066, "compression_ratio": 1.7372549019607844, "no_speech_prob": 2.7886644816260686e-12}, {"id": 725, "seek": 255354, "start": 2574.5, "end": 2576.88, "text": " mathematical validate and repair chain.", "tokens": [51413, 18894, 29562, 293, 10535, 5021, 13, 51532], "temperature": 0.0, "avg_logprob": -0.17967126265816066, "compression_ratio": 1.7372549019607844, "no_speech_prob": 2.7886644816260686e-12}, {"id": 726, "seek": 255354, "start": 2577.24, "end": 2578.58, "text": " How does the validation work?", "tokens": [51550, 1012, 775, 264, 24071, 589, 30, 51617], "temperature": 0.0, "avg_logprob": -0.17967126265816066, "compression_ratio": 1.7372549019607844, "no_speech_prob": 2.7886644816260686e-12}, {"id": 727, "seek": 255354, "start": 2578.72, "end": 2580.58, "text": " When the computer reads the memory back,", "tokens": [51624, 1133, 264, 3820, 15700, 264, 4675, 646, 11, 51717], "temperature": 0.0, "avg_logprob": -0.17967126265816066, "compression_ratio": 1.7372549019607844, "no_speech_prob": 2.7886644816260686e-12}, {"id": 728, "seek": 258058, "start": 2580.58, "end": 2582.1, "text": " it first computes a syndrome", "tokens": [50365, 309, 700, 715, 1819, 257, 19371, 50441], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 729, "seek": 258058, "start": 2582.1, "end": 2583.36, "text": " to validate the data,", "tokens": [50441, 281, 29562, 264, 1412, 11, 50504], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 730, "seek": 258058, "start": 2583.92, "end": 2585.68, "text": " basically checking if the geometry", "tokens": [50532, 1936, 8568, 498, 264, 18426, 50620], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 731, "seek": 258058, "start": 2585.68, "end": 2587.6, "text": " of the math still adds up correctly.", "tokens": [50620, 295, 264, 5221, 920, 10860, 493, 8944, 13, 50716], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 732, "seek": 258058, "start": 2587.86, "end": 2589.22, "text": " If the syndrome is zero,", "tokens": [50729, 759, 264, 19371, 307, 4018, 11, 50797], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 733, "seek": 258058, "start": 2589.72, "end": 2590.68, "text": " all is well.", "tokens": [50822, 439, 307, 731, 13, 50870], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 734, "seek": 258058, "start": 2590.84, "end": 2591.52, "text": " And if it's not?", "tokens": [50878, 400, 498, 309, 311, 406, 30, 50912], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 735, "seek": 258058, "start": 2591.7, "end": 2593.0, "text": " If the syndrome is non-zero,", "tokens": [50921, 759, 264, 19371, 307, 2107, 12, 32226, 11, 50986], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 736, "seek": 258058, "start": 2593.16, "end": 2594.64, "text": " it means a bit has flipped.", "tokens": [50994, 309, 1355, 257, 857, 575, 26273, 13, 51068], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 737, "seek": 258058, "start": 2595.14, "end": 2597.16, "text": " The mathematical genius of the Hamming Code", "tokens": [51093, 440, 18894, 14017, 295, 264, 8234, 2810, 15549, 51194], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 738, "seek": 258058, "start": 2597.16, "end": 2598.44, "text": " is that the specific value", "tokens": [51194, 307, 300, 264, 2685, 2158, 51258], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 739, "seek": 258058, "start": 2598.44, "end": 2599.68, "text": " of the non-zero syndrome", "tokens": [51258, 295, 264, 2107, 12, 32226, 19371, 51320], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 740, "seek": 258058, "start": 2599.68, "end": 2602.18, "text": " points to exactly which specific bit flipped,", "tokens": [51320, 2793, 281, 2293, 597, 2685, 857, 26273, 11, 51445], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 741, "seek": 258058, "start": 2602.2999999999997, "end": 2604.02, "text": " and the computer simply flips it back.", "tokens": [51451, 293, 264, 3820, 2935, 40249, 309, 646, 13, 51537], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 742, "seek": 258058, "start": 2604.18, "end": 2605.62, "text": " Here's where it gets really interesting, though.", "tokens": [51545, 1692, 311, 689, 309, 2170, 534, 1880, 11, 1673, 13, 51617], "temperature": 0.0, "avg_logprob": -0.21751500620986475, "compression_ratio": 1.7575757575757576, "no_speech_prob": 2.4183448212727887e-12}, {"id": 743, "seek": 260562, "start": 2605.62, "end": 2607.94, "text": " The book asks a terrifying question.", "tokens": [50365, 440, 1446, 8962, 257, 18106, 1168, 13, 50481], "temperature": 0.0, "avg_logprob": -0.19938404776833274, "compression_ratio": 1.5611510791366907, "no_speech_prob": 2.1415540781694054e-12}, {"id": 744, "seek": 260562, "start": 2609.06, "end": 2611.8199999999997, "text": " What happens if two bits flip simultaneously?", "tokens": [50537, 708, 2314, 498, 732, 9239, 7929, 16561, 30, 50675], "temperature": 0.0, "avg_logprob": -0.19938404776833274, "compression_ratio": 1.5611510791366907, "no_speech_prob": 2.1415540781694054e-12}, {"id": 745, "seek": 260562, "start": 2612.2, "end": 2613.68, "text": " This raises an important question", "tokens": [50694, 639, 19658, 364, 1021, 1168, 50768], "temperature": 0.0, "avg_logprob": -0.19938404776833274, "compression_ratio": 1.5611510791366907, "no_speech_prob": 2.1415540781694054e-12}, {"id": 746, "seek": 260562, "start": 2613.68, "end": 2616.48, "text": " about the fundamental epistemological limits of repair.", "tokens": [50768, 466, 264, 8088, 2388, 43958, 4383, 10406, 295, 10535, 13, 50908], "temperature": 0.0, "avg_logprob": -0.19938404776833274, "compression_ratio": 1.5611510791366907, "no_speech_prob": 2.1415540781694054e-12}, {"id": 747, "seek": 260562, "start": 2617.08, "end": 2619.4, "text": " A standard Hamming 7-Water-4 code", "tokens": [50938, 316, 3832, 8234, 2810, 1614, 12, 54, 771, 12, 19, 3089, 51054], "temperature": 0.0, "avg_logprob": -0.19938404776833274, "compression_ratio": 1.5611510791366907, "no_speech_prob": 2.1415540781694054e-12}, {"id": 748, "seek": 260562, "start": 2619.4, "end": 2620.6, "text": " is geometrically designed", "tokens": [51054, 307, 12956, 81, 984, 4761, 51114], "temperature": 0.0, "avg_logprob": -0.19938404776833274, "compression_ratio": 1.5611510791366907, "no_speech_prob": 2.1415540781694054e-12}, {"id": 749, "seek": 260562, "start": 2620.6, "end": 2623.24, "text": " to only correct one single error.", "tokens": [51114, 281, 787, 3006, 472, 2167, 6713, 13, 51246], "temperature": 0.0, "avg_logprob": -0.19938404776833274, "compression_ratio": 1.5611510791366907, "no_speech_prob": 2.1415540781694054e-12}, {"id": 750, "seek": 260562, "start": 2623.58, "end": 2627.46, "text": " If two bits flip due to a massive cosmic ray strike,", "tokens": [51263, 759, 732, 9239, 7929, 3462, 281, 257, 5994, 27614, 18592, 9302, 11, 51457], "temperature": 0.0, "avg_logprob": -0.19938404776833274, "compression_ratio": 1.5611510791366907, "no_speech_prob": 2.1415540781694054e-12}, {"id": 751, "seek": 260562, "start": 2628.06, "end": 2630.02, "text": " the validation check still runs.", "tokens": [51487, 264, 24071, 1520, 920, 6676, 13, 51585], "temperature": 0.0, "avg_logprob": -0.19938404776833274, "compression_ratio": 1.5611510791366907, "no_speech_prob": 2.1415540781694054e-12}, {"id": 752, "seek": 260562, "start": 2630.3599999999997, "end": 2632.72, "text": " The math still blindly produces the syndrome,", "tokens": [51602, 440, 5221, 920, 47744, 14725, 264, 19371, 11, 51720], "temperature": 0.0, "avg_logprob": -0.19938404776833274, "compression_ratio": 1.5611510791366907, "no_speech_prob": 2.1415540781694054e-12}, {"id": 753, "seek": 260562, "start": 2632.94, "end": 2634.52, "text": " but because the geometry is broken,", "tokens": [51731, 457, 570, 264, 18426, 307, 5463, 11, 51810], "temperature": 0.0, "avg_logprob": -0.19938404776833274, "compression_ratio": 1.5611510791366907, "no_speech_prob": 2.1415540781694054e-12}, {"id": 754, "seek": 263452, "start": 2634.52, "end": 2637.64, "text": " the syndrome will point to the entirely wrong bit.", "tokens": [50365, 264, 19371, 486, 935, 281, 264, 7696, 2085, 857, 13, 50521], "temperature": 0.0, "avg_logprob": -0.15680411282707662, "compression_ratio": 1.7695035460992907, "no_speech_prob": 1.9129095009395858e-12}, {"id": 755, "seek": 263452, "start": 2637.8, "end": 2640.0, "text": " It's exactly like an overconfident spell checker.", "tokens": [50529, 467, 311, 2293, 411, 364, 670, 24697, 1078, 9827, 1520, 260, 13, 50639], "temperature": 0.0, "avg_logprob": -0.15680411282707662, "compression_ratio": 1.7695035460992907, "no_speech_prob": 1.9129095009395858e-12}, {"id": 756, "seek": 263452, "start": 2640.08, "end": 2640.56, "text": " It is.", "tokens": [50643, 467, 307, 13, 50667], "temperature": 0.0, "avg_logprob": -0.15680411282707662, "compression_ratio": 1.7695035460992907, "no_speech_prob": 1.9129095009395858e-12}, {"id": 757, "seek": 263452, "start": 2640.62, "end": 2641.7, "text": " If I am typing an email", "tokens": [50670, 759, 286, 669, 18444, 364, 3796, 50724], "temperature": 0.0, "avg_logprob": -0.15680411282707662, "compression_ratio": 1.7695035460992907, "no_speech_prob": 1.9129095009395858e-12}, {"id": 758, "seek": 263452, "start": 2641.7, "end": 2643.64, "text": " and I type te instead of the,", "tokens": [50724, 293, 286, 2010, 535, 2602, 295, 264, 11, 50821], "temperature": 0.0, "avg_logprob": -0.15680411282707662, "compression_ratio": 1.7695035460992907, "no_speech_prob": 1.9129095009395858e-12}, {"id": 759, "seek": 263452, "start": 2643.98, "end": 2646.78, "text": " the spell checker easily sees the single typo", "tokens": [50838, 264, 9827, 1520, 260, 3612, 8194, 264, 2167, 2125, 78, 50978], "temperature": 0.0, "avg_logprob": -0.15680411282707662, "compression_ratio": 1.7695035460992907, "no_speech_prob": 1.9129095009395858e-12}, {"id": 760, "seek": 263452, "start": 2646.78, "end": 2649.0, "text": " and perfectly silently fixes it.", "tokens": [50978, 293, 6239, 40087, 32539, 309, 13, 51089], "temperature": 0.0, "avg_logprob": -0.15680411282707662, "compression_ratio": 1.7695035460992907, "no_speech_prob": 1.9129095009395858e-12}, {"id": 761, "seek": 263452, "start": 2649.44, "end": 2652.18, "text": " But if I furiously misspell a word so badly,", "tokens": [51111, 583, 498, 286, 2687, 8994, 1713, 49241, 257, 1349, 370, 13425, 11, 51248], "temperature": 0.0, "avg_logprob": -0.15680411282707662, "compression_ratio": 1.7695035460992907, "no_speech_prob": 1.9129095009395858e-12}, {"id": 762, "seek": 263452, "start": 2652.7, "end": 2654.98, "text": " mashing the keyboard with two or three wrong letters,", "tokens": [51274, 2300, 571, 264, 10186, 365, 732, 420, 1045, 2085, 7825, 11, 51388], "temperature": 0.0, "avg_logprob": -0.15680411282707662, "compression_ratio": 1.7695035460992907, "no_speech_prob": 1.9129095009395858e-12}, {"id": 763, "seek": 263452, "start": 2655.4, "end": 2657.0, "text": " the spell checker might try to correct it", "tokens": [51409, 264, 9827, 1520, 260, 1062, 853, 281, 3006, 309, 51489], "temperature": 0.0, "avg_logprob": -0.15680411282707662, "compression_ratio": 1.7695035460992907, "no_speech_prob": 1.9129095009395858e-12}, {"id": 764, "seek": 263452, "start": 2657.0, "end": 2659.06, "text": " and accidentally swap in a completely valid,", "tokens": [51489, 293, 15715, 18135, 294, 257, 2584, 7363, 11, 51592], "temperature": 0.0, "avg_logprob": -0.15680411282707662, "compression_ratio": 1.7695035460992907, "no_speech_prob": 1.9129095009395858e-12}, {"id": 765, "seek": 263452, "start": 2659.46, "end": 2660.5, "text": " correctly spelled word", "tokens": [51612, 8944, 34388, 1349, 51664], "temperature": 0.0, "avg_logprob": -0.15680411282707662, "compression_ratio": 1.7695035460992907, "no_speech_prob": 1.9129095009395858e-12}, {"id": 766, "seek": 263452, "start": 2660.5, "end": 2662.7599999999998, "text": " that is entirely the wrong word for the sentence.", "tokens": [51664, 300, 307, 7696, 264, 2085, 1349, 337, 264, 8174, 13, 51777], "temperature": 0.0, "avg_logprob": -0.15680411282707662, "compression_ratio": 1.7695035460992907, "no_speech_prob": 1.9129095009395858e-12}, {"id": 767, "seek": 266276, "start": 2662.76, "end": 2665.82, "text": " And the industry term for that exact catastrophic failure", "tokens": [50365, 400, 264, 3518, 1433, 337, 300, 1900, 34915, 7763, 50518], "temperature": 0.0, "avg_logprob": -0.2041457494099935, "compression_ratio": 1.6896551724137931, "no_speech_prob": 1.8111229746833879e-12}, {"id": 768, "seek": 266276, "start": 2665.82, "end": 2667.6600000000003, "text": " is silent miscorrection.", "tokens": [50518, 307, 12784, 3346, 19558, 11417, 13, 50610], "temperature": 0.0, "avg_logprob": -0.2041457494099935, "compression_ratio": 1.6896551724137931, "no_speech_prob": 1.8111229746833879e-12}, {"id": 769, "seek": 266276, "start": 2668.1600000000003, "end": 2668.98, "text": " Silent miscorrection.", "tokens": [50635, 40862, 3346, 19558, 11417, 13, 50676], "temperature": 0.0, "avg_logprob": -0.2041457494099935, "compression_ratio": 1.6896551724137931, "no_speech_prob": 1.8111229746833879e-12}, {"id": 770, "seek": 266276, "start": 2669.46, "end": 2671.6200000000003, "text": " The system reports complete absolute success.", "tokens": [50700, 440, 1185, 7122, 3566, 8236, 2245, 13, 50808], "temperature": 0.0, "avg_logprob": -0.2041457494099935, "compression_ratio": 1.6896551724137931, "no_speech_prob": 1.8111229746833879e-12}, {"id": 771, "seek": 266276, "start": 2671.76, "end": 2674.1600000000003, "text": " The validation check passed with flying colors,", "tokens": [50815, 440, 24071, 1520, 4678, 365, 7137, 4577, 11, 50935], "temperature": 0.0, "avg_logprob": -0.2041457494099935, "compression_ratio": 1.6896551724137931, "no_speech_prob": 1.8111229746833879e-12}, {"id": 772, "seek": 266276, "start": 2674.5600000000004, "end": 2676.78, "text": " but the underlying history is completely corrupted.", "tokens": [50955, 457, 264, 14217, 2503, 307, 2584, 39480, 13, 51066], "temperature": 0.0, "avg_logprob": -0.2041457494099935, "compression_ratio": 1.6896551724137931, "no_speech_prob": 1.8111229746833879e-12}, {"id": 773, "seek": 266276, "start": 2677.2200000000003, "end": 2679.38, "text": " The memory is a perfect mathematical lie.", "tokens": [51088, 440, 4675, 307, 257, 2176, 18894, 4544, 13, 51196], "temperature": 0.0, "avg_logprob": -0.2041457494099935, "compression_ratio": 1.6896551724137931, "no_speech_prob": 1.8111229746833879e-12}, {"id": 774, "seek": 266276, "start": 2679.6200000000003, "end": 2682.6000000000004, "text": " Fliction emphasizes that this isn't just an engineering bug.", "tokens": [51208, 3235, 4105, 48856, 300, 341, 1943, 380, 445, 364, 7043, 7426, 13, 51357], "temperature": 0.0, "avg_logprob": -0.2041457494099935, "compression_ratio": 1.6896551724137931, "no_speech_prob": 1.8111229746833879e-12}, {"id": 775, "seek": 266276, "start": 2682.7200000000003, "end": 2685.78, "text": " It is a profound epistemological limit of the universe.", "tokens": [51363, 467, 307, 257, 14382, 2388, 43958, 4383, 4948, 295, 264, 6445, 13, 51516], "temperature": 0.0, "avg_logprob": -0.2041457494099935, "compression_ratio": 1.6896551724137931, "no_speech_prob": 1.8111229746833879e-12}, {"id": 776, "seek": 266276, "start": 2685.94, "end": 2687.1600000000003, "text": " Because it passed the test.", "tokens": [51524, 1436, 309, 4678, 264, 1500, 13, 51585], "temperature": 0.0, "avg_logprob": -0.2041457494099935, "compression_ratio": 1.6896551724137931, "no_speech_prob": 1.8111229746833879e-12}, {"id": 777, "seek": 266276, "start": 2687.5400000000004, "end": 2687.92, "text": " Right.", "tokens": [51604, 1779, 13, 51623], "temperature": 0.0, "avg_logprob": -0.2041457494099935, "compression_ratio": 1.6896551724137931, "no_speech_prob": 1.8111229746833879e-12}, {"id": 778, "seek": 266276, "start": 2688.48, "end": 2690.44, "text": " Admissibility is not the same thing as truth.", "tokens": [51651, 46292, 891, 2841, 307, 406, 264, 912, 551, 382, 3494, 13, 51749], "temperature": 0.0, "avg_logprob": -0.2041457494099935, "compression_ratio": 1.6896551724137931, "no_speech_prob": 1.8111229746833879e-12}, {"id": 779, "seek": 269044, "start": 2690.44, "end": 2694.06, "text": " Just because a signal passes a geometric validation check", "tokens": [50365, 1449, 570, 257, 6358, 11335, 257, 33246, 24071, 1520, 50546], "temperature": 0.0, "avg_logprob": -0.18091468811035155, "compression_ratio": 1.6411960132890366, "no_speech_prob": 2.298058661767688e-12}, {"id": 780, "seek": 269044, "start": 2694.06, "end": 2697.0, "text": " only means there is a lack of detected inconsistency.", "tokens": [50546, 787, 1355, 456, 307, 257, 5011, 295, 21896, 22039, 468, 3020, 13, 50693], "temperature": 0.0, "avg_logprob": -0.18091468811035155, "compression_ratio": 1.6411960132890366, "no_speech_prob": 2.298058661767688e-12}, {"id": 781, "seek": 269044, "start": 2697.44, "end": 2699.96, "text": " It doesn't mean it is the actual history of the universe.", "tokens": [50715, 467, 1177, 380, 914, 309, 307, 264, 3539, 2503, 295, 264, 6445, 13, 50841], "temperature": 0.0, "avg_logprob": -0.18091468811035155, "compression_ratio": 1.6411960132890366, "no_speech_prob": 2.298058661767688e-12}, {"id": 782, "seek": 269044, "start": 2700.14, "end": 2700.7200000000003, "text": " That is terrifying.", "tokens": [50850, 663, 307, 18106, 13, 50879], "temperature": 0.0, "avg_logprob": -0.18091468811035155, "compression_ratio": 1.6411960132890366, "no_speech_prob": 2.298058661767688e-12}, {"id": 783, "seek": 269044, "start": 2700.9, "end": 2704.38, "text": " The circuit can and will perfectly regenerate a false hister", "tokens": [50888, 440, 9048, 393, 293, 486, 6239, 26358, 473, 257, 7908, 702, 391, 51062], "temperature": 0.0, "avg_logprob": -0.18091468811035155, "compression_ratio": 1.6411960132890366, "no_speech_prob": 2.298058661767688e-12}, {"id": 784, "seek": 269044, "start": 2704.38, "end": 2707.92, "text": " if the noise pushes it into the wrong admissibility volume.", "tokens": [51062, 498, 264, 5658, 21020, 309, 666, 264, 2085, 5910, 891, 2841, 5523, 13, 51239], "temperature": 0.0, "avg_logprob": -0.18091468811035155, "compression_ratio": 1.6411960132890366, "no_speech_prob": 2.298058661767688e-12}, {"id": 785, "seek": 269044, "start": 2708.08, "end": 2710.6, "text": " This entire framework is incredibly neat.", "tokens": [51247, 639, 2302, 8388, 307, 6252, 10654, 13, 51373], "temperature": 0.0, "avg_logprob": -0.18091468811035155, "compression_ratio": 1.6411960132890366, "no_speech_prob": 2.298058661767688e-12}, {"id": 786, "seek": 269044, "start": 2710.8, "end": 2712.48, "text": " It ties together visual geometry,", "tokens": [51383, 467, 14039, 1214, 5056, 18426, 11, 51467], "temperature": 0.0, "avg_logprob": -0.18091468811035155, "compression_ratio": 1.6411960132890366, "no_speech_prob": 2.298058661767688e-12}, {"id": 787, "seek": 269044, "start": 2713.1, "end": 2714.9, "text": " complex calculus, thermodynamics,", "tokens": [51498, 3997, 33400, 11, 8810, 35483, 11, 51588], "temperature": 0.0, "avg_logprob": -0.18091468811035155, "compression_ratio": 1.6411960132890366, "no_speech_prob": 2.298058661767688e-12}, {"id": 788, "seek": 269044, "start": 2715.3, "end": 2716.5, "text": " biological synchronization,", "tokens": [51608, 13910, 19331, 2144, 11, 51668], "temperature": 0.0, "avg_logprob": -0.18091468811035155, "compression_ratio": 1.6411960132890366, "no_speech_prob": 2.298058661767688e-12}, {"id": 789, "seek": 269044, "start": 2716.98, "end": 2718.0, "text": " and computer science", "tokens": [51692, 293, 3820, 3497, 51743], "temperature": 0.0, "avg_logprob": -0.18091468811035155, "compression_ratio": 1.6411960132890366, "no_speech_prob": 2.298058661767688e-12}, {"id": 790, "seek": 269044, "start": 2718.0, "end": 2720.08, "text": " into one unified theory.", "tokens": [51743, 666, 472, 26787, 5261, 13, 51847], "temperature": 0.0, "avg_logprob": -0.18091468811035155, "compression_ratio": 1.6411960132890366, "no_speech_prob": 2.298058661767688e-12}, {"id": 791, "seek": 272008, "start": 2720.08, "end": 2721.84, "text": " It's a massive synthesis.", "tokens": [50365, 467, 311, 257, 5994, 30252, 13, 50453], "temperature": 0.0, "avg_logprob": -0.20888510994289233, "compression_ratio": 1.5423728813559323, "no_speech_prob": 1.741737721931702e-12}, {"id": 792, "seek": 272008, "start": 2722.16, "end": 2723.54, "text": " But maybe it's too neat.", "tokens": [50469, 583, 1310, 309, 311, 886, 10654, 13, 50538], "temperature": 0.0, "avg_logprob": -0.20888510994289233, "compression_ratio": 1.5423728813559323, "no_speech_prob": 1.741737721931702e-12}, {"id": 793, "seek": 272008, "start": 2723.74, "end": 2724.56, "text": " You know what scientists say?", "tokens": [50548, 509, 458, 437, 7708, 584, 30, 50589], "temperature": 0.0, "avg_logprob": -0.20888510994289233, "compression_ratio": 1.5423728813559323, "no_speech_prob": 1.741737721931702e-12}, {"id": 794, "seek": 272008, "start": 2725.08, "end": 2727.24, "text": " A theory that explains everything actually explains nothing.", "tokens": [50615, 316, 5261, 300, 13948, 1203, 767, 13948, 1825, 13, 50723], "temperature": 0.0, "avg_logprob": -0.20888510994289233, "compression_ratio": 1.5423728813559323, "no_speech_prob": 1.741737721931702e-12}, {"id": 795, "seek": 272008, "start": 2727.92, "end": 2730.0, "text": " If you could bend any random physical fact", "tokens": [50757, 759, 291, 727, 11229, 604, 4974, 4001, 1186, 50861], "temperature": 0.0, "avg_logprob": -0.20888510994289233, "compression_ratio": 1.5423728813559323, "no_speech_prob": 1.741737721931702e-12}, {"id": 796, "seek": 272008, "start": 2730.0, "end": 2732.2599999999998, "text": " to fit this ample twist and admissibility metaphor,", "tokens": [50861, 281, 3318, 341, 42857, 8203, 293, 5910, 891, 2841, 19157, 11, 50974], "temperature": 0.0, "avg_logprob": -0.20888510994289233, "compression_ratio": 1.5423728813559323, "no_speech_prob": 1.741737721931702e-12}, {"id": 797, "seek": 272008, "start": 2732.66, "end": 2734.16, "text": " is it actually a rigorous science,", "tokens": [50994, 307, 309, 767, 257, 29882, 3497, 11, 51069], "temperature": 0.0, "avg_logprob": -0.20888510994289233, "compression_ratio": 1.5423728813559323, "no_speech_prob": 1.741737721931702e-12}, {"id": 798, "seek": 272008, "start": 2734.2599999999998, "end": 2735.46, "text": " or is it just pretty poetry?", "tokens": [51074, 420, 307, 309, 445, 1238, 15155, 30, 51134], "temperature": 0.0, "avg_logprob": -0.20888510994289233, "compression_ratio": 1.5423728813559323, "no_speech_prob": 1.741737721931702e-12}, {"id": 799, "seek": 272008, "start": 2735.7, "end": 2738.56, "text": " Where does the author admit this massive framework falls apart?", "tokens": [51146, 2305, 775, 264, 3793, 9796, 341, 5994, 8388, 8804, 4936, 30, 51289], "temperature": 0.0, "avg_logprob": -0.20888510994289233, "compression_ratio": 1.5423728813559323, "no_speech_prob": 1.741737721931702e-12}, {"id": 800, "seek": 273856, "start": 2738.56, "end": 2741.92, "text": " This section is perhaps the most intellectually honest", "tokens": [50365, 639, 3541, 307, 4317, 264, 881, 46481, 3245, 50533], "temperature": 0.0, "avg_logprob": -0.15317042187006788, "compression_ratio": 1.7254901960784315, "no_speech_prob": 3.0450761270145454e-12}, {"id": 801, "seek": 273856, "start": 2741.92, "end": 2744.7599999999998, "text": " and structurally vital part of the entire book.", "tokens": [50533, 293, 6594, 6512, 11707, 644, 295, 264, 2302, 1446, 13, 50675], "temperature": 0.0, "avg_logprob": -0.15317042187006788, "compression_ratio": 1.7254901960784315, "no_speech_prob": 3.0450761270145454e-12}, {"id": 802, "seek": 273856, "start": 2745.4, "end": 2749.0, "text": " Flixian explicitly details seven specific failure modes", "tokens": [50707, 3235, 970, 952, 20803, 4365, 3407, 2685, 7763, 14068, 50887], "temperature": 0.0, "avg_logprob": -0.15317042187006788, "compression_ratio": 1.7254901960784315, "no_speech_prob": 3.0450761270145454e-12}, {"id": 803, "seek": 273856, "start": 2749.0, "end": 2751.52, "text": " where the continuation geometry framework", "tokens": [50887, 689, 264, 29357, 18426, 8388, 51013], "temperature": 0.0, "avg_logprob": -0.15317042187006788, "compression_ratio": 1.7254901960784315, "no_speech_prob": 3.0450761270145454e-12}, {"id": 804, "seek": 273856, "start": 2751.52, "end": 2753.2599999999998, "text": " either mathematically breaks down", "tokens": [51013, 2139, 44003, 9857, 760, 51100], "temperature": 0.0, "avg_logprob": -0.15317042187006788, "compression_ratio": 1.7254901960784315, "no_speech_prob": 3.0450761270145454e-12}, {"id": 805, "seek": 273856, "start": 2753.2599999999998, "end": 2755.1, "text": " or becomes so uselessly complicated", "tokens": [51100, 420, 3643, 370, 14115, 356, 6179, 51192], "temperature": 0.0, "avg_logprob": -0.15317042187006788, "compression_ratio": 1.7254901960784315, "no_speech_prob": 3.0450761270145454e-12}, {"id": 806, "seek": 273856, "start": 2755.1, "end": 2757.44, "text": " that it loses all explanatory power.", "tokens": [51192, 300, 309, 18293, 439, 9045, 4745, 1347, 13, 51309], "temperature": 0.0, "avg_logprob": -0.15317042187006788, "compression_ratio": 1.7254901960784315, "no_speech_prob": 3.0450761270145454e-12}, {"id": 807, "seek": 273856, "start": 2757.68, "end": 2760.6, "text": " Because a true theory must be capable of being wrong.", "tokens": [51321, 1436, 257, 2074, 5261, 1633, 312, 8189, 295, 885, 2085, 13, 51467], "temperature": 0.0, "avg_logprob": -0.15317042187006788, "compression_ratio": 1.7254901960784315, "no_speech_prob": 3.0450761270145454e-12}, {"id": 808, "seek": 273856, "start": 2760.7599999999998, "end": 2761.2999999999997, "text": " Exactly.", "tokens": [51475, 7587, 13, 51502], "temperature": 0.0, "avg_logprob": -0.15317042187006788, "compression_ratio": 1.7254901960784315, "no_speech_prob": 3.0450761270145454e-12}, {"id": 809, "seek": 273856, "start": 2761.72, "end": 2765.52, "text": " The author demands that a true theory must be capable of being wrong.", "tokens": [51523, 440, 3793, 15107, 300, 257, 2074, 5261, 1633, 312, 8189, 295, 885, 2085, 13, 51713], "temperature": 0.0, "avg_logprob": -0.15317042187006788, "compression_ratio": 1.7254901960784315, "no_speech_prob": 3.0450761270145454e-12}, {"id": 810, "seek": 276552, "start": 2765.52, "end": 2766.8, "text": " I deeply respect that.", "tokens": [50365, 286, 8760, 3104, 300, 13, 50429], "temperature": 0.0, "avg_logprob": -0.1888846830888228, "compression_ratio": 1.596774193548387, "no_speech_prob": 2.298076225842882e-12}, {"id": 811, "seek": 276552, "start": 2766.86, "end": 2767.46, "text": " It's like saying,", "tokens": [50432, 467, 311, 411, 1566, 11, 50462], "temperature": 0.0, "avg_logprob": -0.1888846830888228, "compression_ratio": 1.596774193548387, "no_speech_prob": 2.298076225842882e-12}, {"id": 812, "seek": 276552, "start": 2767.96, "end": 2770.86, "text": " I have built this beautiful, intricate glass castle,", "tokens": [50487, 286, 362, 3094, 341, 2238, 11, 38015, 4276, 14114, 11, 50632], "temperature": 0.0, "avg_logprob": -0.1888846830888228, "compression_ratio": 1.596774193548387, "no_speech_prob": 2.298076225842882e-12}, {"id": 813, "seek": 276552, "start": 2771.22, "end": 2773.94, "text": " and now here are the exact mathematical explosives", "tokens": [50650, 293, 586, 510, 366, 264, 1900, 18894, 46421, 50786], "temperature": 0.0, "avg_logprob": -0.1888846830888228, "compression_ratio": 1.596774193548387, "no_speech_prob": 2.298076225842882e-12}, {"id": 814, "seek": 276552, "start": 2773.94, "end": 2775.22, "text": " you can use to blow it up.", "tokens": [50786, 291, 393, 764, 281, 6327, 309, 493, 13, 50850], "temperature": 0.0, "avg_logprob": -0.1888846830888228, "compression_ratio": 1.596774193548387, "no_speech_prob": 2.298076225842882e-12}, {"id": 815, "seek": 276552, "start": 2775.58, "end": 2776.38, "text": " What are the explosives?", "tokens": [50868, 708, 366, 264, 46421, 30, 50908], "temperature": 0.0, "avg_logprob": -0.1888846830888228, "compression_ratio": 1.596774193548387, "no_speech_prob": 2.298076225842882e-12}, {"id": 816, "seek": 276552, "start": 2776.46, "end": 2777.64, "text": " The first major explosive", "tokens": [50912, 440, 700, 2563, 24630, 50971], "temperature": 0.0, "avg_logprob": -0.1888846830888228, "compression_ratio": 1.596774193548387, "no_speech_prob": 2.298076225842882e-12}, {"id": 817, "seek": 276552, "start": 2777.64, "end": 2779.9, "text": " is the breakdown of the scalar amp lit whist.", "tokens": [50971, 307, 264, 18188, 295, 264, 39684, 18648, 7997, 315, 468, 13, 51084], "temperature": 0.0, "avg_logprob": -0.1888846830888228, "compression_ratio": 1.596774193548387, "no_speech_prob": 2.298076225842882e-12}, {"id": 818, "seek": 276552, "start": 2780.24, "end": 2781.72, "text": " We spent a lot of time talking about", "tokens": [51101, 492, 4418, 257, 688, 295, 565, 1417, 466, 51175], "temperature": 0.0, "avg_logprob": -0.1888846830888228, "compression_ratio": 1.596774193548387, "no_speech_prob": 2.298076225842882e-12}, {"id": 819, "seek": 276552, "start": 2781.72, "end": 2783.24, "text": " how cascaded amplifiers", "tokens": [51175, 577, 3058, 66, 12777, 9731, 23463, 51251], "temperature": 0.0, "avg_logprob": -0.1888846830888228, "compression_ratio": 1.596774193548387, "no_speech_prob": 2.298076225842882e-12}, {"id": 820, "seek": 276552, "start": 2783.24, "end": 2785.64, "text": " beautifully multiply their amplitudes", "tokens": [51251, 16525, 12972, 641, 9731, 16451, 51371], "temperature": 0.0, "avg_logprob": -0.1888846830888228, "compression_ratio": 1.596774193548387, "no_speech_prob": 2.298076225842882e-12}, {"id": 821, "seek": 276552, "start": 2785.64, "end": 2786.58, "text": " and add their twists.", "tokens": [51371, 293, 909, 641, 35290, 13, 51418], "temperature": 0.0, "avg_logprob": -0.1888846830888228, "compression_ratio": 1.596774193548387, "no_speech_prob": 2.298076225842882e-12}, {"id": 822, "seek": 276552, "start": 2786.68, "end": 2786.94, "text": " Right.", "tokens": [51423, 1779, 13, 51436], "temperature": 0.0, "avg_logprob": -0.1888846830888228, "compression_ratio": 1.596774193548387, "no_speech_prob": 2.298076225842882e-12}, {"id": 823, "seek": 278694, "start": 2786.94, "end": 2789.82, "text": " But Flixian admits that simple math only works perfectly", "tokens": [50365, 583, 3235, 970, 952, 46682, 300, 2199, 5221, 787, 1985, 6239, 50509], "temperature": 0.0, "avg_logprob": -0.1339468582816746, "compression_ratio": 1.733788395904437, "no_speech_prob": 1.5610567309295997e-12}, {"id": 824, "seek": 278694, "start": 2789.82, "end": 2792.4, "text": " if the amplifiers are exactly perfectly matched,", "tokens": [50509, 498, 264, 9731, 23463, 366, 2293, 6239, 21447, 11, 50638], "temperature": 0.0, "avg_logprob": -0.1339468582816746, "compression_ratio": 1.733788395904437, "no_speech_prob": 1.5610567309295997e-12}, {"id": 825, "seek": 278694, "start": 2792.54, "end": 2795.1, "text": " meaning absolutely no signal reflects backwards", "tokens": [50645, 3620, 3122, 572, 6358, 18926, 12204, 50773], "temperature": 0.0, "avg_logprob": -0.1339468582816746, "compression_ratio": 1.733788395904437, "no_speech_prob": 1.5610567309295997e-12}, {"id": 826, "seek": 278694, "start": 2795.1, "end": 2795.94, "text": " between the stages.", "tokens": [50773, 1296, 264, 10232, 13, 50815], "temperature": 0.0, "avg_logprob": -0.1339468582816746, "compression_ratio": 1.733788395904437, "no_speech_prob": 1.5610567309295997e-12}, {"id": 827, "seek": 278694, "start": 2796.12, "end": 2798.54, "text": " Like water flowing through perfectly smooth pipes", "tokens": [50824, 1743, 1281, 13974, 807, 6239, 5508, 21882, 50945], "temperature": 0.0, "avg_logprob": -0.1339468582816746, "compression_ratio": 1.733788395904437, "no_speech_prob": 1.5610567309295997e-12}, {"id": 828, "seek": 278694, "start": 2798.54, "end": 2799.36, "text": " with no ridges.", "tokens": [50945, 365, 572, 3973, 2880, 13, 50986], "temperature": 0.0, "avg_logprob": -0.1339468582816746, "compression_ratio": 1.733788395904437, "no_speech_prob": 1.5610567309295997e-12}, {"id": 829, "seek": 278694, "start": 2799.78, "end": 2802.12, "text": " But if there is a physical mismatch in the impedance,", "tokens": [51007, 583, 498, 456, 307, 257, 4001, 23220, 852, 294, 264, 36264, 11, 51124], "temperature": 0.0, "avg_logprob": -0.1339468582816746, "compression_ratio": 1.733788395904437, "no_speech_prob": 1.5610567309295997e-12}, {"id": 830, "seek": 278694, "start": 2802.58, "end": 2804.7200000000003, "text": " the signal violently bounces back and forth", "tokens": [51147, 264, 6358, 46728, 46901, 646, 293, 5220, 51254], "temperature": 0.0, "avg_logprob": -0.1339468582816746, "compression_ratio": 1.733788395904437, "no_speech_prob": 1.5610567309295997e-12}, {"id": 831, "seek": 278694, "start": 2804.7200000000003, "end": 2807.2400000000002, "text": " between the stages, creating standing waves.", "tokens": [51254, 1296, 264, 10232, 11, 4084, 4877, 9417, 13, 51380], "temperature": 0.0, "avg_logprob": -0.1339468582816746, "compression_ratio": 1.733788395904437, "no_speech_prob": 1.5610567309295997e-12}, {"id": 832, "seek": 278694, "start": 2807.34, "end": 2808.64, "text": " And the simple math breaks.", "tokens": [51385, 400, 264, 2199, 5221, 9857, 13, 51450], "temperature": 0.0, "avg_logprob": -0.1339468582816746, "compression_ratio": 1.733788395904437, "no_speech_prob": 1.5610567309295997e-12}, {"id": 833, "seek": 278694, "start": 2808.64, "end": 2812.2000000000003, "text": " The math instantly explodes from simple scalar multiplication", "tokens": [51450, 440, 5221, 13518, 42610, 490, 2199, 39684, 27290, 51628], "temperature": 0.0, "avg_logprob": -0.1339468582816746, "compression_ratio": 1.733788395904437, "no_speech_prob": 1.5610567309295997e-12}, {"id": 834, "seek": 278694, "start": 2812.2000000000003, "end": 2814.78, "text": " into highly complex matrix algebra.", "tokens": [51628, 666, 5405, 3997, 8141, 21989, 13, 51757], "temperature": 0.0, "avg_logprob": -0.1339468582816746, "compression_ratio": 1.733788395904437, "no_speech_prob": 1.5610567309295997e-12}, {"id": 835, "seek": 281478, "start": 2814.78, "end": 2819.1600000000003, "text": " You can't just use a single, elegant amp lit whist operator anymore.", "tokens": [50365, 509, 393, 380, 445, 764, 257, 2167, 11, 21117, 18648, 7997, 315, 468, 12973, 3602, 13, 50584], "temperature": 0.0, "avg_logprob": -0.1650741829359827, "compression_ratio": 1.5907590759075907, "no_speech_prob": 2.184273812169679e-12}, {"id": 836, "seek": 281478, "start": 2819.7400000000002, "end": 2822.6800000000003, "text": " The simple visual geometric picture fails entirely,", "tokens": [50613, 440, 2199, 5056, 33246, 3036, 18199, 7696, 11, 50760], "temperature": 0.0, "avg_logprob": -0.1650741829359827, "compression_ratio": 1.5907590759075907, "no_speech_prob": 2.184273812169679e-12}, {"id": 837, "seek": 281478, "start": 2822.96, "end": 2825.34, "text": " and you are dragged back into the messy,", "tokens": [50774, 293, 291, 366, 25717, 646, 666, 264, 16191, 11, 50893], "temperature": 0.0, "avg_logprob": -0.1650741829359827, "compression_ratio": 1.5907590759075907, "no_speech_prob": 2.184273812169679e-12}, {"id": 838, "seek": 281478, "start": 2825.6200000000003, "end": 2828.2400000000002, "text": " calculating reality of scattering matrices.", "tokens": [50907, 28258, 4103, 295, 42314, 32284, 13, 51038], "temperature": 0.0, "avg_logprob": -0.1650741829359827, "compression_ratio": 1.5907590759075907, "no_speech_prob": 2.184273812169679e-12}, {"id": 839, "seek": 281478, "start": 2828.5800000000004, "end": 2830.48, "text": " What is another area where the metaphor collapses?", "tokens": [51055, 708, 307, 1071, 1859, 689, 264, 19157, 48765, 30, 51150], "temperature": 0.0, "avg_logprob": -0.1650741829359827, "compression_ratio": 1.5907590759075907, "no_speech_prob": 2.184273812169679e-12}, {"id": 840, "seek": 281478, "start": 2830.94, "end": 2832.32, "text": " Non-sinusoidal regimes.", "tokens": [51173, 8774, 12, 19767, 301, 17079, 304, 45738, 13, 51242], "temperature": 0.0, "avg_logprob": -0.1650741829359827, "compression_ratio": 1.5907590759075907, "no_speech_prob": 2.184273812169679e-12}, {"id": 841, "seek": 281478, "start": 2832.86, "end": 2834.5, "text": " The entire concept of the amp lit whist", "tokens": [51269, 440, 2302, 3410, 295, 264, 18648, 7997, 315, 468, 51351], "temperature": 0.0, "avg_logprob": -0.1650741829359827, "compression_ratio": 1.5907590759075907, "no_speech_prob": 2.184273812169679e-12}, {"id": 842, "seek": 281478, "start": 2834.5, "end": 2836.1400000000003, "text": " is built on the mathematical foundation", "tokens": [51351, 307, 3094, 322, 264, 18894, 7030, 51433], "temperature": 0.0, "avg_logprob": -0.1650741829359827, "compression_ratio": 1.5907590759075907, "no_speech_prob": 2.184273812169679e-12}, {"id": 843, "seek": 281478, "start": 2836.1400000000003, "end": 2838.96, "text": " of a smooth, continuous sine wave phaser.", "tokens": [51433, 295, 257, 5508, 11, 10957, 18609, 5772, 903, 17756, 13, 51574], "temperature": 0.0, "avg_logprob": -0.1650741829359827, "compression_ratio": 1.5907590759075907, "no_speech_prob": 2.184273812169679e-12}, {"id": 844, "seek": 281478, "start": 2839.1000000000004, "end": 2840.94, "text": " Like a perfect rolling ocean wave.", "tokens": [51581, 1743, 257, 2176, 9439, 7810, 5772, 13, 51673], "temperature": 0.0, "avg_logprob": -0.1650741829359827, "compression_ratio": 1.5907590759075907, "no_speech_prob": 2.184273812169679e-12}, {"id": 845, "seek": 281478, "start": 2841.0800000000004, "end": 2843.44, "text": " But look at a modern switching power supply,", "tokens": [51680, 583, 574, 412, 257, 4363, 16493, 1347, 5847, 11, 51798], "temperature": 0.0, "avg_logprob": -0.1650741829359827, "compression_ratio": 1.5907590759075907, "no_speech_prob": 2.184273812169679e-12}, {"id": 846, "seek": 284344, "start": 2843.44, "end": 2845.7000000000003, "text": " or the digital clock edge inside a CPU.", "tokens": [50365, 420, 264, 4562, 7830, 4691, 1854, 257, 13199, 13, 50478], "temperature": 0.0, "avg_logprob": -0.13788482791087667, "compression_ratio": 1.5732899022801303, "no_speech_prob": 2.1668086162135447e-12}, {"id": 847, "seek": 284344, "start": 2846.14, "end": 2847.34, "text": " Those aren't smooth waves.", "tokens": [50500, 3950, 3212, 380, 5508, 9417, 13, 50560], "temperature": 0.0, "avg_logprob": -0.13788482791087667, "compression_ratio": 1.5732899022801303, "no_speech_prob": 2.1668086162135447e-12}, {"id": 848, "seek": 284344, "start": 2847.46, "end": 2850.4, "text": " They are jagged, violent, near-instantaneous transitions", "tokens": [50566, 814, 366, 6368, 3004, 11, 11867, 11, 2651, 12, 48142, 15447, 23767, 50713], "temperature": 0.0, "avg_logprob": -0.13788482791087667, "compression_ratio": 1.5732899022801303, "no_speech_prob": 2.1668086162135447e-12}, {"id": 849, "seek": 284344, "start": 2850.4, "end": 2852.6, "text": " containing hundreds of high-frequency harmonics.", "tokens": [50713, 19273, 6779, 295, 1090, 12, 19325, 48154, 14750, 1167, 13, 50823], "temperature": 0.0, "avg_logprob": -0.13788482791087667, "compression_ratio": 1.5732899022801303, "no_speech_prob": 2.1668086162135447e-12}, {"id": 850, "seek": 284344, "start": 2853.1, "end": 2855.14, "text": " The single-phaser amp lit whist metaphor", "tokens": [50848, 440, 2167, 12, 950, 17756, 18648, 7997, 315, 468, 19157, 50950], "temperature": 0.0, "avg_logprob": -0.13788482791087667, "compression_ratio": 1.5732899022801303, "no_speech_prob": 2.1668086162135447e-12}, {"id": 851, "seek": 284344, "start": 2855.14, "end": 2857.52, "text": " completely collapses under its own weight", "tokens": [50950, 2584, 48765, 833, 1080, 1065, 3364, 51069], "temperature": 0.0, "avg_logprob": -0.13788482791087667, "compression_ratio": 1.5732899022801303, "no_speech_prob": 2.1668086162135447e-12}, {"id": 852, "seek": 284344, "start": 2857.52, "end": 2859.62, "text": " when you try to apply it to a jagged square wave.", "tokens": [51069, 562, 291, 853, 281, 3079, 309, 281, 257, 6368, 3004, 3732, 5772, 13, 51174], "temperature": 0.0, "avg_logprob": -0.13788482791087667, "compression_ratio": 1.5732899022801303, "no_speech_prob": 2.1668086162135447e-12}, {"id": 853, "seek": 284344, "start": 2859.8, "end": 2861.52, "text": " I was also struck by the failure mode", "tokens": [51183, 286, 390, 611, 13159, 538, 264, 7763, 4391, 51269], "temperature": 0.0, "avg_logprob": -0.13788482791087667, "compression_ratio": 1.5732899022801303, "no_speech_prob": 2.1668086162135447e-12}, {"id": 854, "seek": 284344, "start": 2861.52, "end": 2863.2400000000002, "text": " involving adaptive admissibility.", "tokens": [51269, 17030, 27912, 5910, 891, 2841, 13, 51355], "temperature": 0.0, "avg_logprob": -0.13788482791087667, "compression_ratio": 1.5732899022801303, "no_speech_prob": 2.1668086162135447e-12}, {"id": 855, "seek": 284344, "start": 2863.64, "end": 2866.7200000000003, "text": " We talked about analog filters acting as static gates", "tokens": [51375, 492, 2825, 466, 16660, 15995, 6577, 382, 13437, 19792, 51529], "temperature": 0.0, "avg_logprob": -0.13788482791087667, "compression_ratio": 1.5732899022801303, "no_speech_prob": 2.1668086162135447e-12}, {"id": 856, "seek": 284344, "start": 2866.7200000000003, "end": 2869.4, "text": " that rigidly decide what frequencies are admissible", "tokens": [51529, 300, 22195, 356, 4536, 437, 20250, 366, 5910, 41073, 51663], "temperature": 0.0, "avg_logprob": -0.13788482791087667, "compression_ratio": 1.5732899022801303, "no_speech_prob": 2.1668086162135447e-12}, {"id": 857, "seek": 286940, "start": 2869.4, "end": 2870.7400000000002, "text": " and what are refused.", "tokens": [50365, 293, 437, 366, 14654, 13, 50432], "temperature": 0.0, "avg_logprob": -0.20066659492358827, "compression_ratio": 1.6185567010309279, "no_speech_prob": 1.9852518066965086e-12}, {"id": 858, "seek": 286940, "start": 2871.5, "end": 2873.62, "text": " But modern adaptive electronic filters", "tokens": [50470, 583, 4363, 27912, 10092, 15995, 50576], "temperature": 0.0, "avg_logprob": -0.20066659492358827, "compression_ratio": 1.6185567010309279, "no_speech_prob": 1.9852518066965086e-12}, {"id": 859, "seek": 286940, "start": 2873.62, "end": 2877.34, "text": " constantly rewrite their own internal mathematical rules", "tokens": [50576, 6460, 28132, 641, 1065, 6920, 18894, 4474, 50762], "temperature": 0.0, "avg_logprob": -0.20066659492358827, "compression_ratio": 1.6185567010309279, "no_speech_prob": 1.9852518066965086e-12}, {"id": 860, "seek": 286940, "start": 2877.34, "end": 2879.7000000000003, "text": " based on the statistics of the incoming signal.", "tokens": [50762, 2361, 322, 264, 12523, 295, 264, 22341, 6358, 13, 50880], "temperature": 0.0, "avg_logprob": -0.20066659492358827, "compression_ratio": 1.6185567010309279, "no_speech_prob": 1.9852518066965086e-12}, {"id": 861, "seek": 286940, "start": 2880.1, "end": 2881.64, "text": " So the gate is constantly moving itself.", "tokens": [50900, 407, 264, 8539, 307, 6460, 2684, 2564, 13, 50977], "temperature": 0.0, "avg_logprob": -0.20066659492358827, "compression_ratio": 1.6185567010309279, "no_speech_prob": 1.9852518066965086e-12}, {"id": 862, "seek": 286940, "start": 2881.8, "end": 2881.92, "text": " Right.", "tokens": [50985, 1779, 13, 50991], "temperature": 0.0, "avg_logprob": -0.20066659492358827, "compression_ratio": 1.6185567010309279, "no_speech_prob": 1.9852518066965086e-12}, {"id": 863, "seek": 286940, "start": 2882.34, "end": 2885.2000000000003, "text": " The simple static geometry of an admissibility volume", "tokens": [51012, 440, 2199, 13437, 18426, 295, 364, 5910, 891, 2841, 5523, 51155], "temperature": 0.0, "avg_logprob": -0.20066659492358827, "compression_ratio": 1.6185567010309279, "no_speech_prob": 1.9852518066965086e-12}, {"id": 864, "seek": 286940, "start": 2885.2000000000003, "end": 2887.6, "text": " doesn't hold up when the physical landscape", "tokens": [51155, 1177, 380, 1797, 493, 562, 264, 4001, 9661, 51275], "temperature": 0.0, "avg_logprob": -0.20066659492358827, "compression_ratio": 1.6185567010309279, "no_speech_prob": 1.9852518066965086e-12}, {"id": 865, "seek": 286940, "start": 2887.6, "end": 2889.42, "text": " is aggressively shifting under your feet.", "tokens": [51275, 307, 32024, 17573, 833, 428, 3521, 13, 51366], "temperature": 0.0, "avg_logprob": -0.20066659492358827, "compression_ratio": 1.6185567010309279, "no_speech_prob": 1.9852518066965086e-12}, {"id": 866, "seek": 286940, "start": 2889.76, "end": 2892.02, "text": " And then there's the moment where the biological analogy", "tokens": [51383, 400, 550, 456, 311, 264, 1623, 689, 264, 13910, 21663, 51496], "temperature": 0.0, "avg_logprob": -0.20066659492358827, "compression_ratio": 1.6185567010309279, "no_speech_prob": 1.9852518066965086e-12}, {"id": 867, "seek": 286940, "start": 2892.02, "end": 2893.4, "text": " of the fireflies breaks down.", "tokens": [51496, 295, 264, 2610, 24471, 9857, 760, 13, 51565], "temperature": 0.0, "avg_logprob": -0.20066659492358827, "compression_ratio": 1.6185567010309279, "no_speech_prob": 1.9852518066965086e-12}, {"id": 868, "seek": 286940, "start": 2893.52, "end": 2893.7000000000003, "text": " Yeah.", "tokens": [51571, 865, 13, 51580], "temperature": 0.0, "avg_logprob": -0.20066659492358827, "compression_ratio": 1.6185567010309279, "no_speech_prob": 1.9852518066965086e-12}, {"id": 869, "seek": 286940, "start": 2893.94, "end": 2895.6800000000003, "text": " Chaos in chimera states.", "tokens": [51592, 32644, 294, 18375, 1663, 4368, 13, 51679], "temperature": 0.0, "avg_logprob": -0.20066659492358827, "compression_ratio": 1.6185567010309279, "no_speech_prob": 1.9852518066965086e-12}, {"id": 870, "seek": 289568, "start": 2895.68, "end": 2900.16, "text": " The elegant Kuramoto model assumes the population of fireflies", "tokens": [50365, 440, 21117, 16481, 35858, 2316, 37808, 264, 4415, 295, 2610, 24471, 50589], "temperature": 0.0, "avg_logprob": -0.12307614678735132, "compression_ratio": 1.6093189964157706, "no_speech_prob": 2.05226309037132e-12}, {"id": 871, "seek": 289568, "start": 2900.16, "end": 2903.2999999999997, "text": " either all eventually sync up into a beautiful rhythm", "tokens": [50589, 2139, 439, 4728, 20271, 493, 666, 257, 2238, 11801, 50746], "temperature": 0.0, "avg_logprob": -0.12307614678735132, "compression_ratio": 1.6093189964157706, "no_speech_prob": 2.05226309037132e-12}, {"id": 872, "seek": 289568, "start": 2903.2999999999997, "end": 2905.94, "text": " or they remain entirely disorganized.", "tokens": [50746, 420, 436, 6222, 7696, 717, 12372, 1602, 13, 50878], "temperature": 0.0, "avg_logprob": -0.12307614678735132, "compression_ratio": 1.6093189964157706, "no_speech_prob": 2.05226309037132e-12}, {"id": 873, "seek": 289568, "start": 2906.3599999999997, "end": 2909.62, "text": " But in real, physical, highly complex networks", "tokens": [50899, 583, 294, 957, 11, 4001, 11, 5405, 3997, 9590, 51062], "temperature": 0.0, "avg_logprob": -0.12307614678735132, "compression_ratio": 1.6093189964157706, "no_speech_prob": 2.05226309037132e-12}, {"id": 874, "seek": 289568, "start": 2909.62, "end": 2912.46, "text": " you get these terrifying things called chimera states.", "tokens": [51062, 291, 483, 613, 18106, 721, 1219, 18375, 1663, 4368, 13, 51204], "temperature": 0.0, "avg_logprob": -0.12307614678735132, "compression_ratio": 1.6093189964157706, "no_speech_prob": 2.05226309037132e-12}, {"id": 875, "seek": 289568, "start": 2912.62, "end": 2913.3599999999997, "text": " What's a chimera state?", "tokens": [51212, 708, 311, 257, 18375, 1663, 1785, 30, 51249], "temperature": 0.0, "avg_logprob": -0.12307614678735132, "compression_ratio": 1.6093189964157706, "no_speech_prob": 2.05226309037132e-12}, {"id": 876, "seek": 289568, "start": 2913.56, "end": 2916.16, "text": " This is where half the network is perfectly synchronized", "tokens": [51259, 639, 307, 689, 1922, 264, 3209, 307, 6239, 19331, 1602, 51389], "temperature": 0.0, "avg_logprob": -0.12307614678735132, "compression_ratio": 1.6093189964157706, "no_speech_prob": 2.05226309037132e-12}, {"id": 877, "seek": 289568, "start": 2916.16, "end": 2916.9199999999996, "text": " and working together", "tokens": [51389, 293, 1364, 1214, 51427], "temperature": 0.0, "avg_logprob": -0.12307614678735132, "compression_ratio": 1.6093189964157706, "no_speech_prob": 2.05226309037132e-12}, {"id": 878, "seek": 289568, "start": 2916.9199999999996, "end": 2920.7999999999997, "text": " and the other half is boiling in random, disconnected chaos.", "tokens": [51427, 293, 264, 661, 1922, 307, 16208, 294, 4974, 11, 29426, 14158, 13, 51621], "temperature": 0.0, "avg_logprob": -0.12307614678735132, "compression_ratio": 1.6093189964157706, "no_speech_prob": 2.05226309037132e-12}, {"id": 879, "seek": 289568, "start": 2920.98, "end": 2922.12, "text": " At the exact same time.", "tokens": [51630, 1711, 264, 1900, 912, 565, 13, 51687], "temperature": 0.0, "avg_logprob": -0.12307614678735132, "compression_ratio": 1.6093189964157706, "no_speech_prob": 2.05226309037132e-12}, {"id": 880, "seek": 289568, "start": 2922.3399999999997, "end": 2922.64, "text": " Yeah.", "tokens": [51698, 865, 13, 51713], "temperature": 0.0, "avg_logprob": -0.12307614678735132, "compression_ratio": 1.6093189964157706, "no_speech_prob": 2.05226309037132e-12}, {"id": 881, "seek": 292264, "start": 2922.64, "end": 2924.6, "text": " The simple order parameter,", "tokens": [50365, 440, 2199, 1668, 13075, 11, 50463], "temperature": 0.0, "avg_logprob": -0.13971317225489124, "compression_ratio": 1.5945017182130585, "no_speech_prob": 1.9091941569349125e-12}, {"id": 882, "seek": 292264, "start": 2924.8799999999997, "end": 2926.72, "text": " which is the single mathematical number", "tokens": [50477, 597, 307, 264, 2167, 18894, 1230, 50569], "temperature": 0.0, "avg_logprob": -0.13971317225489124, "compression_ratio": 1.5945017182130585, "no_speech_prob": 1.9091941569349125e-12}, {"id": 883, "seek": 292264, "start": 2926.72, "end": 2929.1, "text": " used to measure how synchronized the whole group is,", "tokens": [50569, 1143, 281, 3481, 577, 19331, 1602, 264, 1379, 1594, 307, 11, 50688], "temperature": 0.0, "avg_logprob": -0.13971317225489124, "compression_ratio": 1.5945017182130585, "no_speech_prob": 1.9091941569349125e-12}, {"id": 884, "seek": 292264, "start": 2929.54, "end": 2931.48, "text": " just becomes useless garbage data", "tokens": [50710, 445, 3643, 14115, 14150, 1412, 50807], "temperature": 0.0, "avg_logprob": -0.13971317225489124, "compression_ratio": 1.5945017182130585, "no_speech_prob": 1.9091941569349125e-12}, {"id": 885, "seek": 292264, "start": 2931.48, "end": 2933.8199999999997, "text": " when the network physically fragments", "tokens": [50807, 562, 264, 3209, 9762, 29197, 50924], "temperature": 0.0, "avg_logprob": -0.13971317225489124, "compression_ratio": 1.5945017182130585, "no_speech_prob": 1.9091941569349125e-12}, {"id": 886, "seek": 292264, "start": 2933.8199999999997, "end": 2935.18, "text": " its own geometry like that.", "tokens": [50924, 1080, 1065, 18426, 411, 300, 13, 50992], "temperature": 0.0, "avg_logprob": -0.13971317225489124, "compression_ratio": 1.5945017182130585, "no_speech_prob": 1.9091941569349125e-12}, {"id": 887, "seek": 292264, "start": 2935.72, "end": 2938.64, "text": " I want to focus on one specific failure mode", "tokens": [51019, 286, 528, 281, 1879, 322, 472, 2685, 7763, 4391, 51165], "temperature": 0.0, "avg_logprob": -0.13971317225489124, "compression_ratio": 1.5945017182130585, "no_speech_prob": 1.9091941569349125e-12}, {"id": 888, "seek": 292264, "start": 2938.64, "end": 2940.2799999999997, "text": " the book mentions at the very end", "tokens": [51165, 264, 1446, 23844, 412, 264, 588, 917, 51247], "temperature": 0.0, "avg_logprob": -0.13971317225489124, "compression_ratio": 1.5945017182130585, "no_speech_prob": 1.9091941569349125e-12}, {"id": 889, "seek": 292264, "start": 2940.2799999999997, "end": 2942.56, "text": " because I think it serves as the ultimate test", "tokens": [51247, 570, 286, 519, 309, 13451, 382, 264, 9705, 1500, 51361], "temperature": 0.0, "avg_logprob": -0.13971317225489124, "compression_ratio": 1.5945017182130585, "no_speech_prob": 1.9091941569349125e-12}, {"id": 890, "seek": 292264, "start": 2942.56, "end": 2944.44, "text": " for you, the listener, going forward.", "tokens": [51361, 337, 291, 11, 264, 31569, 11, 516, 2128, 13, 51455], "temperature": 0.0, "avg_logprob": -0.13971317225489124, "compression_ratio": 1.5945017182130585, "no_speech_prob": 1.9091941569349125e-12}, {"id": 891, "seek": 292264, "start": 2944.96, "end": 2947.66, "text": " Flickshin calls it the conceptual compactness criterion.", "tokens": [51481, 3235, 618, 2716, 259, 5498, 309, 264, 24106, 14679, 1287, 46691, 13, 51616], "temperature": 0.0, "avg_logprob": -0.13971317225489124, "compression_ratio": 1.5945017182130585, "no_speech_prob": 1.9091941569349125e-12}, {"id": 892, "seek": 292264, "start": 2947.92, "end": 2949.14, "text": " This is the real test.", "tokens": [51629, 639, 307, 264, 957, 1500, 13, 51690], "temperature": 0.0, "avg_logprob": -0.13971317225489124, "compression_ratio": 1.5945017182130585, "no_speech_prob": 1.9091941569349125e-12}, {"id": 893, "seek": 294914, "start": 2949.14, "end": 2953.22, "text": " Is this incredibly dense new vocabulary of amplet whists,", "tokens": [50365, 1119, 341, 6252, 18011, 777, 19864, 295, 9731, 302, 315, 1751, 11, 50569], "temperature": 0.0, "avg_logprob": -0.1629825168185764, "compression_ratio": 1.583916083916084, "no_speech_prob": 1.8182047664336287e-12}, {"id": 894, "seek": 294914, "start": 2953.66, "end": 2955.14, "text": " sphere pops, pop and refuse,", "tokens": [50591, 16687, 16795, 11, 1665, 293, 16791, 11, 50665], "temperature": 0.0, "avg_logprob": -0.1629825168185764, "compression_ratio": 1.583916083916084, "no_speech_prob": 1.8182047664336287e-12}, {"id": 895, "seek": 294914, "start": 2955.6, "end": 2958.02, "text": " admissibility volumes and recursive continuation", "tokens": [50688, 5910, 891, 2841, 22219, 293, 20560, 488, 29357, 50809], "temperature": 0.0, "avg_logprob": -0.1629825168185764, "compression_ratio": 1.583916083916084, "no_speech_prob": 1.8182047664336287e-12}, {"id": 896, "seek": 294914, "start": 2958.02, "end": 2960.7799999999997, "text": " actually make circuit theory simpler to use and understand", "tokens": [50809, 767, 652, 9048, 5261, 18587, 281, 764, 293, 1223, 50947], "temperature": 0.0, "avg_logprob": -0.1629825168185764, "compression_ratio": 1.583916083916084, "no_speech_prob": 1.8182047664336287e-12}, {"id": 897, "seek": 294914, "start": 2960.7799999999997, "end": 2964.46, "text": " or does it just add a massive pretentious conceptual burden?", "tokens": [50947, 420, 775, 309, 445, 909, 257, 5994, 1162, 317, 851, 24106, 12578, 30, 51131], "temperature": 0.0, "avg_logprob": -0.1629825168185764, "compression_ratio": 1.583916083916084, "no_speech_prob": 1.8182047664336287e-12}, {"id": 898, "seek": 294914, "start": 2964.6, "end": 2965.5, "text": " It's a fair question.", "tokens": [51138, 467, 311, 257, 3143, 1168, 13, 51183], "temperature": 0.0, "avg_logprob": -0.1629825168185764, "compression_ratio": 1.583916083916084, "no_speech_prob": 1.8182047664336287e-12}, {"id": 899, "seek": 294914, "start": 2965.8199999999997, "end": 2968.2999999999997, "text": " Does this framework take a simple 50 cent resistor", "tokens": [51199, 4402, 341, 8388, 747, 257, 2199, 2625, 1489, 37672, 51323], "temperature": 0.0, "avg_logprob": -0.1629825168185764, "compression_ratio": 1.583916083916084, "no_speech_prob": 1.8182047664336287e-12}, {"id": 900, "seek": 294914, "start": 2968.2999999999997, "end": 2971.48, "text": " and needlessly turn it into a profound philosophical crisis?", "tokens": [51323, 293, 643, 12048, 1261, 309, 666, 257, 14382, 25066, 5869, 30, 51482], "temperature": 0.0, "avg_logprob": -0.1629825168185764, "compression_ratio": 1.583916083916084, "no_speech_prob": 1.8182047664336287e-12}, {"id": 901, "seek": 294914, "start": 2971.92, "end": 2974.8399999999997, "text": " Flickshin's conclusion to that question is remarkably grounded.", "tokens": [51504, 3235, 618, 2716, 259, 311, 10063, 281, 300, 1168, 307, 37381, 23535, 13, 51650], "temperature": 0.0, "avg_logprob": -0.1629825168185764, "compression_ratio": 1.583916083916084, "no_speech_prob": 1.8182047664336287e-12}, {"id": 902, "seek": 297484, "start": 2974.84, "end": 2978.42, "text": " They state that if the vocabulary doesn't allow you to see physical", "tokens": [50365, 814, 1785, 300, 498, 264, 19864, 1177, 380, 2089, 291, 281, 536, 4001, 50544], "temperature": 0.0, "avg_logprob": -0.15385339019495411, "compression_ratio": 1.6594982078853047, "no_speech_prob": 2.5189975973172185e-12}, {"id": 903, "seek": 297484, "start": 2978.42, "end": 2981.6000000000004, "text": " and mathematical connections that were previously hidden from you,", "tokens": [50544, 293, 18894, 9271, 300, 645, 8046, 7633, 490, 291, 11, 50703], "temperature": 0.0, "avg_logprob": -0.15385339019495411, "compression_ratio": 1.6594982078853047, "no_speech_prob": 2.5189975973172185e-12}, {"id": 904, "seek": 297484, "start": 2982.06, "end": 2985.58, "text": " like the stunning connection between Adler's radio tubes", "tokens": [50726, 411, 264, 18550, 4984, 1296, 1999, 1918, 311, 6477, 21458, 50902], "temperature": 0.0, "avg_logprob": -0.15385339019495411, "compression_ratio": 1.6594982078853047, "no_speech_prob": 2.5189975973172185e-12}, {"id": 905, "seek": 297484, "start": 2985.58, "end": 2987.8, "text": " and Kuramoto's biological fireflies,", "tokens": [50902, 293, 16481, 35858, 311, 13910, 2610, 24471, 11, 51013], "temperature": 0.0, "avg_logprob": -0.15385339019495411, "compression_ratio": 1.6594982078853047, "no_speech_prob": 2.5189975973172185e-12}, {"id": 906, "seek": 297484, "start": 2988.2000000000003, "end": 2990.84, "text": " or the absolute thermodynamic necessity", "tokens": [51033, 420, 264, 8236, 8810, 34988, 24217, 51165], "temperature": 0.0, "avg_logprob": -0.15385339019495411, "compression_ratio": 1.6594982078853047, "no_speech_prob": 2.5189975973172185e-12}, {"id": 907, "seek": 297484, "start": 2990.84, "end": 2993.48, "text": " of logic gates destroying information,", "tokens": [51165, 295, 9952, 19792, 19926, 1589, 11, 51297], "temperature": 0.0, "avg_logprob": -0.15385339019495411, "compression_ratio": 1.6594982078853047, "no_speech_prob": 2.5189975973172185e-12}, {"id": 908, "seek": 297484, "start": 2993.98, "end": 2996.7400000000002, "text": " then you should discard the vocabulary and not use it.", "tokens": [51322, 550, 291, 820, 31597, 264, 19864, 293, 406, 764, 309, 13, 51460], "temperature": 0.0, "avg_logprob": -0.15385339019495411, "compression_ratio": 1.6594982078853047, "no_speech_prob": 2.5189975973172185e-12}, {"id": 909, "seek": 297484, "start": 2996.82, "end": 2998.54, "text": " So if it's not useful, drop it.", "tokens": [51464, 407, 498, 309, 311, 406, 4420, 11, 3270, 309, 13, 51550], "temperature": 0.0, "avg_logprob": -0.15385339019495411, "compression_ratio": 1.6594982078853047, "no_speech_prob": 2.5189975973172185e-12}, {"id": 910, "seek": 297484, "start": 2998.86, "end": 2999.2000000000003, "text": " Yes.", "tokens": [51566, 1079, 13, 51583], "temperature": 0.0, "avg_logprob": -0.15385339019495411, "compression_ratio": 1.6594982078853047, "no_speech_prob": 2.5189975973172185e-12}, {"id": 911, "seek": 297484, "start": 2999.6200000000003, "end": 3002.98, "text": " But the author's brutal honesty about these seven failure modes", "tokens": [51604, 583, 264, 3793, 311, 17878, 26839, 466, 613, 3407, 7763, 14068, 51772], "temperature": 0.0, "avg_logprob": -0.15385339019495411, "compression_ratio": 1.6594982078853047, "no_speech_prob": 2.5189975973172185e-12}, {"id": 912, "seek": 300298, "start": 3002.98, "end": 3005.2400000000002, "text": " is exactly what elevates this entire book", "tokens": [50365, 307, 2293, 437, 7701, 1024, 341, 2302, 1446, 50478], "temperature": 0.0, "avg_logprob": -0.12556532657507694, "compression_ratio": 1.6920529801324504, "no_speech_prob": 1.7249882078296253e-12}, {"id": 913, "seek": 300298, "start": 3005.2400000000002, "end": 3007.72, "text": " from being just a fun philosophical metaphor", "tokens": [50478, 490, 885, 445, 257, 1019, 25066, 19157, 50602], "temperature": 0.0, "avg_logprob": -0.12556532657507694, "compression_ratio": 1.6920529801324504, "no_speech_prob": 1.7249882078296253e-12}, {"id": 914, "seek": 300298, "start": 3007.72, "end": 3011.84, "text": " to being a rigorous, testable, physical theory.", "tokens": [50602, 281, 885, 257, 29882, 11, 1500, 712, 11, 4001, 5261, 13, 50808], "temperature": 0.0, "avg_logprob": -0.12556532657507694, "compression_ratio": 1.6920529801324504, "no_speech_prob": 1.7249882078296253e-12}, {"id": 915, "seek": 300298, "start": 3012.08, "end": 3013.94, "text": " It boldly bounds its own applicability.", "tokens": [50820, 467, 11928, 356, 29905, 1080, 1065, 2580, 2310, 13, 50913], "temperature": 0.0, "avg_logprob": -0.12556532657507694, "compression_ratio": 1.6920529801324504, "no_speech_prob": 1.7249882078296253e-12}, {"id": 916, "seek": 300298, "start": 3014.56, "end": 3015.72, "text": " It knows exactly what it is,", "tokens": [50944, 467, 3255, 2293, 437, 309, 307, 11, 51002], "temperature": 0.0, "avg_logprob": -0.12556532657507694, "compression_ratio": 1.6920529801324504, "no_speech_prob": 1.7249882078296253e-12}, {"id": 917, "seek": 300298, "start": 3015.82, "end": 3018.2, "text": " and more importantly, it knows exactly what it isn't.", "tokens": [51007, 293, 544, 8906, 11, 309, 3255, 2293, 437, 309, 1943, 380, 13, 51126], "temperature": 0.0, "avg_logprob": -0.12556532657507694, "compression_ratio": 1.6920529801324504, "no_speech_prob": 1.7249882078296253e-12}, {"id": 918, "seek": 300298, "start": 3018.64, "end": 3020.94, "text": " So let's bring this massive journey all together.", "tokens": [51148, 407, 718, 311, 1565, 341, 5994, 4671, 439, 1214, 13, 51263], "temperature": 0.0, "avg_logprob": -0.12556532657507694, "compression_ratio": 1.6920529801324504, "no_speech_prob": 1.7249882078296253e-12}, {"id": 919, "seek": 300298, "start": 3021.34, "end": 3024.32, "text": " A circuit board isn't just a static grid of metal and silicon", "tokens": [51283, 316, 9048, 3150, 1943, 380, 445, 257, 13437, 10748, 295, 5760, 293, 22848, 51432], "temperature": 0.0, "avg_logprob": -0.12556532657507694, "compression_ratio": 1.6920529801324504, "no_speech_prob": 1.7249882078296253e-12}, {"id": 920, "seek": 300298, "start": 3024.32, "end": 3025.7400000000002, "text": " sitting quietly in your pocket.", "tokens": [51432, 3798, 19141, 294, 428, 8963, 13, 51503], "temperature": 0.0, "avg_logprob": -0.12556532657507694, "compression_ratio": 1.6920529801324504, "no_speech_prob": 1.7249882078296253e-12}, {"id": 921, "seek": 300298, "start": 3026.08, "end": 3029.34, "text": " It is an active, dynamic, constantly churning battleground.", "tokens": [51520, 467, 307, 364, 4967, 11, 8546, 11, 6460, 417, 10656, 4635, 2921, 13, 51683], "temperature": 0.0, "avg_logprob": -0.12556532657507694, "compression_ratio": 1.6920529801324504, "no_speech_prob": 1.7249882078296253e-12}, {"id": 922, "seek": 300298, "start": 3029.6, "end": 3032.44, "text": " Capacitors and inductors act as lossy historians,", "tokens": [51696, 8363, 326, 9862, 293, 31612, 830, 605, 382, 4470, 88, 26442, 11, 51838], "temperature": 0.0, "avg_logprob": -0.12556532657507694, "compression_ratio": 1.6920529801324504, "no_speech_prob": 1.7249882078296253e-12}, {"id": 923, "seek": 303244, "start": 3032.44, "end": 3035.26, "text": " hoarding the tightly compressed mathematical integrals of the past.", "tokens": [50365, 45940, 278, 264, 21952, 30353, 18894, 3572, 1124, 295, 264, 1791, 13, 50506], "temperature": 0.0, "avg_logprob": -0.1717061143580491, "compression_ratio": 1.6644518272425248, "no_speech_prob": 1.734959832050409e-12}, {"id": 924, "seek": 303244, "start": 3035.68, "end": 3039.12, "text": " Logic gates and diodes act as irreversible shredders of information,", "tokens": [50527, 49898, 19792, 293, 1026, 4789, 605, 382, 16014, 840, 964, 21567, 15633, 295, 1589, 11, 50699], "temperature": 0.0, "avg_logprob": -0.1717061143580491, "compression_ratio": 1.6644518272425248, "no_speech_prob": 1.734959832050409e-12}, {"id": 925, "seek": 303244, "start": 3039.62, "end": 3042.7000000000003, "text": " hopelessly constrained by the inescapable, taxing laws", "tokens": [50724, 27317, 356, 38901, 538, 264, 294, 279, 9485, 712, 11, 3366, 278, 6064, 50878], "temperature": 0.0, "avg_logprob": -0.1717061143580491, "compression_ratio": 1.6644518272425248, "no_speech_prob": 1.734959832050409e-12}, {"id": 926, "seek": 303244, "start": 3042.7000000000003, "end": 3045.16, "text": " of thermodynamics and land hours bound.", "tokens": [50878, 295, 8810, 35483, 293, 2117, 2496, 5472, 13, 51001], "temperature": 0.0, "avg_logprob": -0.1717061143580491, "compression_ratio": 1.6644518272425248, "no_speech_prob": 1.734959832050409e-12}, {"id": 927, "seek": 303244, "start": 3045.4, "end": 3046.36, "text": " Oscillators are rhythmic,", "tokens": [51013, 17406, 373, 3391, 366, 46967, 11, 51061], "temperature": 0.0, "avg_logprob": -0.1717061143580491, "compression_ratio": 1.6644518272425248, "no_speech_prob": 1.734959832050409e-12}, {"id": 928, "seek": 303244, "start": 3046.8, "end": 3049.38, "text": " living pulses born from fixed-point geometry,", "tokens": [51083, 2647, 45279, 4232, 490, 6806, 12, 6053, 18426, 11, 51212], "temperature": 0.0, "avg_logprob": -0.1717061143580491, "compression_ratio": 1.6644518272425248, "no_speech_prob": 1.734959832050409e-12}, {"id": 929, "seek": 303244, "start": 3049.94, "end": 3052.14, "text": " governed by the exact same universal mathematics", "tokens": [51240, 35529, 538, 264, 1900, 912, 11455, 18666, 51350], "temperature": 0.0, "avg_logprob": -0.1717061143580491, "compression_ratio": 1.6644518272425248, "no_speech_prob": 1.734959832050409e-12}, {"id": 930, "seek": 303244, "start": 3052.14, "end": 3054.12, "text": " that coordinate the flashing of fireflies", "tokens": [51350, 300, 15670, 264, 31049, 295, 2610, 24471, 51449], "temperature": 0.0, "avg_logprob": -0.1717061143580491, "compression_ratio": 1.6644518272425248, "no_speech_prob": 1.734959832050409e-12}, {"id": 931, "seek": 303244, "start": 3054.12, "end": 3055.86, "text": " and the beating of human hearts.", "tokens": [51449, 293, 264, 13497, 295, 1952, 8852, 13, 51536], "temperature": 0.0, "avg_logprob": -0.1717061143580491, "compression_ratio": 1.6644518272425248, "no_speech_prob": 1.734959832050409e-12}, {"id": 932, "seek": 303244, "start": 3056.14, "end": 3056.88, "text": " And noise.", "tokens": [51550, 400, 5658, 13, 51587], "temperature": 0.0, "avg_logprob": -0.1717061143580491, "compression_ratio": 1.6644518272425248, "no_speech_prob": 1.734959832050409e-12}, {"id": 933, "seek": 303244, "start": 3057.36, "end": 3060.58, "text": " Noise isn't just a manufacturing accident or a bad connection.", "tokens": [51611, 44821, 1943, 380, 445, 257, 11096, 6398, 420, 257, 1578, 4984, 13, 51772], "temperature": 0.0, "avg_logprob": -0.1717061143580491, "compression_ratio": 1.6644518272425248, "no_speech_prob": 1.734959832050409e-12}, {"id": 934, "seek": 306058, "start": 3060.58, "end": 3063.92, "text": " It is the unavoidable thermodynamic cost", "tokens": [50365, 467, 307, 264, 36541, 17079, 712, 8810, 34988, 2063, 50532], "temperature": 0.0, "avg_logprob": -0.14575693926473302, "compression_ratio": 1.6345514950166113, "no_speech_prob": 1.9432276968101014e-12}, {"id": 935, "seek": 306058, "start": 3063.92, "end": 3066.7, "text": " of interacting with a warm, physical universe.", "tokens": [50532, 295, 18017, 365, 257, 4561, 11, 4001, 6445, 13, 50671], "temperature": 0.0, "avg_logprob": -0.14575693926473302, "compression_ratio": 1.6345514950166113, "no_speech_prob": 1.9432276968101014e-12}, {"id": 936, "seek": 306058, "start": 3066.96, "end": 3070.2599999999998, "text": " It is a pressure constantly compressing the volume of admissibility", "tokens": [50684, 467, 307, 257, 3321, 6460, 14778, 278, 264, 5523, 295, 5910, 891, 2841, 50849], "temperature": 0.0, "avg_logprob": -0.14575693926473302, "compression_ratio": 1.6345514950166113, "no_speech_prob": 1.9432276968101014e-12}, {"id": 937, "seek": 306058, "start": 3070.2599999999998, "end": 3072.66, "text": " until the circuit fights back with hamming codes,", "tokens": [50849, 1826, 264, 9048, 14512, 646, 365, 36600, 278, 14211, 11, 50969], "temperature": 0.0, "avg_logprob": -0.14575693926473302, "compression_ratio": 1.6345514950166113, "no_speech_prob": 1.9432276968101014e-12}, {"id": 938, "seek": 306058, "start": 3073.06, "end": 3075.98, "text": " silent miscorrections, and relentless D-Dram refreshes.", "tokens": [50989, 12784, 3346, 19558, 2554, 626, 11, 293, 46136, 413, 12, 35, 2356, 15134, 279, 13, 51135], "temperature": 0.0, "avg_logprob": -0.14575693926473302, "compression_ratio": 1.6345514950166113, "no_speech_prob": 1.9432276968101014e-12}, {"id": 939, "seek": 306058, "start": 3076.08, "end": 3079.58, "text": " The entire circuit board is a microscopic, beautiful microcosm", "tokens": [51140, 440, 2302, 9048, 3150, 307, 257, 47897, 11, 2238, 4532, 6877, 76, 51315], "temperature": 0.0, "avg_logprob": -0.14575693926473302, "compression_ratio": 1.6345514950166113, "no_speech_prob": 1.9432276968101014e-12}, {"id": 940, "seek": 306058, "start": 3080.2999999999997, "end": 3082.2, "text": " of the universal struggle against entropy.", "tokens": [51351, 295, 264, 11455, 7799, 1970, 30867, 13, 51446], "temperature": 0.0, "avg_logprob": -0.14575693926473302, "compression_ratio": 1.6345514950166113, "no_speech_prob": 1.9432276968101014e-12}, {"id": 941, "seek": 306058, "start": 3082.34, "end": 3082.98, "text": " It really is.", "tokens": [51453, 467, 534, 307, 13, 51485], "temperature": 0.0, "avg_logprob": -0.14575693926473302, "compression_ratio": 1.6345514950166113, "no_speech_prob": 1.9432276968101014e-12}, {"id": 942, "seek": 306058, "start": 3083.18, "end": 3084.16, "text": " I'm going to leave you with a thought.", "tokens": [51495, 286, 478, 516, 281, 1856, 291, 365, 257, 1194, 13, 51544], "temperature": 0.0, "avg_logprob": -0.14575693926473302, "compression_ratio": 1.6345514950166113, "no_speech_prob": 1.9432276968101014e-12}, {"id": 943, "seek": 306058, "start": 3084.62, "end": 3088.0, "text": " Extrapolating from an open problem poses the very end afflictions book.", "tokens": [51567, 9881, 4007, 401, 990, 490, 364, 1269, 1154, 26059, 264, 588, 917, 48287, 626, 1446, 13, 51736], "temperature": 0.0, "avg_logprob": -0.14575693926473302, "compression_ratio": 1.6345514950166113, "no_speech_prob": 1.9432276968101014e-12}